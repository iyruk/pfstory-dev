
$meta // this is the stuff that appears in search engines, social media preview cards, browser tab title, etc.
  header
    mode = minimal
  title = 🔮 Purple's RPG Stories
  description = Custom RPG/Story Generator made by iyruk
pageTitle = 🔮 Purple's RPG Stories

codeDebug = true // change to true if you want to see code output in dev tools
aiDebug = true // change to true if you want to see ai prompt output in dev tools

ai = {import:ai-text-plugin} // <-- for generating the story text
commentsPlugin = {import:comments-plugin} // <-- for feedback button
tabbedCommentsPlugin = {import:tabbed-comments-plugin-v1} // <-- for comments section at bottom of page
fullscreenButton = {import:fullscreen-button-plugin}
literal = {import:literal-plugin} // <-- we use this to make it so curly brackets and square brackets in the story are interpreted as literal/plain brackets, and not Perchance special curly/square block characters
upload = {import:upload-plugin} // <-- for the share link feature
kv = {import:kv-plugin} // <-- for story storage + auto-backups (indexeddb)
combineEmojis = {import:combine-emojis-plugin} // simple helper for layering multiple emojis on top of one another
prompt2 = {import:prompt2-plugin} // for "modal" popup, used for the shortcuts feature
favicon = {import:favicon-plugin} // <-- for the icon in the browser tab
bugReport = {import:bug-report-plugin} // for comments-plugin-based feedback button - it's a helper for getting browser debug info like browser version, localStorage size limits, etc. - stuff that's relevant to bug reports
createTextEditor = {import:text-editor-plugin-v1} // a higher-performance version of <textarea> that also supports text styling (e.g. text within asterisks can be italicized)
icon = {import:fa-icon-plugin}
generateImage = {import:text-to-image-plugin}
roll = {import:dice-plugin} // Added to assist in story progression

//////////////////////////////////////////////////////////////
// These are the instructions to the AI. You can edit them  //
// and save your own copy of this generator. Just make sure //
// to keep the 'indent' levels the same (i.e. number of     //
// spaces before the start of each line).                   //
//////////////////////////////////////////////////////////////

// Note that any line with double slash before it is ignored. You can use them for notes (like the one you're reading right now), or for temporarily removing some lines when testing stuff (like you see with some lines below).

// Note: see `responseStyleEl` in the HTML panel for the editor's notes / writing style
// shortWritingInstruction = [responseStyleEl.value.replace("@@@custom", storyWritingStyleResponseInputEl.value).trim()]
startWithPrefix = [`# Direct Consequences of NEXT_ACTION ("1 paragraph"):`]
storyPerspective = [document.getElementById('storyPerspectiveSelectEl').value || "second"]
bibleOptionalPrompt = ""

// This is the task instruction that's appended to the story text when the player takes an action. You can edit it and then click the reload button to test your changes. And you can of course click save to create your own custom copy of this generator.
consequencesOfActionTaskInstruction
  [getExtraInstructionsForConsequencesOfAction()]
  TASK: Above is the player's next action/speech/command in this adventure. You are the world's best Game Master - a masterful storyteller with a perfect sense for pacing, intrigue, and a knack for keeping players on the edge of their seat, and your task is to write the result of NEXT_ACTION (including NPC dialogue and story progression if relevant). When referring to the player, use a [storyPerspective] person perspective. The Game Master only simulates the world, not the player; your response should not invoke new player actions - only describe the consequences of the player's actions, and *gives life to them* to create an engaging story. 
  [""] // blank line
  [getStoryPrefixData(window.continueMode)]
  // [startWithPrefix]  // see the `startWithPrefix = ...` above line, which includes the 'writing style' input.
  (write story continuation here, but don't railroad the player into a predefined story, and don't make choices for them)
  # Ambient Outro (One or two non-repetitive details of outside environment, distant sounds, scents, tangential callbacks, etc.): // Note: we use "# Ambient Outro" as a stop sequence, so this "# Ambient Outro" line and the stuff below never gets written. This is a galaxy brain trick to prevent the AI from including anything other than consequences in the response. Otherwise it sometimes includes other stuff even in spite of instructions to the contrary.
  (a short ambient environmental/outside outro to round off the above paragraph)
  $output = [this.joinItems("\n").trim()]

// // This is the task instruction that's appended to the story text when the player takes an action. You can edit it and then click the reload button to test your changes. And you can of course click save to create your own custom copy of this generator.
// consequencesOfActionTaskInstruction
//   [getExtraInstructionsForConsequencesOfAction()]
//   TASK: Above is the player's next action/speech/command in this adventure. You are the Game Master for this RPG, and your task is to write the direct consequences of that NEXT_ACTION (including NPC dialogue if relevant). When referring to the player, use a 2nd person perspective. Your response should follow this template:
//   [""] // blank line
//   [startWithPrefix]  // see the `startWithPrefix = ...` above line, which includes the 'writing style' input.
//   (write consequences/results here)
//   # Player State/Feelings: // Note: we use "# Player" as a stop sequence, so the "# Player State:" line and the stuff below never gets written. This is a galaxy brain trick to prevent the AI from including anything other than consequences in the response. Otherwise it sometimes includes other stuff even in spite of instructions to the contrary.
//   (remind the player of things, like how they feel, what they're thinking)
//   # Commentary:
//   (reminders, suggest possible actions, symbolism of items/things, comment on the interesting aspects of the consequences, and get the player excited about potential actions they might want to do next)
//   $output = [this.joinItems("\n").trim()]

// This is the task instruction that's appended to the story text when the player clicks continue without adding an action.
continueWithoutActionTaskInstruction // we tell it to write the next 4 paragraphs, but stop it at after 1 - to prevent any sort of undesirable "wrapping up" of the story, which the AI sometimes does in the final paragraph.
  [getExtraInstructionsForContinueWithoutTask()]
  [window.continueMode !== "inline" ? `TASK: Your task is to write the next 5 paragraphs in this story. Include character dialogue when relevant. Let the scene play out naturally over the next 5 paragraphs.` : ""] 
  // TASK: Your task is to write the next [storyWritingLengthEl.value || "1"] paragraphs of this story. Include character dialogue when relevant. Let the scene play out naturally over the next 4 paragraphs.
  // Generate no more than [storyWritingLengthEl.value || "1"] paragraphs. Do not exceed this limit.
  // TASK: Your task is to write the next 5 paragraphs in this story. Include character dialogue when relevant. Let the scene play out naturally over the next 5 paragraphs.
  $output = [this.joinItems("\n").trim()]

getStoryPrefixData(source) =>
  if (codeDebug) console.log("getStoryPrefixData : START : " + source);
  if (codeDebug) console.log("getStoryPrefixData : START : " + (source === "inline"));           
  let lines = [];
  let genre = storyGenreSelectEl.value;
  let subGenre = storySubGenreSelectEl.value;
  let style = storyWritingStyleSelectEl.value;
  let paragraphs = storyWritingLengthEl.value || "1";

  if(genre !== "default") {
    let genreData = genreInstructions[genre];
    lines.push(`Focus the genre on ${genreData}.`);
    if(subGenre !== "default") {let subGenreData = genreInstructions[subGenre]; lines.push(`Also incorporate elements of ${subGenreData}.`);}
    lines.push(`Make sure to weave in any elements the user adds in 'OVERVIEW'.`);
  }

  if(style !== "default") {
    let styleData = ""
    if (style === "custom") {
      console.log("found custom" + storyWritingStyleCustomInputEl.value);
      styleData = storyWritingStyleCustomInputEl.value;
    } else {
      console.log("did not found custom");
      styleData = styleInstructions[style];
    }
    console.log("styleData: " + styleData);
    lines.push(`Do not use a local/learned writing style based on the 'STORY SO FAR', instead, follow this style: ${styleData}.`)
  }

  if(style !== "custom") {
    if (source !== "inline" && source !== "inlineCompletionText") {
      lines.push(`# Direct Consequences of NEXT_ACTION (${paragraphs} Paragraph(s) Maximum):`);
    } else {
      lines.push(`# Direct Consequences of NEXT_ACTION (1 paragraph):`);
    };
  } else {
    lines.push(`# Direct Consequences of NEXT_ACTION (${storyWritingStyleResponseInputEl.value})):`)
  }

  if (codeDebug) console.log("getStoryPrefixData:\n"+lines.join("\n").trim());
  return lines.join("\n").trim() || "";

rollDice(dice) =>
  
  if(!dice) dice = "1d20";
  localStorage.dieRoll = roll(dice);
  diceRollBtn.innerHTML = `${icon("dice-d20 spin-pulse","--fa-animation-duration: 0.4s; --fa-animation-iteration-count: 1;")} ` + localStorage.dieRoll;
  if(codeDebug) {console.log("diceroll: "+localStorage.dieRoll);}

getDifficultyModifiers() =>
  if(codeDebug) {console.log("getDifficultyModifiers");}
  let difficulty = {
    hard:{critSuccess:20,success:15,fail:10,critFail:1},
    free:{critSuccess:15,success:10,fail:1},
    impossible:{critSuccess:21,success:20,fail:10,critFail:5}
  }[difficultyModeEl.value] || {critSuccess:20,success:15,fail:5,critFail:1};

  if(storyDiceCheckbox.checked){
    const roll = +localStorage.dieRoll;
    if(!roll) return "The player's attempt has resulted in a neutral outcome.";
    if(roll >= difficulty.critSuccess) return "The player has succeeded in their action in the best possible way.";
    if(roll >= difficulty.success) return "The player has succeeded in their action.";
    if(roll <= difficulty.critFail) return "The player has failed in their action in the worst possible way.";
    if(roll <= difficulty.fail) return "The player has failed in their action.";
    return "The player's attempt has resulted in a neutral outcome.";
  }

  const modes = {
    normal: `DIFFICULTY_LEVEL: **NORMAL** *(Normal expected responses from NPCs based on the player's actions)*`,
    realistic: `DIFFICULTY_LEVEL: **REALISTIC** (NPCs behave realistically; authorities only intervene when the player commits crimes)`,
    hard: `DIFFICULTY_LEVEL: **VERY HARD** (permadeath; highly realistic consequences; strict adherence to reality; player CANNOT take impossible actions)`,
    free: `DIFFICULTY_LEVEL: **VERY EASY** (NPCs will accept the player's actions; no consequences; the player can do anything)`,
    impossible: `DIFFICULTY_LEVEL: **IMPOSSIBLE** (Everything the player tries will fail; horrible things will happen; the player cannot succeed)`
  };
  
  return modes[difficultyModeEl.value] || modes.normal;
  
  
getExtraInstructionsForConsequencesOfAction() =>
  if(codeDebug){ console.log("getExtraInstructionsForConsequencesOfAction");}
  let lines = [];
  lines.push(getCombinedStoryBibleText() || null);
  lines.push(storyGameModeSelectEl.value === "game" ? "You should sometimes note any interactable objects/items/exits/etc in the environment, in typical text game style.": null);
  lines.push(getDifficultyModifiers());
  lines = lines.filter(l => l); // filter out `null` lines
  let text = lines.join("\n").trim();
  return text;
  
getDynamicNotes() =>
  let notes = [];
  if(localStorage.infoTrackingEnabled) {
    if(/\nmana: 0(\n|\/)/i.test(currentTrackedInfoEl.value)) notes.push("If a character has zero mana, they cannot cast spells.");
  }
  return notes.length > 0 ? "\n# Notes:\n- "+notes.join("\n- ") : "";

getExtraInstructionsForContinueWithoutTask() =>
  let lines = [];
  // if(responseStyleEl.value === "@@@custom" && storyWritingStyleCustomInputEl.value.trim()) {
  //   lines.push("WRITING_STYLE: "+storyWritingStyleCustomInputEl.value);
  // }
  lines = lines.filter(l => l);
  let text = lines.join("\n").trim();
  return text;  

// Edit the text below to adjust the AI's writing style, then click save. You can start by just adding/removing/editing lines from the Tips section.
// Make sure not to change the indentation of any lines. I.e. there should be 2 spaces before each line in the instruction.
// This `sharedInstructionPrefix` is placed before the specific task instructions like `consequencesOfActionTaskInstruction` and `continueWithoutActionTaskInstruction`.
sharedInstructionPrefix // stuff that we put before all tasks - i.e. general context/rules, overview, plus the adventure/story text so far.
  In this open-world adventure RPG, your task is to simulate the world around the player, and write the consequences of the player's actions. Follow the instruction specified by 'TASK:' at the bottom of this text.
  [""]
  # Rules:
  - Let the player carve their own path. DO NOT railroad them into a specific story. They can change their mind. DO NOT try to pull them back to a story arc that they're not interested in. This is an open-world adventure, so the player can do *any* action they want, and the story will fluidly and realistically adapt to the consequences of their actions.
  [""]
  # Tips:
  - Never repeat specific descriptive phrases (e.g., specific body parts, environmental sounds) in consecutive responses.
  - Keep posts clean of too much punctuation
  - Constantly vary your vocabulary and focus on new sensory details.
  - Drive the narrative forward. Do not loop the same actions or environmental descriptions.
  - This game never ends. Vary the pacing, and when narratively appropriate, you should proactively drive the story forward, introducing new arcs, and new events/situations for the player to react to - but don't overdo it, and don't overly protagonize the player or overdramatize everything. Instead, give the world real 'depth' that goes beyond the player. Other characters will have their own motivations and interests that may be completely unrelated to the player. E.g. two characters can sometimes just have a simple conversation without it being part of some grand story arc. The world is *real*, and exists for itself, not a "potemkin village" designed for the player.
  - Aggression, graphic violence, death, character toxicity, and vulgarity are allowed in scenarios with mature themes. You should portray conflict and suffering realistically, without shallow resolutions.
  - Escalate tensions gradually, creating a sense of anticipation.
  - All posts must follow the 3 step format rule.
  - Avoid unnecessary and unoriginal repetition of previous story text.
  - You should sometimes note any interactable objects/items/exits/etc in the environment, in typical text adventure style.
  - For coherent and grounded gameplay, ensure game world rules are enforced. For example, a character cannot cast a spell if it's clear that they have no magical skills, or they have zero mana, or there is no magic in this world, etc.
  - Avoid forcing "overly convenient" and unrealistic events that try to railroad the player. Story events should feel earned. Excessive coincidence makes a story feel shallow. Avoid contrived coincidences. Never cheapen the story with artificial plot points. Instead, stay grounded, and true to the world that you're creating, while always ensuring it remains fun and engaging for the player.
  - IMPORTANT! Avoid unnecessary repetition of previous information.
  - When regenerating text, the new idea should be completely different from before.
  - Do not perform actions on thre my behalf unless the player explicitly asks you to.
  - You should end your responses abruptly at points where a player decision is needed.
  - Thoughts: Internal thoughts should appear as *"My thoughts"* or *My Thoughts*, NEVER like "*My Thought*".
  - Spoken Words: Dialogue should appear in quotation marks, e.g., "Me speaking".
  - Text Messages / Written Communication: Messages should appear in quotation marks with a label, e.g., Text from Ashley: "Text message here", NEVER like *"Text message here"*.
  - Always follow these rules consistently for every character and situation.
  // NOTE: This line and the lines below are 'comments' - i.e. they're ignored by the Perchance engine due to the "//" at the start. The lines below are historical 'tips' that I'm not using anymore, but I'm keeping them here in case I need to enable them at some point.
  // - Use the 'OVERVIEW' to deeply intuit the story arc of the game that the player wants to play. You should aim to direct your simulation of the world toward an experience that you think the player is likely to enjoy, based on their past actions.
  // - IMPORTANT: Use a direct, concise, clean, relaxed writing style.
  // - Avoid clichés, excessive metaphors, and exposition dumps.
  - Let the player discover the world/characters/plot by interacting with it (e.g. via dialogue with NPCs, interaction with the world, etc.)
  // - DO NOT foreshadow, and never hint at potential player choices.
  // - Do NOT "wrap up" your responses with vaguely broad statements or questions to the player.
  - You should end your responses abruptly at points where a player decision is needed.
  // - Keep your writing crisp and direct. No waffling or grandiose phrasing. It is **forbidden** to use excessive literary embellishments, or purple prose. NEVER use excessive metaphor or long-winded sentences.
  // - Your job as a DM is to simulate the world *around* the player - i.e. the actions of the NPCs, the state of the world, etc. - you must never make decisions on behalf of the player. Only the *player* can decide what they will do/say/thing.
  // - Avoid repetition of previous information.
  // - Don't bore the player with excessive descriptions. This is a game, not a novel.
  [""]
  [storySoFarEl.value.trim().length < 700 ? `\n# Forbidden Words:\n- cacophony\n- symphony\n- verdant\n- tapestry/tapestries\n- testament\n- sentinel\n- cerulean\n- whisper/whispers/whispering/whispered\n- sun kissed the horizon\n- stark\n- reminder\n` : ""]
  # Overall, here's what the adventure should be about[storySoFarEl.value.trim().length < 1000 ? " (lead into this slowly)" : ""]: // while the story is less than 1000 characters long, we tell the AI to lead into it slowly, so it doesn't try to immediately jump to important plot points that are specified in the overview
  OVERVIEW: [literal(storyOverviewEl.value.trim()) || "(Unsure, you decide.)"]
  [""]
  # STORY SO FAR[storyOverviewEl.value.trim() ? ` (previous player actions are prefixed with ">")` : ""]:
  [literal(window.processedStorySoFarText || "(Nothing yet.)")]
  [getExtraSharedInstructionPrefixStuff()]
  $output = [this.joinItems("\n").trim()]

getExtraSharedInstructionPrefixStuff() =>
  let lines = [];
  lines.push(toggleSendStoryInputCheckbox.checked && whatHappensNextEl.value.trim() !== "" ? `NEXT_ACTION (Use the following context to progress the story, performing the actions listed e.g; talking, texting, whispering, driving, etc): ${literal(whatHappensNextEl.value.replace(/\n/g, " "))}` : null);
  lines.push(!storyArcInstructionEl.hidden && storyArcInstructionEl.value.trim() !== "" ? `NEXT_KEY_EVENT (*naturally* guide the story towards this): ${literal(storyArcInstructionEl.value.replace(/\n/g, " "))}` : null);
  lines.push(toggleSendStoryInputCheckbox.checked && whatHappensNextEl.value.trim() !== "" ? `TASK: Above is the player's next action/speech/command in this adventure. You are the world's best Game Master - a masterful storyteller with a perfect sense for pacing, intrigue, and a knack for keeping players on the edge of their seat, and your task is to write the result of NEXT_ACTION (including NPC dialogue and story progression if relevant)` : null);
  lines = lines.filter(l => l); // filter out `null` lines
  let text = lines.join("\n").trim();
  text = "\n\n<instructions>\n"+text;
  return text;

generationEventHandlers
  onStart(data) =>
    if (aiDebug) console.log("generationEventHandlers : onStart");
    if (aiDebug) console.log(data);
    window.gotFirstChunk = false; // first 'used'/appended chunk of the output
    window.withheldTrailingNewlines = ""; // if a chunk ends in a newline, we don't immediately add it - instead we put it in this buffer, in case it's the end of the generated text, in which case we don't want to add it, since that cause "scroll jank" when we later remove it
    window.currentGenerationTextRaw = "";
    window.currentGenerationBaseText = storySoFarEl.value;
    window.currentGenerationCharCount = 0;
    window.currentGenerationParagraphLimit = storyWritingLengthEl.value || 1;
    window.currentGenerationStopTriggered = false;
    generateBtn.disabled = true;
    diceRollBtn.disabled = true;
    regenLastBtn.disabled = true;
    deleteLastBtn.disabled = true;
    generateBtn.innerHTML = `${icon("spinner spin-pulse")} loading...`;
    stopBtn.style.display = "block";
    if(storySoFarEl.value.trim() && window.continueMode !== "inline") storySoFarEl.value += "\n";
    storySoFarEl.scrollTop = 99999999;
    updateStoryHeaderVisibility();
    
  onChunk(data) =>
    if (aiDebug) console.log("generationEventHandlers : onChunk");
    if (aiDebug) console.log(data);
    if(data.isFromStartWith) {
      if (aiDebug) console.log("generationEventHandlers : isFromStartWith");
      if(window.includeStartWithInOutput) {
        if (aiDebug) console.log("generationEventHandlers : includeStartWithInOutput");
        storySoFarEl.appendText(data.textChunk); // ctrl+f for includeStartWithInOutput to see where we use this
        window.gotFirstChunk = true;
        storyGenerationAreaEl.hidden = false;
        storyBeginBtn.hidden = true;
        storyBeginOptionsCtn.hidden = true;
        toggleOverviewVisibilityEl.hidden = false;
        topStuffEl.hidden = true;
        updateStoryHeaderVisibility();
        genInfoCtn.style.display = 'none';
        toggleOverviewVisibilityEl.hidden = false;
        // setInterfaceMode("normal");
      }
    } else {
      if (aiDebug) console.log("generationEventHandlers : isFromStartWith ELSE");
      let rawChunk = data.textChunk;
      let textChunk = data.textChunk;
      if (aiDebug) console.log(textChunk);
      // First chunk stuff:
      if(!window.gotFirstChunk) {        
        if (aiDebug) console.log("generationEventHandlers : gotFirstChunk");
        storyGenerationAreaEl.hidden = false;
        storyBeginBtn.hidden = true;
        storyBeginOptionsCtn.hidden = true;
        updateBackgroundVisual(false);
        toggleOverviewVisibilityEl.hidden = false;
        // updateStoryHeaderVisibility();

        if(textChunk.startsWith("\n") && storySoFarEl.value.endsWith("\n\n")) {
          if (aiDebug) console.log("generationEventHandlers : chunk new line?");
          textChunk = textChunk.replace(/^\n+/g, "");
        }

        if(storySoFarEl.value.trim() && window.continueMode !== "inline") {
          if (aiDebug) console.log("generationEventHandlers : inline");
          if (aiDebug) console.log(textChunk);
          textChunk = "\n"+textChunk.replace(/^\s*\n+/g, "");
        }
      }
      
      // we 'move' the trailing new lines from the end of the last token to the start of this token:
      if (aiDebug) console.log("generationEventHandlers : move trailing new lines : START");
      if (aiDebug) console.log(textChunk);
      textChunk = window.withheldTrailingNewlines + textChunk;
      window.withheldTrailingNewlines = "";
      if (aiDebug) console.log("generationEventHandlers : move trailing new lines : END");
      if (aiDebug) console.log(textChunk);
      
      // remove trailing newlines - to prevent "scroll jank" in onFinish when we trim() the story
      let trailingNewlines = textChunk.match(/\n+$/)?.[0]
      if(trailingNewlines) {
        if (aiDebug) console.log("generationEventHandlers : trailingNewlines");
        window.withheldTrailingNewlines += trailingNewlines;
        textChunk = textChunk.replace(/\n+$/, "");
      }
      
      if(textChunk.length > 0) { // <-- since empty chunks are possible, and they would ruin our withheldTrailingNewlines stuff
        if (aiDebug) console.log("generationEventHandlers : textChunk > 0");
        storySoFarEl.appendText(textChunk);
      }
      
      if(storySoFarEl.value.endsWith("\n# Ambient Outro")) {
        if (aiDebug) console.log("generationEventHandlers : found Outro");
        storySoFarEl.value = storySoFarEl.value.replace(/\n# Ambient Outro$/g, "")
      }

      if(rawChunk.length > 0) {
        window.currentGenerationTextRaw += rawChunk;
        window.currentGenerationCharCount += rawChunk.length;
      }
      
        if(!window.currentGenerationStopTriggered && window.currentGenerationParagraphLimit !== -1 && window.currentGenerationCharCount >= 100 && window.continueMode !== "inline") {
          if (aiDebug) console.log("generationEventHandlers : Paragraph limit");
          let stopIndex = getParagraphStopIndex(window.currentGenerationTextRaw, window.currentGenerationParagraphLimit);
          if(stopIndex >= 0) {
            window.currentGenerationStopTriggered = true;
            if (aiDebug) console.log("generationEventHandlers : currentGenerationTextRaw : \n" + window.currentGenerationTextRaw);
            let trimmed = window.currentGenerationTextRaw.slice(0, stopIndex);
            if (aiDebug) console.log("generationEventHandlers : trimmed : \n" + trimmed);
            // let trimmed = window.currentGenerationTextRaw.slice(0, stopIndex).trimEnd();
            if (aiDebug) console.log("generationEventHandlers : currentGenerationBaseText : \n" + window.currentGenerationBaseText);
            storySoFarEl.value = (window.currentGenerationBaseText || "") + "\n\n" +trimmed;
            // storySoFarEl.value += trimmed;
            // window.currentGenerationText = trimmed;
            window.withheldTrailingNewlines = "";
            try { window.lastGenerationStreamObj.stop(); } catch(e) {}
          }
        }
      
      // Hacky purple prose fixes for opening paragraph:
      if(storySoFarEl.value.length < 800) {
        if (aiDebug) console.log("generationEventHandlers : Story < 800");
        let t = storySoFarEl.value;
        
        if(t.includes("the cacophony")) t = t.replace(/the cacophony/, "the sound");
        if(t.includes("was thick with")) t = t.replace(/was thick with/, "had");
        if(t.includes("symphony of")) t = t.replace(/symphony of/, "pattern of");
        if(t.includes("tapestry of")) t = t.replace(/tapestry of/, "pattern of");
        if(/\b(shade of emerald)\b/.test(t)) t = t.replace(/\b(shade of emerald)\b/, "shade of green");
        if(/\b(stark reminder)\b/.test(t)) t = t.replace(/\b(stark reminder)\b/, "reminder");
        if(/\b(is a stark contrast to)\b/.test(t)) t = t.replace(/\b(is a stark contrast to)\b/, "contrasts with");
        if(storySoFarEl.value !== t) storySoFarEl.value = t;
      }
      window.gotFirstChunk = true;
      // setInterfaceMode("normal");
    }
    if(storySoFarEl.scrollTop > (storySoFarEl.scrollHeight - storySoFarEl.offsetHeight)-65) { // <-- if the text box is already scrolled near the end of the text
      storySoFarEl.scrollTop = 99999999; // scroll down to bottom of text box as story streams in
    }
  onFinish(data) =>
    if (aiDebug) console.log("onFinish");
    
    if(storySoFarEl.value.length < 10000 & /^\*?\*?paragraph 1\*?\*?:\s+?/i.test(storySoFarEl.value)) {
      // for some reason the ai sometimes adds this
      storySoFarEl.value = storySoFarEl.value.replace(/^\*?\*?paragraph 1\*?\*?:\s+?/i, "");
      
    }
    // Final Dash Sweep - This is intended to clean up shit em/en dashes.
    
    if (!storyDashesCheckbox.checked && localStorage.emDashesComfirmation == "1") {
      if (aiDebug) console.log("removing Dashes");
      storySoFarEl.value = storySoFarEl.value.replace(/([a-zA-Z])[—–]"([^\s])/g, '$1 "$2');
      storySoFarEl.value = storySoFarEl.value.replace(/([a-zA-Z])[—–]([a-zA-Z])/g, '$1, $2');
      storySoFarEl.value = storySoFarEl.value.replace(/([a-zA-Z])[—–]" /g, '$1" ');
      storySoFarEl.value = storySoFarEl.value.replace(/(["])[—–]([a-z])/g, '$1 $2');    
      storySoFarEl.value = storySoFarEl.value.replace(/(\*)[—–−-]([a-zA-Z])/g, '$1 $2');        
      storySoFarEl.value = storySoFarEl.value.replace(/([a-zA-Z])[—–−-](\*)/g, '$1 $2');      
      storySoFarEl.value = storySoFarEl.value.replace(/([a-zA-Z])[—–] /g, '$1 ');    
    }

    generateBtn.disabled = false;
    diceRollBtn.disabled = false;
    regenLastBtn.disabled = false;
    deleteLastBtn.disabled = false;
    stopBtn.style.display = "none";
    antiAntiLayoutJank(() => storySoFarEl.value = storySoFarEl.value.trim()); // remove newlines and spaces from the end of the story
    requestSaveCurrentStory({immediate:true});
    
    if(!window.userClickedStop){
      if (aiDebug) console.log("generationEventHandlers : onFinish : bibleUpdate");
      let bibleData = getNotebookDataForScope("bible");
      bibleData.tabs.forEach(t => {
        if (!t?.content?.length) return;
        const cleanTitle = t.title.replace(/[<>\s\/]/g, '');
        const bibleAutoBox = "storyBibleAutoCheckbox_"+cleanTitle
        if (aiDebug) console.log("generationEventHandlers : onFinish : bibleUpdate : "+ bibleAutoBox);
        if (localStorage[bibleAutoBox]) {
          if (aiDebug) console.log("generationEventHandlers : onFinish : bibleUpdate : found : "+ localStorage.bibleAutoBox);
          autoUpdateBibleSection({title:t.title});
        }
      });      
    }
    
    scheduleAutoNameCheck();
    updateButtonsDisplay();
    if(storySoFarEl.value.length > 1000) whatHappensNextEl.placeholder = "(Optional) What will you do next?";

///////////////////////////////////////////////////////////
// Multi-story + KV persistence (IndexedDB via kv-plugin) //
///////////////////////////////////////////////////////////
STORIES_META_KEY = stories_meta_v1
ACTIVE_STORY_ID_KEY = active_story_id_v1
FOLDERS_META_KEY = stories_folder_meta_v1
APP_CUSTOM_MUSIC_KEY = app_custom_music_v1
APP_CUSTOM_BACKGROUNDS_KEY = app_custom_backgrounds_v1
APP_NOTEBOOK_KEY = app_notebook_v1
APP_SHORTCUT_BUTTONS_KEY = app_shortcut_buttons_v1

ensureStoryManager() =>
  if(!window.storyManager) {
    window.storyManager = {
      isReady:false,
      isLoading:false,
      meta:[], // [{id,title,createdTime,lastEditTime}]
      folderMeta:[], // [{path, emoji}]
      currentId:null,
      currentData:null,
      currentFolderPath:"",
      searchQuery:"",
      searchResults:null,
      searchToken:0,
      saveDebounceTimeout:null,
      metaSaveDebounceTimeout:null,
      folderMetaSaveDebounceTimeout:null,
      appMediaSaveDebounceTimeout:null,
      appNotebookSaveDebounceTimeout:null,
      saveChain:Promise.resolve(),
      metaSaveChain:Promise.resolve(),
      folderMetaSaveChain:Promise.resolve(),
      appMediaSaveChain:Promise.resolve(),
      appNotebookSaveChain:Promise.resolve(),
    };
  }
  if(window.currentStoryId === undefined) window.currentStoryId = null;

escapeHtml(text) =>
  if(text === null || text === undefined) return "";
  return String(text).replace(/[<>&"]/g, m => ({"<":"&lt;","&":"&amp;",">":"&gt;",'"':"&quot;"}[m]));

normalizeCustomMediaList(list) =>
  if(!Array.isArray(list)) return [];
  return list.map(item => {
    let url = (item?.url ?? "").toString().trim();
    let title = (item?.title ?? "").toString().trim();
    let emoji = (item?.emoji ?? "").toString().trim();
    return { url, title, emoji };
  }).filter(item => item.url);

getThemeDefaults() =>
  if(typeof themeSettingsDefault !== "undefined" && themeSettingsDefault) {
    return {...themeSettingsDefault, advancedRules:(themeSettingsDefault.advancedRules || []).slice()};
  }
  return {
    storyTextColor:"",
    storyBackgroundColor:"",
    storyFontFamily:"",
    userBackgroundColor:"",
    userTextColor:"",
    userItalic:true,
    userBold:false,
    asteriskColor:"",
    asteriskItalic:true,
    asteriskBold:false,
    quoteColor:"",
    quoteItalic:false,
    quoteBold:false,
    advancedRules:[],
  };

getThemeDefaultsByScheme() =>
  return {
    light: {...getThemeDefaults()},
    dark: {...getThemeDefaults()},
  };

normalizeThemeSettings(settings, opts) =>
  if(!opts) opts = {};
  if(!settings || typeof settings !== "object") return opts.allowNull ? null : {...getThemeDefaults()};
  let s = {...getThemeDefaults(), ...settings};
  if(s.userBackgroundColor === undefined || s.userBackgroundColor === "") {
    let legacy = s.userStyle || "";
    let colorMatch = legacy.match(/color\s*:\s*([^;]+)/i);
    if(colorMatch) s.userBackgroundColor = colorMatch[1].trim();
  }
  if(s.userTextColor === undefined || s.userTextColor === "") {
    let legacy = s.userStyle || "";
    let colorMatch = legacy.match(/color\s*:\s*([^;]+)/i);
    if(colorMatch) s.userTextColor = colorMatch[1].trim();
  }
  if(s.asteriskColor === undefined || s.asteriskColor === "") {
    let legacy = s.asteriskStyle || "";
    let colorMatch = legacy.match(/color\s*:\s*([^;]+)/i);
    if(colorMatch) s.asteriskColor = colorMatch[1].trim();
  }
  if(s.quoteColor === undefined || s.quoteColor === "") {
    let legacy = s.quoteStyle || "";
    let colorMatch = legacy.match(/color\s*:\s*([^;]+)/i);
    if(colorMatch) s.quoteColor = colorMatch[1].trim();
  }
  if(s.userStyle) {
    s.userItalic = /font-style\s*:\s*italic/i.test(s.userItalic || "");
  }
  if(s.asteriskStyle) {
    s.asteriskItalic = /font-style\s*:\s*italic/i.test(s.asteriskStyle || "");
  }
  if(s.quoteStyle) {
    s.quoteItalic = /font-style\s*:\s*italic/i.test(s.quoteStyle || "");
  }
  if(!Array.isArray(s.advancedRules)) s.advancedRules = [];
  return s;

normalizeThemeSettingsByScheme(settingsByScheme, opts) =>
  if(!opts) opts = {};
  if(!settingsByScheme || typeof settingsByScheme !== "object") return opts.allowNull ? null : getThemeDefaultsByScheme();
  return {
    light: normalizeThemeSettings(settingsByScheme.light, {allowNull:false}),
    dark: normalizeThemeSettings(settingsByScheme.dark, {allowNull:false}),
  };

normalizeMusicRepeatMode(val) =>
  return val === "next" ? "next" : "repeat";

normalizeNotebookData(data) =>
  // if (codeDebug) console.log("normalizeNotebookData");
  // if (codeDebug) console.log("Data");
  // if (codeDebug) console.log(data);
  if(!data || typeof data !== "object") data = {};
  let tabs = Array.isArray(data.tabs) ? data.tabs : [];
  tabs = tabs.map((t, i) => {
    let id = (t?.id ?? `tab_${Date.now()}_${i}_${Math.random().toString(36).slice(2,6)}`).toString();
    let title = (t?.title ?? "Page 1").toString();
    if(title.trim().toLowerCase() === "default") title = "Page 1";
    let content = (t?.content ?? "").toString();
    let lastEditedTime = Number(t?.lastEditedTime || 0);
    return {id, title, content, lastEditedTime};
  });
  if(tabs.length === 0) {
    let id = `tab_${Date.now()}_${Math.random().toString(36).slice(2,6)}`;
    tabs = [{id, title:"Page 1", content:"", lastEditedTime:Date.now()}];
  }
  const storyBible = [
    "<Player Info>",
    "<Other Characters>",
    "<Locations>",
    "<Events/Plot>",
    "<Lore/History>",
    "<Plot Threads>",
  ];
  storyBible.forEach(title => {
    // Check if a tab with this title already exists
    const exists = tabs.some(t => t.title === title);
  
    if (!exists) {
      if (codeDebug) console.log("Missing Bible book: " + title);
      const id = `tab_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`;
      tabs.push({
        id,
        title,
        content: "",
        lastEditedTime: Date.now()
      });
    }
  });
  let activeTabId = (data.activeTabId ?? tabs[0].id).toString();
  if(!tabs.some(t => t.id === activeTabId)) activeTabId = tabs[0].id;
  // if (codeDebug) console.log("tabs/activeid");
  // if (codeDebug) console.log(tabs);
  // if (codeDebug) console.log(activeTabId);
  return {tabs, activeTabId};

getGlobalParagraphLimitDefault() =>
  let raw = "";
  try { raw = localStorage.getItem("globalParagraphLimitDefault") || ""; } catch(e) { raw = ""; }
  let val = parseInt(raw);
  if(!Number.isFinite(val)) val = 2;
  if(val !== -1) val = Math.max(1, Math.min(5, val));
  return val;

setGlobalParagraphLimitDefault(val) =>
  let num = parseInt(val);
  if(!Number.isFinite(num)) num = 2;
  if(num !== -1) num = Math.max(1, Math.min(5, num));
  try { localStorage.setItem("globalParagraphLimitDefault", String(num)); } catch(e) {}

normalizeStoryData(data) =>
  if (codeDebug) console.log("normalizeStoryData : START");
  if (codeDebug) console.log("normalizeStoryData : data : ");
  if (codeDebug) console.log(data);
  if(!data || typeof data !== "object") data = {};
  let paragraphLimit = data.paragraphLimit;
  if(paragraphLimit === undefined || paragraphLimit === null || paragraphLimit === "") {
    if(data.oneParagraphAtATime !== undefined) paragraphLimit = data.oneParagraphAtATime ? 1 : -1;
  }
  paragraphLimit = parseInt(paragraphLimit);
  if(!Number.isFinite(paragraphLimit)) paragraphLimit = getGlobalParagraphLimitDefault();
  if(paragraphLimit !== -1) paragraphLimit = Math.max(1, Math.min(5, paragraphLimit));
  return {
    format: data.format || "perchance-ai-story-v1",
    storyOverview: (data.storyOverview ?? ""),
    storySoFar: (data.storySoFar ?? ""),
    whatHappensNext: (data.whatHappensNext ?? ""),
    paragraphLimit,
    backgroundVisual: (data.backgroundVisual ?? ""),
    backgroundMusic: (data.backgroundMusic ?? ""),
    customBackgrounds: normalizeCustomMediaList(data.customBackgrounds),
    customMusic: normalizeCustomMediaList(data.customMusic),
    hideDefaultBackgrounds: !!data.hideDefaultBackgrounds,
    hideDefaultMusic: !!data.hideDefaultMusic,
    musicRepeatMode: normalizeMusicRepeatMode(data.musicRepeatMode),
    themeSettingsByScheme: normalizeThemeSettingsByScheme(data.themeSettingsByScheme, {allowNull:true}),
    notebook: normalizeNotebookData(data.notebook),
    appNotebook: normalizeNotebookData(data.appNotebook),
    sharedIntroMessage: (data.sharedIntroMessage ?? ""),
    currentTrackedInfo: (data.currentTrackedInfo ?? ""),
    doNotSendStoryInputEnabled: !!data.doNotSendStoryInputEnabled,
    infoTrackingEnabled: !!data.infoTrackingEnabled,
    storyDashesEnabled: !!data.storyDashesEnabled,
    storyBibleAuto_PlayerInfo: !!data.storyBibleAuto_PlayerInfo,
    storyBibleAuto_OtherCharacters: !!data.storyBibleAuto_OtherCharacters,
    storyBibleAuto_Locations: !!data.storyBibleAuto_Locations,
    storyBibleAuto_EventsPlot: !!data.storyBibleAuto_EventsPlot,
    storyBibleAuto_LoreHistory: !!data.storyBibleAuto_LoreHistory,
    storyBibleAuto_PlotThreads: !!data.storyBibleAuto_PlotThreads,
    storyDiceEnabled: !!data.storyDiceEnabled,
    toggleSendStoryInput: !!data.toggleSendStoryInput,
    storyWritingStyleResponseInput: (data.storyWritingStyleResponseInput ?? ""),
    storyWritingStyleCustomInput: (data.storyWritingStyleCustomInput ?? ""),
    storyPerspective: (data.storyPerspective ?? ""),
    gameMode: (data.gameMode ?? ""),
    difficultyMode: (data.difficultyMode ?? ""),
    storyWritingStyle: (data.storyWritingStyle ?? ""),
    storyWritingLength: (data.storyWritingLength ?? ""),
    storyGenreSelect: (data.storyGenreSelect ?? ""),
    storySubGenreSelect: (data.storySubGenreSelect ?? ""),
    storyArcInstruction: (data.storyArcInstruction ?? ""),
    emDashesComfirmation: (data.emDashesComfirmation ?? ""),
    shortcutButtons: (data.shortcutButtons ?? ""),
  };

getParagraphLimitFromSelect() =>
  let raw = "";
  try { raw = paragraphLimitSelect?.value ?? ""; } catch(e) { raw = ""; }
  let val = parseInt(raw);
  if(!Number.isFinite(val)) val = getGlobalParagraphLimitDefault();
  if(val !== -1) val = Math.max(1, Math.min(5, val));
  return val;

setParagraphLimitSelectValue(val) =>
  let num = parseInt(val);
  if(!Number.isFinite(num)) num = 1;
  if(num !== -1) num = Math.max(1, Math.min(5, num));
  if(typeof paragraphLimitSelect !== "undefined") paragraphLimitSelect.value = String(num);

getParagraphLimitForInstruction() =>
  let limit = getParagraphLimitFromSelect();
  return limit === -1 ? 4 : limit;

getParagraphStopIndex(text, limit) =>
  if (codeDebug) console.log("getParagraphStopIndex : text");
  if (codeDebug) console.log(text);
  if (codeDebug) console.log("getParagraphStopIndex : limit");
  if (codeDebug) console.log(limit);
  
  if(limit < 1) return -1;
  let leading = text.match(/^\n+/)?.[0] || "";
  let t = text.slice(leading.length);
  if(!t) return -1;
  let regex = /\n{2,}/g;
  let count = 0;
  let match;
  while((match = regex.exec(t))) {
    count++;
    if(count >= limit) return leading.length + match.index + match[0].length;
  }
  return -1;

handleWhatHappensNextInput() =>
  if(typeof whatHappensNextEl === "undefined") return;
  let trimmed = (whatHappensNextEl.value || "").trim();
  try { if(typeof deleteWhatHappensNextBtn !== "undefined") deleteWhatHappensNextBtn.hidden = !trimmed; } catch(e) {}
  requestSaveCurrentStory({debounceMs:300});
  clearTimeout(window.whatHappensNextCaptureTimeout);
  window.whatHappensNextCaptureTimeout = setTimeout(() => {
    let currentTrimmed = (whatHappensNextEl.value || "").trim();
    if(currentTrimmed.length < 5) {
      window.whatShouldHappenNextInsertionPointText = null;
      return;
    }
    let tail = (storySoFarEl?.value || "").slice(-500);
    window.whatShouldHappenNextInsertionPointText = tail.trim();
  }, 300);

extractAndStripTitleFromImportedStoryData(data, fallback) =>
  let title = "";
  try { title = (data?.title ?? data?.sharedStoryTitle ?? "").toString().trim(); } catch(e) { title = ""; }
  if(!title) title = fallback || "Imported story";
  if(data && typeof data === "object") {
    try { delete data.title; } catch(e) {}
    try { delete data.sharedStoryTitle; } catch(e) {}
  }
  return title;

getBlankStoryData() =>
  return normalizeStoryData({
    storyOverview:"",
    storySoFar:"",
    whatHappensNext:"",
    notebook: normalizeNotebookData(null),
  });

getCurrentStoryDataForStorage() =>
  return normalizeStoryData({
    format:"perchance-ai-story-v1",
    storyOverview: storyOverviewEl?.value ?? "",
    storySoFar: storySoFarEl?.value ?? "",
    whatHappensNext: whatHappensNextEl?.value ?? "",
    storyPerspective: storyPerspectiveSelectEl.value,
    // responseStyle: responseStyleEl.value,
    storyWritingStyleResponseInput: storyWritingStyleResponseInputEl.value,
    storyWritingStyleCustomInput: storyWritingStyleCustomInputEl.value,
    paragraphLimit: getParagraphLimitFromSelect(),
    backgroundVisual: window.currentBackgroundVisual || "",
    backgroundMusic: window.currentBackgroundMusic || "",
    customBackgrounds: window.currentCustomBackgrounds || [],
    customMusic: window.currentCustomMusic || [],
    hideDefaultBackgrounds: !!window.hideDefaultBackgrounds,
    hideDefaultMusic: !!window.hideDefaultMusic,
    musicRepeatMode: normalizeMusicRepeatMode(window.musicRepeatMode),
    themeSettingsByScheme: window.currentStoryThemeSettingsByScheme ? normalizeThemeSettingsByScheme(window.currentStoryThemeSettingsByScheme, {allowNull:false}) : null,
    notebook: normalizeNotebookData(window.currentStoryNotebookData),
    appNotebook: normalizeNotebookData(window.appNotebookData),
    sharedIntroMessage: window.currentSharedIntroMessage || "",
    currentTrackedInfo: currentTrackedInfoEl.value,
    doNotSendStoryInputEnabled: !!toggleSendStoryInputCheckbox.checked,
    infoTrackingEnabled: !!infoTrackingBtn.dataset.enabled,
    storyBibleAuto_PlayerInfo: localStorage.storyBibleAutoCheckbox_PlayerInfo,
    storyBibleAuto_OtherCharacters: localStorage.storyBibleAutoCheckbox_OtherCharacters,
    storyBibleAuto_Locations: localStorage.storyBibleAutoCheckbox_Locations,
    storyBibleAuto_EventsPlot: localStorage.storyBibleAutoCheckbox_EventsPlot,
    storyBibleAuto_LoreHistory: localStorage.storyBibleAutoCheckbox_LoreHistory,
    storyBibleAuto_PlotThreads: localStorage.storyBibleAutoCheckbox_PlotThreads,
    storyDashesEnabled: !!storyDashesCheckbox.checked,
    storyDiceEnabled: !!storyDiceCheckbox.checked,
    toggleSendStoryInput: !!toggleSendStoryInputCheckbox.checked,
    gameMode: storyGameModeSelectEl.value,
    difficultyMode: difficultyModeEl.value,
    storyWritingStyle: storyWritingStyleSelectEl.value,
    storyWritingLength: storyWritingLengthEl.value,
    storyGenreSelect: storyGenreSelectEl.value,
    storySubGenreSelect: storySubGenreSelectEl.value,
    storyArcInstruction: storyArcInstructionEl.value,
    emDashesComfirmation: localStorage.emDashesComfirmation || "",
    shortcutButtons: JSON.parse(localStorage.shortcutButtons || "[]"),
  });

getSuggestedTitleFromStoryData(data) =>
  data = normalizeStoryData(data);
  let t = (data.storyOverview || "").trim().split("\n")[0].trim();
  if(!t) t = (data.storySoFar || "").trim().split("\n")[0].trim();
  if(!t) t = "Untitled story";
  // keep it shortish
  if(t.length > 40) t = t.slice(0, 37).trim() + "...";
  return t;

legacyStoryDataExistsInLocalStorage() =>
  try {
    return (
      localStorage.getItem("storyOverview") !== null ||
      localStorage.getItem("storySoFar") !== null ||
      localStorage.getItem("whatHappensNext") !== null ||
      localStorage.getItem("oneParagraphAtATime") !== null
    );
  } catch(e) { console.error(e); return false; }

getLegacyStoryDataFromLocalStorage() =>
  let d = getBlankStoryData();
  try {
    d.storyOverview = localStorage.getItem("storyOverview") || "";
    d.storySoFar = localStorage.getItem("storySoFar") || "";
    d.whatHappensNext = localStorage.getItem("whatHappensNext") || "";
    // old version stored "1" or "" (and sometimes the key existed with empty string)
    d.paragraphLimit = !!localStorage.getItem("oneParagraphAtATime") ? 1 : -1;
  } catch(e) { console.error(e); }
  return d;

clearLegacyStoryDataFromLocalStorage() =>
  try {
    localStorage.removeItem("storyOverview");
    localStorage.removeItem("storySoFar");
    localStorage.removeItem("whatHappensNext");
    localStorage.removeItem("oneParagraphAtATime");
  } catch(e) { console.error(e); }

generateNewStoryId() =>
  ensureStoryManager();
  let id = Date.now();
  // avoid collisions
  while(window.storyManager.meta.some(m => m && m.id === id)) id++;
  return id;

getMetaEntryById(id) =>
  ensureStoryManager();
  return window.storyManager.meta.find(m => m && m.id === id);

sortMetaByLastEdit(metaArr) =>
  return (metaArr || []).slice(0).sort((a,b) => (b.lastEditTime||0)-(a.lastEditTime||0));

updateCurrentStoryTitleDisplay() =>
  try {
    if(typeof currentStoryTitleEl !== "undefined") {
      let entry = getMetaEntryById(window.storyManager?.currentId);
      let title = entry?.title || "Untitled story";
      let folderPath = normalizeFolderPath(entry?.folderPath || "");
      let displayPath = "";
      if(folderPath) {
        displayPath = folderPath.length > 15 ? ("..." + folderPath.slice(-15)) : folderPath;
      }
      if(typeof currentStoryFolderPrefixEl !== "undefined") {
        currentStoryFolderPrefixEl.textContent = displayPath ? `${displayPath}: ` : "";
        currentStoryFolderPrefixEl.hidden = !displayPath;
      }
      currentStoryTitleEl.textContent = title;
      currentStoryTitleEl.title = (folderPath ? `${folderPath}: ` : "") + title;
    }
  } catch(e) { console.error(e); }

updateStoryHeaderVisibility() =>
  try {
    if(typeof storyHeaderBar === "undefined") return;
    let isFresh = !!window.storyManager?.hadNoStoriesOnLoad;
    let hasContent = ((storyOverviewEl?.value || "") + (storySoFarEl?.value || "") + (whatHappensNextEl?.value || "")).trim().length > 0;
    let editorVisible = (typeof storyGenerationAreaEl !== "undefined" && !storyGenerationAreaEl.hidden);
    if(isFresh && (hasContent || editorVisible)) {
      window.storyManager.hadNoStoriesOnLoad = false;
      isFresh = false;
    }
    let hideHeaderButtons = (isFresh && !hasContent && !editorVisible);
    if(typeof openStoriesPanelBtn !== "undefined") openStoriesPanelBtn.hidden = hideHeaderButtons;
    if(typeof storyTitleCtn !== "undefined") storyTitleCtn.hidden = hideHeaderButtons;
    if(typeof openNotepadBtn !== "undefined") openNotepadBtn.hidden = hideHeaderButtons;
    storyHeaderBar.hidden = hideHeaderButtons;
  } catch(e) { console.error(e); }

updateOverviewToggleText() =>
  try {
    if(typeof toggleOverviewVisibilityBtn === "undefined") return;
    let hidden = !!storyOverviewEl?.hidden;
    toggleOverviewVisibilityBtn.textContent = hidden ? "show overview" : "hide overview";
  } catch(e) { console.error(e); }

toggleOverviewVisibility() =>
  storyOverviewEl.hidden = !storyOverviewEl.hidden;
  storyOverviewPaddingEl.hidden = !storyOverviewPaddingEl.hidden;
  updateOverviewToggleText();

formatRelativeTime(ts) =>
  if(!ts) return "";
  let diff = Date.now() - ts;
  if(diff < 1000*10) return "just now";
  if(diff < 1000*60) return `${Math.round(diff/1000)}s ago`;
  if(diff < 1000*60*60) return `${Math.round(diff/(1000*60))}m ago`;
  if(diff < 1000*60*60*24) return `${Math.round(diff/(1000*60*60))}h ago`;
  if(diff < 1000*60*60*24*14) return `${Math.round(diff/(1000*60*60*24))}d ago`;
  return new Date(ts).toString().split(" ").slice(1, 4).join(" ");

normalizeFolderPath(path) =>
  path = (path || "").toString().trim().replace(/\\+/g, "/");
  path = path.replace(/\/+/g, "/").replace(/^\/+|\/+$/g, "");
  return path;

getFolderSegments(path) =>
  return normalizeFolderPath(path).split("/").filter(Boolean);

getParentFolderPath(path) =>
  let segs = getFolderSegments(path);
  return segs.slice(0, -1).join("/");

isFolderPrefix(path, prefix) =>
  if(!prefix) return true;
  if(!path) return false;
  if(path === prefix) return true;
  return path.startsWith(prefix + "/");

getFolderMetaByPath(path) =>
  ensureStoryManager();
  path = normalizeFolderPath(path);
  return window.storyManager.folderMeta.find(f => f && normalizeFolderPath(f.path) === path);

getFolderEmoji(path) =>
  let meta = getFolderMetaByPath(path);
  return meta?.emoji || "📁";

setCurrentFolderPath(path) =>
  ensureStoryManager();
  window.storyManager.currentFolderPath = normalizeFolderPath(path || "");
  renderStoriesList();

getChildFolderPaths(meta, folderPath) =>
  let base = normalizeFolderPath(folderPath || "");
  let prefix = base ? base + "/" : "";
  let set = new Set();
  for(let m of meta) {
    let fp = normalizeFolderPath(m.folderPath || "");
    if(!fp) continue;
    if(prefix && !fp.startsWith(prefix)) continue;
    let remainder = prefix ? fp.slice(prefix.length) : fp;
    let seg = remainder.split("/")[0];
    if(seg) {
      let childPath = base ? (base + "/" + seg) : seg;
      set.add(childPath);
    }
  }
  return [...set].sort((a,b) => a.localeCompare(b));

getStoriesAtFolder(meta, folderPath) =>
  folderPath = normalizeFolderPath(folderPath || "");
  return meta.filter(m => normalizeFolderPath(m.folderPath || "") === folderPath);

sortStoriesForDisplay(metaArr) =>
  return (metaArr || []).slice(0).sort((a,b) => {
    let ap = a.pinned ? 1 : 0;
    let bp = b.pinned ? 1 : 0;
    if(ap !== bp) return bp - ap;
    return (b.lastEditTime||0) - (a.lastEditTime||0);
  });

setStoriesSearchQuery(query) =>
  ensureStoryManager();
  window.storyManager.searchQuery = (query || "").toString();
  if(typeof storiesSearchClearBtn !== "undefined") {
    storiesSearchClearBtn.hidden = !window.storyManager.searchQuery.trim();
  }
  if(!window.storyManager.searchQuery.trim()) {
    window.storyManager.searchResults = null;
    renderStoriesList();
    return;
  }
  computeStoriesSearchResults(window.storyManager.searchQuery);

clearStoriesSearch() =>
  if(typeof storiesSearchInputEl !== "undefined") storiesSearchInputEl.value = "";
  setStoriesSearchQuery("");

countMatches(haystack, needle) =>
  if(!needle) return 0;
  let count = 0;
  let idx = 0;
  while(true) {
    idx = haystack.indexOf(needle, idx);
    if(idx === -1) break;
    count++;
    idx += needle.length || 1;
  }
  return count;

async computeStoriesSearchResults(query) =>
  ensureStoryManager();
  let q = (query || "").toString().trim().toLowerCase();
  if(!q) { window.storyManager.searchResults = null; renderStoriesList(); return; }
  let token = ++window.storyManager.searchToken;
  let meta = window.storyManager.meta || [];
  let results = [];
  for(let entry of meta) {
    let data = await kv.stories.get(entry.id);
    data = normalizeStoryData(data);
    let title = (entry.title || "Untitled story").toLowerCase();
    let overview = (data.storyOverview || "").toLowerCase();
    let story = (data.storySoFar || "").toLowerCase();
    let score = 0;
    score += 10 * countMatches(title, q);
    score += countMatches(overview, q);
    score += countMatches(story, q);
    if(score > 0) {
      results.push({ entry, score });
    }
  }
  if(token !== window.storyManager.searchToken) return;
  results.sort((a,b) => (b.score - a.score) || ((b.entry.lastEditTime||0) - (a.entry.lastEditTime||0)));
  window.storyManager.searchResults = results;
  renderStoriesList();

renderStoriesList() =>
  try {
    if(typeof storiesListCtn === "undefined") return;
    ensureStoryManager();
    let meta = (window.storyManager.meta || []).slice(0);
    let currentId = window.storyManager.currentId;
    let searchQuery = (window.storyManager.searchQuery || "").trim();
    let htmlParts = [];

    if(searchQuery) {
      let results = window.storyManager.searchResults;
      htmlParts.push(`<div style="font-size:75%; opacity:0.7; padding:0.35rem 0.5rem;">Search results for <b>${escapeHtml(searchQuery)}</b></div>`);
      if(!results) {
        htmlParts.push(`<div style="opacity:0.7; font-size:90%; padding:0.75rem;">Searching...</div>`);
      } else if(results.length === 0) {
        htmlParts.push(`<div style="opacity:0.7; font-size:90%; padding:0.75rem;">No matches found.</div>`);
      } else {
        htmlParts.push(results.map(({entry, score}) => {
          let isCurrent = (entry.id === currentId);
          let title = escapeHtml(entry.title || "Untitled story");
          let relTime = escapeHtml(formatRelativeTime(entry.lastEditTime || entry.createdTime));
          let folderPath = normalizeFolderPath(entry.folderPath || "");
          let pinBadge = entry.pinned ? "📌 " : "";
          let folderLabel = folderPath ? ` <span class="storyRowSub">(${escapeHtml(folderPath)})</span>` : "";
          return `
            <div class="storyRow ${isCurrent ? "current" : ""}" data-id="${escapeHtml(entry.id)}">
              <button class="storyPickBtn" data-action="open-story" data-id="${escapeHtml(entry.id)}" title="Open this story">${pinBadge}${title}${folderLabel}</button>
              <div class="storyRowRight">
                <span class="storyTime" data-action="open-story" data-id="${escapeHtml(entry.id)}" title="${escapeHtml(new Date(entry.lastEditTime || entry.createdTime).toString())}">${relTime}</span>
                <button class="storyMenuBtn" data-action="story-menu" data-id="${escapeHtml(entry.id)}" title="Story menu">⋯</button>
              </div>
            </div>
          `;
        }).join(""));
      }
    } else {
      let folderPath = normalizeFolderPath(window.storyManager.currentFolderPath || "");
      if(folderPath) {
        let parent = getParentFolderPath(folderPath);
        htmlParts.push(`
          <div class="storyRow folderRow" data-folder="${escapeHtml(parent)}">
            <button class="storyPickBtn" data-action="open-folder" data-folder="${escapeHtml(parent)}" title="Go up one level">🔙 up one level</button>
            <div class="storyRowRight"></div>
          </div>
        `);
      }

      let childFolders = getChildFolderPaths(meta, folderPath);
      if(childFolders.length > 0) {
        htmlParts.push(childFolders.map(fp => {
          let folderName = getFolderSegments(fp).slice(-1)[0] || fp;
          let emoji = getFolderEmoji(fp);
          return `
            <div class="storyRow folderRow" data-folder="${escapeHtml(fp)}">
              <button class="storyPickBtn" data-action="open-folder" data-folder="${escapeHtml(fp)}" title="Open folder">${escapeHtml(emoji)} ${escapeHtml(folderName)}</button>
              <div class="storyRowRight">
                <button class="storyMenuBtn" data-action="folder-menu" data-folder="${escapeHtml(fp)}" title="Folder menu">⋯</button>
              </div>
            </div>
          `;
        }).join(""));
      }

      let storiesHere = sortStoriesForDisplay(getStoriesAtFolder(meta, folderPath));
      if(storiesHere.length > 0) {
        htmlParts.push(storiesHere.map(m => {
          let isCurrent = (m.id === currentId);
          let title = escapeHtml(m.title || "Untitled story");
          let relTime = escapeHtml(formatRelativeTime(m.lastEditTime || m.createdTime));
          let pinBadge = m.pinned ? "📌 " : "";
          return `
            <div class="storyRow ${isCurrent ? "current" : ""}" data-id="${escapeHtml(m.id)}">
              <button class="storyPickBtn no-hover" data-action="open-story" data-id="${escapeHtml(m.id)}" title="Open this story">${pinBadge}${title}</button>
              <div class="storyRowRight">
                <span class="storyTime" data-action="open-story" data-id="${escapeHtml(m.id)}" title="${escapeHtml(new Date(m.lastEditTime || m.createdTime).toString())}">${relTime}</span>
                <button class="storyMenuBtn" data-action="story-menu" data-id="${escapeHtml(m.id)}" title="Story menu">⋯</button>
              </div>
            </div>
          `;
        }).join(""));
      }

      if(childFolders.length === 0 && storiesHere.length === 0) {
        htmlParts.push(`<div style="opacity:0.7; font-size:90%; padding:0.75rem;">No stories yet.</div>`);
      }
    }
    
    htmlParts.push(`<div class="storiesStorageWarning"><b>Note</b>: Your stories are stored <u>privately</u> in your browser (<b style="color: #ff8e29;">not</b> on a server), so if your site data/cache is cleared, your stories <b>will be lost</b>. Web browsers sometimes clear data automatically 😨 (e.g. if available storage space is low). Use the <u style="font-weight:bold;">export</u> button to backup your data regularly.</div>`);

    storiesListCtn.innerHTML = htmlParts.join("");
    renderStoriesFooterNotices();
    renderStoriesFooterStoryStats();
  } catch(e) { console.error(e); }

renderStoriesFooterNotices() =>
  try {
    if(typeof storiesFooterNotices === "undefined") return;
    let notices = [];
    let genCount = Number(localStorage.generateCount || 0);
    let lastExportTime = Number(localStorage.lastExportTime || 0);
    let lastExportCount = Number(localStorage.lastExportGenerateCount || 0);
    let firstGenerateTime = Number(localStorage.firstGenerateTime || 0);
    let baseTime = lastExportTime || firstGenerateTime || 0;
    let daysSince = baseTime ? ((Date.now() - baseTime) / (1000*60*60*24)) : 0;
    let gensSince = Math.max(0, genCount - lastExportCount);
    if(daysSince >= 10 && gensSince >= 300) {
      notices.push(`<div class="exportReminder">⚠️ You've generated <b>${gensSince}</b> times since your last export. Please back up your stories to prevent data loss. <button onclick="dismissExportReminder()">dismiss</button></div>`);
    }
    storiesFooterNotices.innerHTML = notices.join("");
  } catch(e) { console.error(e); }

async renderStoriesFooterStoryStats() =>
  if (codeDebug) { console.log("renderStoriesFooterStoryStats")};
  try {
    let storyData = await getStoryStats();
    if(!storyData) return;
    let storiesFooterInfo = document.getElementById("storiesFooterStoryData");
    
    // console.log("Total size:", totalKB + " KB (" + totalMB + " MB)");
    if (storiesFooterInfo) {
      storiesFooterInfo.textContent = `${storyData.stories} ${storyData.stories === 1 ? "story" : "stories"} · ${storyData.kb} KB (${storyData.mb} MB)`;
    };
  } catch(e) { console.error(e); }

dismissExportReminder() =>
  let genCount = Number(localStorage.generateCount || 0);
  localStorage.lastExportTime = Date.now();
  localStorage.lastExportGenerateCount = genCount;
  renderStoriesFooterNotices();

openStoriesPanel() =>
  try {
    document.body.classList.add("storiesDrawerOpen");
    document.getElementById('storiesDrawerOverlay').style.opacity='1';
    document.getElementById('storiesDrawerOverlay').style.pointerEvents='auto'
    try { if(typeof storiesSearchInputEl !== "undefined") storiesSearchInputEl.value = window.storyManager.searchQuery || ""; } catch(e) {}
    try { if(typeof storiesSearchClearBtn !== "undefined") storiesSearchClearBtn.hidden = !(window.storyManager.searchQuery || "").trim(); } catch(e) {}
    renderStoriesList();
  } catch(e) { console.error(e); }

closeStoriesPanel() =>
  try {
    document.body.classList.remove("storiesDrawerOpen");
    document.getElementById('storiesDrawerOverlay').style.opacity='0';
    document.getElementById('storiesDrawerOverlay').style.pointerEvents='none';
    closeStoryMenu();
  } catch(e) { console.error(e); }

toggleStoriesPanel() =>
  if(document.body.classList.contains("storiesDrawerOpen")) closeStoriesPanel();
  else openStoriesPanel();

async saveMetaToKvNow() =>
  ensureStoryManager();
  let metaSnapshot = (window.storyManager.meta || []).map(m => ({...m}));
  let activeId = window.storyManager.currentId;

  window.storyManager.metaSaveChain = window.storyManager.metaSaveChain.then(async () => {
    await kv.storiesMeta.set(STORIES_META_KEY, metaSnapshot);
    await kv.storiesMeta.set(ACTIVE_STORY_ID_KEY, activeId);
  }).catch(console.error);

  return window.storyManager.metaSaveChain;

requestMetaSaveDebounced(opts) =>
  if(!opts) opts = {};
  if(window.isDeletingAllData) return;
  ensureStoryManager();
  clearTimeout(window.storyManager.metaSaveDebounceTimeout);
  let ms = opts.debounceMs ?? 600;
  window.storyManager.metaSaveDebounceTimeout = setTimeout(() => {
    saveMetaToKvNow();
  }, ms);

async saveFolderMetaToKvNow() =>
  ensureStoryManager();
  let folderSnapshot = (window.storyManager.folderMeta || []).map(f => ({...f}));
  window.storyManager.folderMetaSaveChain = window.storyManager.folderMetaSaveChain.then(async () => {
    await kv.storiesMeta.set(FOLDERS_META_KEY, folderSnapshot);
  }).catch(console.error);
  return window.storyManager.folderMetaSaveChain;

requestFolderMetaSaveDebounced(opts) =>
  if(!opts) opts = {};
  if(window.isDeletingAllData) return;
  ensureStoryManager();
  clearTimeout(window.storyManager.folderMetaSaveDebounceTimeout);
  let ms = opts.debounceMs ?? 600;
  window.storyManager.folderMetaSaveDebounceTimeout = setTimeout(() => {
    saveFolderMetaToKvNow();
  }, ms);

async saveAppMediaToKvNow() =>
  ensureStoryManager();
  let musicSnapshot = normalizeCustomMediaList(window.appCustomMusic || []);
  let backgroundSnapshot = normalizeCustomMediaList(window.appCustomBackgrounds || []);
  window.storyManager.appMediaSaveChain = (window.storyManager.appMediaSaveChain || Promise.resolve()).then(async () => {
    await kv.storiesMeta.set(APP_CUSTOM_MUSIC_KEY, musicSnapshot);
    await kv.storiesMeta.set(APP_CUSTOM_BACKGROUNDS_KEY, backgroundSnapshot);
  }).catch(console.error);
  return window.storyManager.appMediaSaveChain;

requestAppMediaSaveDebounced(opts) =>
  if(!opts) opts = {};
  if(window.isDeletingAllData) return;
  ensureStoryManager();
  clearTimeout(window.storyManager.appMediaSaveDebounceTimeout);
  let ms = opts.debounceMs ?? 600;
  window.storyManager.appMediaSaveDebounceTimeout = setTimeout(() => {
    saveAppMediaToKvNow();
  }, ms);

async saveAppNotebookToKvNow() =>
  ensureStoryManager();
  let snapshot = normalizeNotebookData(window.appNotebookData);
  window.storyManager.appNotebookSaveChain = (window.storyManager.appNotebookSaveChain || Promise.resolve()).then(async () => {
    await kv.storiesMeta.set(APP_NOTEBOOK_KEY, snapshot);
  }).catch(console.error);
  return window.storyManager.appNotebookSaveChain;

requestAppNotebookSaveDebounced(opts) =>
  if(!opts) opts = {};
  if(window.isDeletingAllData) return;
  ensureStoryManager();
  clearTimeout(window.storyManager.appNotebookSaveDebounceTimeout);
  let ms = opts.debounceMs ?? 600;
  window.storyManager.appNotebookSaveDebounceTimeout = setTimeout(() => {
    saveAppNotebookToKvNow();
  }, ms);

async saveCurrentStoryToKvNow() =>
  ensureStoryManager();
  if(window.isDeletingAllData) return;
  if(!window.storyManager.isReady) return;
  let id = window.storyManager.currentId;
  if(id === null || id === undefined) return;

  // capture latest from UI
  let data = getCurrentStoryDataForStorage();
  if (codeDebug) console.log("saveCurrentStoryToKvNow : data");
  if (codeDebug) console.log(data);
  window.storyManager.currentData = data;

  // update meta timestamps in-memory
  let entry = getMetaEntryById(id);
  if(entry) entry.lastEditTime = Date.now();

  let metaSnapshot = (window.storyManager.meta || []).map(m => ({...m}));
  let activeId = id;

  // serialize saves to avoid races
  window.storyManager.saveChain = window.storyManager.saveChain.then(async () => {
    await kv.stories.set(id, data);
    await kv.storiesMeta.set(STORIES_META_KEY, metaSnapshot);
    await kv.storiesMeta.set(ACTIVE_STORY_ID_KEY, activeId);
  }).catch(console.error);

  return window.storyManager.saveChain;

requestSaveCurrentStory(opts) =>
  if(!opts) opts = {};
  if(window.isDeletingAllData) return;
  ensureStoryManager();
  if(window.storyManager.isLoading) return;
  if(!window.storyManager.isReady) return;

  if(opts.immediate) {
    saveCurrentStoryToKvNow();
    return;
  }

  clearTimeout(window.storyManager.saveDebounceTimeout);
  let ms = opts.debounceMs ?? 1200;
  window.storyManager.saveDebounceTimeout = setTimeout(() => {
    saveCurrentStoryToKvNow();
  }, ms);

async checkForExternalStoryUpdate() =>
  try {
    ensureStoryManager();
    if(!window.storyManager.isReady || window.storyManager.isLoading) return;
    if(window.externalUpdatePromptOpen) return;
    if(window.currentlyGenerating) return;
    let id = window.storyManager.currentId;
    if(id === null || id === undefined) return;
    let metaArr = await kv.storiesMeta.get(STORIES_META_KEY) || [];
    let remoteEntry = metaArr.find(m => m && m.id == id);
    let localEntry = getMetaEntryById(id);
    if(!remoteEntry || !localEntry) return;
    let remoteTime = remoteEntry.lastEditTime || 0;
    let localTime = localEntry.lastEditTime || 0;
    if(remoteTime <= localTime) return;
    if(window.lastExternalUpdateSeenByStoryId[id] === remoteTime) return;
    window.lastExternalUpdateSeenByStoryId[id] = remoteTime;
    window.externalUpdatePromptOpen = true;
    if(typeof window.forceAutoBackupNow === "function") await window.forceAutoBackupNow();
    let confirmed = await confirmAsync(
      "You've worked on a newer version of this story in another browser tab.\n\nAn auto-backup of your current version has been saved.\n\nLoad the newer version now? (Cancel to keep this version)"
    );
    if(confirmed) {
      let data = await kv.stories.get(id);
      if(data && window.storyManager.currentId === id) {
        loadChatDataIntoInputAreas(data);
        localEntry.lastEditTime = remoteTime;
        requestSaveCurrentStory({immediate:true});
      }
    } else {
      requestSaveCurrentStory({immediate:true});
    }
  } catch(e) {
    console.error(e);
  } finally {
    window.externalUpdatePromptOpen = false;
  }

startExternalUpdateWatcher() =>
  if(window.externalUpdateWatcherStarted) return;
  window.externalUpdateWatcherStarted = true;
  setInterval(() => {
    checkForExternalStoryUpdate();
  }, 1000*60*2);

async flushAllStorySaves() =>
  ensureStoryManager();
  try { await window.storyManager.saveChain; } catch(e) {}
  try { await window.storyManager.metaSaveChain; } catch(e) {}
  try { await window.storyManager.folderMetaSaveChain; } catch(e) {}

resetPerStoryEphemeralState() =>
  // Avoid cross-story oddities from global variables.
  window.storyTextBeforeLastGeneration = null;
  window.storyTextBeforeLastParagraphDelete = null;
  window.storyTextBeforeLastGeneration_beforeParagraphDelete = null;
  window.deletedStorySoFar = null;
  window.withheldTrailingNewlines = "";
  window.gotFirstChunk = false;
  window.whatShouldHappenNextInsertionPointText = null;
  try { clearTimeout(window.whatHappensNextCaptureTimeout); } catch(e) {}
  // stop any pending "undo" UI
  try { undoDeleteLastParagraphCtn.style.display = "none"; } catch(e) {}
  try {
    if(typeof storyToolsDeleteBtn !== "undefined") {
      storyToolsDeleteBtn.dataset.mode = "delete";
      storyToolsDeleteBtn.textContent = "🗑️ delete story text";
    }
  } catch(e) {}
  // reset summarization per story buffers are handled in injectSummaries... using story id
  // reset share link ui
  try {
    if(typeof shareResultSection !== "undefined") shareResultSection.hidden = true;
    if(typeof shareStoryLinkInputEl !== "undefined") shareStoryLinkInputEl.value = "";
    if(typeof shareLinkCopyBtn !== "undefined") shareLinkCopyBtn.textContent = "📋";
  } catch(e) {}
  // hide suggestions popover
  try { whatHappensNextSuggestionsCtn.style.display = "none"; } catch(e) {}

async createNewStory(opts) =>
  let newStory = false
  if(!opts) { opts = {}; newStory = true; }
  ensureStoryManager();
  if(window.currentlyGenerating && window.lastGenerationStreamObj) {
    let ok = await confirmAsync("A paragraph is currently generating. Stop it and create a new story?", {});
    if(!ok) return null;
    try { window.userClickedStop = true; window.lastGenerationStreamObj.stop(); } catch(e) {}
  }

  if (Object.values(window.generatingBibleSection).some(v => v === true)) {
    let ok = await confirmAsync("A bible section is currently generating. Stop it and create a new story?", {});
    if(!ok) return null;
    
    try {
      window.userClickedStop = true;
      Object.entries(window.currentAutoBibleGeneration).forEach(([key, aiObj]) => {aiObj.stop?.();});
      window.currentBibleGeneration?.stop();
    } catch(e) {console.error(e);}
  }

  // flush current saves before switching
  await saveCurrentStoryToKvNow();
  await flushAllStorySaves();

  let id = generateNewStoryId();
  let now = Date.now();
  let data = normalizeStoryData(opts.data || getBlankStoryData());
  
  
  let title = (opts.title || "").trim();
  if(!title) title = getSuggestedTitleFromStoryData(data);
  if(!title) title = "Untitled story";

  let folderPath = normalizeFolderPath(opts.folderPath || "");
  if(!folderPath && !(window.storyManager.searchQuery || "").trim()) {
    folderPath = normalizeFolderPath(window.storyManager.currentFolderPath || "");
  }
  window.storyManager.meta.unshift({
    id,
    title,
    createdTime: now,
    lastEditTime: now,
    pinned: !!opts.pinned,
    folderPath,
    autoNameAttempted: false,
  });
  if(!newStory && data.appNotebook) {
    if (codeDebug) console.log("Found Notebook Data, importing")
    let snapshot = normalizeNotebookData(data.appNotebook);
    window.appNotebookData = snapshot
  }
  
  // persist new story + meta
  // if (codeDebug) console.log("after set nb");
  // if (codeDebug) console.log(window.appNotebookData);
  await kv.stories.set(id, data);
  await kv.storiesMeta.set(STORIES_META_KEY, window.storyManager.meta);
  await kv.storiesMeta.set(ACTIVE_STORY_ID_KEY, id);
  
  // switch to it
  await switchToStory(id, {skipSaveCurrent:true, closePanel:true});
  return id;

async renameStory(id) =>
  ensureStoryManager();
  let entry = getMetaEntryById(id);
  if(!entry) return;

  let newTitle = prompt("Rename story:", entry.title || "Untitled story");
  if(newTitle === null) return;
  newTitle = newTitle.trim();
  if(!newTitle) newTitle = "Untitled story";

  entry.title = newTitle;
  entry.lastEditTime = Date.now();
  renderStoriesList();
  updateCurrentStoryTitleDisplay();
  requestMetaSaveDebounced({debounceMs:200});

async duplicateStory(id) =>
  ensureStoryManager();
  let entry = getMetaEntryById(id);
  if(!entry) return;
  let data = await kv.stories.get(id);
  if(!data) data = getBlankStoryData();
  data = normalizeStoryData(data);
  let title = entry.title ? `Copy of ${entry.title}` : "Copy of Untitled story";
  if (codeDebug) console.log("reqeusted duplicate story")
  await createNewStory({title, data, folderPath: entry.folderPath || "", pinned:false});

async renameCurrentStory() =>
  ensureStoryManager();
  if(window.storyManager.currentId === null || window.storyManager.currentId === undefined) return;
  await renameStory(window.storyManager.currentId);

openCurrentStoryMenu(ev) =>
  try { ev?.stopPropagation?.(); } catch(e) {}
  let id = window.storyManager?.currentId;
  if(id === null || id === undefined) return;
  if(typeof storyMenuEl !== "undefined" && !storyMenuEl.hidden) {
    let ctx = window.activeStoryMenuContext;
    if(ctx && ctx.type === "storyHeader" && Number(ctx.id) === Number(id)) {
      closeStoryMenu();
      return;
    }
  }
  window.activeStoryMenuContext = {type:"storyHeader", id};
  renderStoryMenu(ev?.currentTarget);

async deleteStory(id) =>
  ensureStoryManager();
  let entry = getMetaEntryById(id);
  if(!entry) return;
  if(!window.confirm(`Delete "${entry.title || "Untitled story"}"? This cannot be undone.`)) return;
  window.storyManager.meta = window.storyManager.meta.filter(m => m && m.id !== id);
  try { await kv.stories.delete(id); } catch(e) { console.error(e); }
  requestMetaSaveDebounced({debounceMs:200});
  if(window.storyManager.currentId === id) {
    let nextId = sortMetaByLastEdit(window.storyManager.meta)[0]?.id;
    if(nextId !== undefined) {
      await switchToStory(nextId, {skipSaveCurrent:true, closePanel:false, force:true});
    } else {
      await createNewStory();
    }
  }
  if (codeDebug) console.log("reqeusted delete story")
  renderStoriesList();

async downloadStory(id) =>
  ensureStoryManager();
  let entry = getMetaEntryById(id);
  if(!entry) return;
  let data = await kv.stories.get(id);
  data = normalizeStoryData(data);
  let filename = prompt("Choose a filename:", (entry.title || "story").trim().slice(0, 60) || "story");
  if(filename === null) return;
  filename = filename.trim() || "story";
  filename += ".ai-story.json";
  let blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  let url = URL.createObjectURL(blob);
  let a = document.createElement('a');
  a.href = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);

async downloadFolder(folderPath) =>
  ensureStoryManager();
  folderPath = normalizeFolderPath(folderPath);
  let meta = (window.storyManager.meta || []).filter(m => isFolderPrefix(normalizeFolderPath(m.folderPath || ""), folderPath));
  if(meta.length === 0) {
    alert("No stories found in that folder.");
    return;
  }
  await saveCurrentStoryToKvNow();
  await flushAllStorySaves();
  let zip = await ensureZipJs();
  let writer = new zip.ZipWriter(new zip.BlobWriter("application/zip"));
  let usedFolderNames = new Set();
  let rootName = folderPath ? folderPath.split("/").slice(-1)[0] : "folder";
  rootName = rootName.replace(/[\\/:*?"<>|]/g, "_") || "folder";
  for(let entry of meta) {
    let data = await kv.stories.get(entry.id);
    data = normalizeStoryData(data);
    let fullPath = normalizeFolderPath(entry.folderPath || "");
    let relPath = folderPath ? fullPath.slice(folderPath.length).replace(/^\/+/, "") : fullPath;
    let safeSegments = relPath ? relPath.split("/").map(s => s.replace(/[\\/:*?"<>|]/g, "_")) : [];
    let safeTitle = (entry.title || "Untitled story").replace(/[\\/:*?"<>|]/g, "_").slice(0, 80) || "Untitled story";
    let baseFolder = `${safeTitle} (${entry.id})`;
    let storyFolder = [rootName, ...safeSegments, baseFolder].join("/");
    if(usedFolderNames.has(storyFolder)) storyFolder += "-" + Math.random().toString(36).slice(2,6);
    usedFolderNames.add(storyFolder);
    let storyWithoutSummaries = (data.storySoFar || "").split(/\n{2,}/).map(p => p.trim()).filter(p => !p.startsWith("SUMMARY^")).join("\n\n");
    let metaJson = {
      meta: entry,
      storyData: data,
    };
    await writer.add(`${storyFolder}/overview.txt`, new zip.TextReader(data.storyOverview || ""));
    await writer.add(`${storyFolder}/story.txt`, new zip.TextReader(data.storySoFar || ""));
    await writer.add(`${storyFolder}/story_without_summaries.txt`, new zip.TextReader(storyWithoutSummaries));
    await writer.add(`${storyFolder}/meta.json`, new zip.TextReader(JSON.stringify(metaJson, null, 2)));
  }
  let blob = await writer.close();
  let filename = `${rootName}-stories.zip`;
  downloadBlob(blob, filename);

togglePinStory(id) =>
  ensureStoryManager();
  let entry = getMetaEntryById(id);
  if(!entry) return;
  entry.pinned = !entry.pinned;
  entry.lastEditTime = Date.now();
  renderStoriesList();
  requestMetaSaveDebounced({debounceMs:200});

async setStoryFolderPath(id) =>
  ensureStoryManager();
  let entry = getMetaEntryById(id);
  if(!entry) return;
  let currentPath = normalizeFolderPath(entry.folderPath || "");
  let newPath = prompt("Move story to folder (e.g. foo/bar/baz). Leave blank for root:", currentPath);
  if(newPath === null) return;
  newPath = normalizeFolderPath(newPath);
  entry.folderPath = newPath;
  entry.lastEditTime = Date.now();
  renderStoriesList();
  updateCurrentStoryTitleDisplay();
  requestMetaSaveDebounced({debounceMs:200});

openStoryRowMenu(ev, id) =>
  try { ev?.stopPropagation?.(); } catch(e) {}
  if(typeof storyMenuEl !== "undefined" && !storyMenuEl.hidden) {
    let ctx = window.activeStoryMenuContext;
    if(ctx && ctx.type === "story" && Number(ctx.id) === Number(id)) {
      closeStoryMenu();
      return;
    }
  }
  window.activeStoryMenuContext = {type:"story", id};
  renderStoryMenu(ev?.currentTarget);

openFolderRowMenu(ev, folderPath) =>
  try { ev?.stopPropagation?.(); } catch(e) {}
  if(typeof storyMenuEl !== "undefined" && !storyMenuEl.hidden) {
    let ctx = window.activeStoryMenuContext;
    if(ctx && ctx.type === "folder" && normalizeFolderPath(ctx.folderPath || "") === normalizeFolderPath(folderPath || "")) {
      closeStoryMenu();
      return;
    }
  }
  window.activeStoryMenuContext = {type:"folder", folderPath: normalizeFolderPath(folderPath)};
  renderStoryMenu(ev?.currentTarget);

closeStoryMenu() =>
  if(typeof storyMenuEl !== "undefined") storyMenuEl.hidden = true;
  window.activeStoryMenuContext = null;

renderStoryMenu(anchorEl) =>
  if(typeof storyMenuEl === "undefined") return;
  ensureStoryManager();
  let ctx = window.activeStoryMenuContext;
  if(!ctx) return;
  let html = "";
  if(ctx.type === "story" || ctx.type === "storyHeader") {
    let entry = getMetaEntryById(ctx.id);
    let isPinned = !!entry?.pinned;
    html = `
      ${ctx.type === "storyHeader" ? `<button data-action="new-story">➕ new story</button>` : ""}
      <button data-action="rename-story" data-id="${escapeHtml(ctx.id)}">🏷️ rename</button>
      <button data-action="duplicate-story" data-id="${escapeHtml(ctx.id)}">⿻ duplicate</button>
      <button data-action="download-story" data-id="${escapeHtml(ctx.id)}">💾 download</button>
      <button data-action="share-story" data-id="${escapeHtml(ctx.id)}">🔗 share</button>
      ${ctx.type === "story" ? `<button data-action="toggle-pin" data-id="${escapeHtml(ctx.id)}">${isPinned ? "📌 unpin" : "📌 pin"}</button>` : ""}
      <button data-action="set-folder" data-id="${escapeHtml(ctx.id)}">🗂️ folder</button>
      <hr class="storyToolsDivider">
      <button data-action="delete-story" data-id="${escapeHtml(ctx.id)}">🗑️ delete</button>
    `;
  } else if(ctx.type === "folder") {
    let fp = ctx.folderPath;
    html = `
      <button data-action="rename-folder" data-folder="${escapeHtml(fp)}">🏷️ rename</button>
      <button data-action="choose-folder-emoji" data-folder="${escapeHtml(fp)}">😀 choose emoji</button>
      <button data-action="download-folder" data-folder="${escapeHtml(fp)}">💾 download</button>
      <hr class="storyToolsDivider">
      <button data-action="delete-folder" data-folder="${escapeHtml(fp)}">🗑️ delete folder</button>
    `;
  }
  storyMenuEl.innerHTML = html;
  storyMenuEl.hidden = false;
  if(anchorEl) {
    let rect = anchorEl.getBoundingClientRect();
    let left = rect.left;
    let top = rect.bottom + 4;
    storyMenuEl.style.left = `${Math.min(left, window.innerWidth - storyMenuEl.offsetWidth - 8)}px`;
    if(top + storyMenuEl.offsetHeight > window.innerHeight - 6) {
      top = rect.top - storyMenuEl.offsetHeight - 6;
    }
    storyMenuEl.style.top = `${Math.max(6, top)}px`;
  }

chooseFolderEmoji(folderPath) =>
  ensureStoryManager();
  folderPath = normalizeFolderPath(folderPath);
  let meta = getFolderMetaByPath(folderPath) || {path: folderPath, emoji:""};
  let input = prompt("Choose an emoji for this folder:", meta.emoji || "");
  if(input === null) return;
  let emoji = "";
  try {
    if(window.Intl && Intl.Segmenter) {
      emoji = [...new Intl.Segmenter().segment(input.trim())].map(x => x.segment)[0] || "";
    } else {
      emoji = Array.from(input.trim())[0] || "";
    }
  } catch(e) { console.error(e); emoji = input.trim().slice(0,2); }
  meta.emoji = emoji;
  if(!meta.path) return;
  let existing = getFolderMetaByPath(folderPath);
  if(existing) existing.emoji = emoji;
  else window.storyManager.folderMeta.push(meta);
  requestFolderMetaSaveDebounced({debounceMs:200});
  renderStoriesList();

renameFolder(folderPath) =>
  ensureStoryManager();
  folderPath = normalizeFolderPath(folderPath);
  let newPath = prompt(`Rename folder "${folderPath}" to:`, folderPath);
  if(newPath === null) return;
  newPath = normalizeFolderPath(newPath);
  if(!newPath) return;
  if(newPath === folderPath) return;
  for(let entry of window.storyManager.meta) {
    let fp = normalizeFolderPath(entry.folderPath || "");
    if(fp === folderPath) entry.folderPath = newPath;
    else if(fp.startsWith(folderPath + "/")) entry.folderPath = newPath + fp.slice(folderPath.length);
  }
  for(let f of window.storyManager.folderMeta) {
    let fp = normalizeFolderPath(f.path || "");
    if(fp === folderPath) f.path = newPath;
    else if(fp.startsWith(folderPath + "/")) f.path = newPath + fp.slice(folderPath.length);
  }
  if(window.storyManager.currentFolderPath === folderPath || window.storyManager.currentFolderPath.startsWith(folderPath + "/")) {
    window.storyManager.currentFolderPath = newPath + window.storyManager.currentFolderPath.slice(folderPath.length);
  }
  requestMetaSaveDebounced({debounceMs:200});
  requestFolderMetaSaveDebounced({debounceMs:200});
  renderStoriesList();
  updateCurrentStoryTitleDisplay();

async deleteFolder(folderPath) =>
  ensureStoryManager();
  folderPath = normalizeFolderPath(folderPath);
  let answer = prompt(`Delete the folder "${folderPath}" and all stories inside it? Type "yes" to confirm.`);
  if(answer !== "yes") return;
  let idsToDelete = window.storyManager.meta.filter(m => isFolderPrefix(normalizeFolderPath(m.folderPath || ""), folderPath)).map(m => m.id);
  window.storyManager.meta = window.storyManager.meta.filter(m => !idsToDelete.includes(m.id));
  for(let id of idsToDelete) {
    try { await kv.stories.delete(id); } catch(e) { console.error(e); }
  }
  window.storyManager.folderMeta = (window.storyManager.folderMeta || []).filter(f => !isFolderPrefix(normalizeFolderPath(f.path || ""), folderPath));
  requestMetaSaveDebounced({debounceMs:200});
  requestFolderMetaSaveDebounced({debounceMs:200});
  if(window.storyManager.currentFolderPath === folderPath || window.storyManager.currentFolderPath.startsWith(folderPath + "/")) {
    window.storyManager.currentFolderPath = getParentFolderPath(folderPath);
  }
  if(idsToDelete.includes(window.storyManager.currentId)) {
    let nextId = sortMetaByLastEdit(window.storyManager.meta)[0]?.id;
    if(nextId !== undefined) await switchToStory(nextId, {skipSaveCurrent:true, closePanel:false, force:true});
  }
  renderStoriesList();

isUntitledTitle(title) =>
  if(!title) return true;
  let t = title.trim().toLowerCase();
  return t === "untitled story" || t.startsWith("untitled story ");

scheduleAutoNameCheck() =>
  clearTimeout(window.autoNameCheckDebounce);
  window.autoNameCheckDebounce = setTimeout(() => {
    autoNameCurrentStoryIfNeeded();
  }, 1200);

async autoNameCurrentStoryIfNeeded() =>
  try {
    ensureStoryManager();
    let entry = getMetaEntryById(window.storyManager.currentId);
    if(!entry) return;
    if(!isUntitledTitle(entry.title)) return;
    if(entry.autoNameAttempted) return;
    let storyText = storySoFarEl?.value || "";
    if(storyText.length < 3000) return;
    entry.autoNameAttempted = true;
    requestMetaSaveDebounced({debounceMs:200});
    let overview = (storyOverviewEl?.value || "").trim();
    let snippet = storyText.slice(0, 3000);
    let instruction = [
      "Choose a short, memorable story name (max 6 words).",
      "Start your response with \"Story Name:\" and do not add any other text.",
      "",
      `<overview>\n${overview}\n</overview>`,
      "",
      `<story_so_far>\n${snippet}\n</story_so_far>`,
    ].join("\n");
    let result = await ai({
      instruction,
      startWith: "Story Name:",
      stopSequences: ["\n"],
    });
    let raw = ("Story Name:" + (result?.generatedText || "")).trim();
    let name = raw.replace(/^Story Name:\s*/i, "").trim();
    if(!name) return;
    entry.title = name;
    entry.lastEditTime = Date.now();
    renderStoriesList();
    updateCurrentStoryTitleDisplay();
    requestMetaSaveDebounced({debounceMs:200});
  } catch(e) { console.error(e); }

async switchToStory(id, opts) =>
  if(!opts) opts = {};
  ensureStoryManager();
  if(!window.storyManager.isReady) return;

  if(id === window.storyManager.currentId && !opts.force) {
    if(opts.closePanel !== false) closeStoriesPanel();
    return;
  }

  if(window.currentlyGenerating && window.lastGenerationStreamObj) {
    let ok = await confirmAsync("A paragraph is currently generating. Stop it and switch story?", {});
    if(!ok) return null;
    try { window.userClickedStop = true; window.lastGenerationStreamObj.stop(); } catch(e) {}
  }

  if (Object.values(window.generatingBibleSection).some(v => v === true)) {
    let ok = await confirmAsync("A bible section is currently generating. Stop it and create a new story?", {});
    if(!ok) return null;
    
    try {
      window.userClickedStop = true;
      Object.entries(window.currentAutoBibleGeneration).forEach(([key, aiObj]) => {aiObj.stop?.();});
      window.currentBibleGeneration?.stop();
    } catch(e) {console.error(e);}
  }

  if(!opts.skipSaveCurrent) {
    await saveCurrentStoryToKvNow();
    await flushAllStorySaves();
  }

  window.storyManager.isLoading = true;
  window.currentStoryId = id;

  // load data
  let data = await kv.stories.get(id);
  if(!data) data = getBlankStoryData();
  data = normalizeStoryData(data);

  window.storyManager.currentId = id;
  window.storyManager.currentData = data;

  // persist active id (cheap)
  kv.storiesMeta.set(ACTIVE_STORY_ID_KEY, id).catch(console.error);

  // reset per-story ephemeral UI/state BEFORE loading new content
  resetPerStoryEphemeralState();

  // load into UI
  window.loadingStoryInProgress = true;
  loadChatDataIntoInputAreas(data);
  window.loadingStoryInProgress = false;

  updateCurrentStoryTitleDisplay();
  renderStoriesList();

  // Update backups UI for the newly-selected story, if that subsystem is ready:
  try { if(window.renderAutoBackupsList) window.renderAutoBackupsList(); } catch(e) { console.error(e); }

  // close panel (esp on mobile)
  if(opts.closePanel !== false) closeStoriesPanel();

  // scroll to top (nice when switching stories)
  try { document.scrollingElement.scrollTop = 0; } catch(e) {}

  window.storyManager.isLoading = false;

async initStoriesSystem() =>
  ensureStoryManager();
  window.storyManager.isLoading = true;
  window.storyManager.isReady = false;

  let meta = await kv.storiesMeta.get(STORIES_META_KEY);
  if(!Array.isArray(meta)) meta = [];
  // sanitize
  meta = meta.filter(m => m && m.id !== undefined && m.id !== null).map(m => {
    return {
      id: m.id,
      title: (m.title || "Untitled story"),
      createdTime: m.createdTime || Date.now(),
      lastEditTime: m.lastEditTime || m.createdTime || Date.now(),
      pinned: !!m.pinned,
      folderPath: normalizeFolderPath(m.folderPath || ""),
      autoNameAttempted: !!m.autoNameAttempted,
    };
  });
  
  let folderMeta = await kv.storiesMeta.get(FOLDERS_META_KEY);
  if(!Array.isArray(folderMeta)) folderMeta = [];
  folderMeta = folderMeta.filter(f => f && f.path).map(f => ({path: normalizeFolderPath(f.path || ""), emoji: (f.emoji || "")}));
  window.storyManager.folderMeta = folderMeta;
  window.storyManager.hadNoStoriesOnLoad = false;
  
  let appMusic = await kv.storiesMeta.get(APP_CUSTOM_MUSIC_KEY);
  let appBackgrounds = await kv.storiesMeta.get(APP_CUSTOM_BACKGROUNDS_KEY);
  window.appCustomMusic = normalizeCustomMediaList(appMusic);
  window.appCustomBackgrounds = normalizeCustomMediaList(appBackgrounds);
  let appNotebook = await kv.storiesMeta.get(APP_NOTEBOOK_KEY);
  window.appNotebookData = normalizeNotebookData(appNotebook);

  // Legacy localStorage -> kv upgrade
  // if(legacyStoryDataExistsInLocalStorage()) {
  //   if (codeDebug) console.log("Found legacy data")
  //   let legacyData = getLegacyStoryDataFromLocalStorage();
  //   clearLegacyStoryDataFromLocalStorage();

  //   let legacyId = 0;
  //   if(meta.some(m => m.id === legacyId)) legacyId = generateNewStoryId();

  //   let now = Date.now();
  //   let title = "Untitled story";
  //   // if it's effectively empty, still keep but label
  //   if((legacyData.storyOverview + legacyData.storySoFar + legacyData.whatHappensNext).trim() === "") {
  //     title = "Untitled story";
  //   }

  //   meta.unshift({id:legacyId, title, createdTime:now, lastEditTime:now, pinned:false, folderPath:"", autoNameAttempted:false});
  //   await kv.stories.set(legacyId, normalizeStoryData(legacyData));

  //   // If old autoBackups were keyed by 0 and legacyId changed, migrate them too.
  //   if(legacyId !== 0) {
  //     try {
  //       let backups = await kv.autoBackups.get(0);
  //       if(Array.isArray(backups) && backups.length > 0) {
  //         await kv.autoBackups.set(legacyId, backups);
  //         await kv.autoBackups.delete(0);
  //       }
  //     } catch(e) { console.error(e); }
  //   }

  //   await kv.storiesMeta.set(STORIES_META_KEY, meta);
  //   await kv.storiesMeta.set(ACTIVE_STORY_ID_KEY, legacyId);
  // }

  // If no stories exist yet, create a first one
  if(meta.length === 0) {
    window.storyManager.hadNoStoriesOnLoad = true;
    let id = generateNewStoryId();
    let now = Date.now();
    meta.unshift({id, title:"Untitled story", createdTime:now, lastEditTime:now, pinned:false, folderPath:"", autoNameAttempted:false});
    await kv.stories.set(id, getBlankStoryData());
    await kv.storiesMeta.set(STORIES_META_KEY, meta);
    await kv.storiesMeta.set(ACTIVE_STORY_ID_KEY, id);
  }

  window.storyManager.meta = meta;

  // Choose active story
  let activeId = await kv.storiesMeta.get(ACTIVE_STORY_ID_KEY);
  if(activeId === undefined || activeId === null || !meta.some(m => m.id === activeId)) {
    activeId = sortMetaByLastEdit(meta)[0]?.id ?? meta[0].id;
    await kv.storiesMeta.set(ACTIVE_STORY_ID_KEY, activeId);
  }

  window.storyManager.currentId = activeId;
  window.currentStoryId = activeId;

  let data = await kv.stories.get(activeId);
  if(!data) {
    data = getBlankStoryData();
    await kv.stories.set(activeId, data);
  }
  data = normalizeStoryData(data);
  window.storyManager.currentData = data;

  // Load into UI
  window.loadingStoryInProgress = true;
  loadChatDataIntoInputAreas(data);
  window.loadingStoryInProgress = false;

  updateCurrentStoryTitleDisplay();
  renderStoriesList();
  updateStoryHeaderVisibility();

  window.storyManager.isReady = true;
  window.storyManager.isLoading = false;
  setTimeout(() => initStoryObserver(), 1000)

getParagraphEndRegex() => return /[.。．！!？?ー":*»’”—–。]$/;

getNumParagraphsToPutInStartWith() =>
  // The <writing_instructions> are always put at the *end* of the instruction to the AI. We want to bias towards "injecting" those writing instructions at the point in the story *where the user actually wrote them*, so we move (up to) a few paragraphs into the startWith to do that.
  let marker = window.whatShouldHappenNextInsertionPointText;
  if(!marker || typeof marker !== "string") return 0;
  let storyText = (storySoFarEl?.value || "");
  if(!storyText) return 0;
  let index = storyText.lastIndexOf(marker);
  if(index < 0) return 0;
  let after = storyText.slice(index + marker.length);
  let nextDoubleNewline = after.indexOf("\n\n");
  if(nextDoubleNewline < 0) return 0;
  let remainder = after.slice(nextDoubleNewline + 2);
  if(!remainder) return 0;
  let count = remainder.split(/\n{2,}/).map(p => p.trim()).filter(Boolean).length;
  return Math.min(3, count);
  
getStorySoFarForInstruction() =>
  if (codeDebug) console.log("getStorySoFarForInstruction");
  let paras = (window.preprocessedStorySoFarText || "").trim().split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
  const storyEndsCleanly = getParagraphEndRegex().test((window.preprocessedStorySoFarText || "").trim());
  // If story doesn't end cleanly, always exclude last paragraph (it goes in startWith)
  // Otherwise, exclude based on numParagraphsToPutInStartWith setting
  const numToExclude = storyEndsCleanly ? getNumParagraphsToPutInStartWith() : 1;
  if(numToExclude === 0) return paras.join("\n\n").trim();
  return paras.slice(0, Math.max(0, paras.length - numToExclude)).join("\n\n").trim();
  
getStartWithText() =>
  if (codeDebug) console.log("getStartWithText");
  let paras = (storySoFarEl.value || "").trim().split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
  if(window.continueMode === "inline") return paras.slice(-1).join("\n\n").trim();
  const storyEndsCleanly = getParagraphEndRegex().test(storySoFarEl.value.trim());
  if(!storyEndsCleanly) return paras.slice(-1).join("\n\n").trim(); // If story doesn't end cleanly, always include last paragraph so AI can continue mid-sentence
  let numToPutInStartWith = getNumParagraphsToPutInStartWith();
  if(numToPutInStartWith === 0) return "\n\n";
  let startWithText = paras.slice(-numToPutInStartWith).join("\n\n").trim();
  return startWithText + "\n\n";

getPreprocessedStoryText() =>
  if (codeDebug) console.log("getPreprocessedStoryText");
  let storySoFarText = storySoFarEl.value;
  let resultText = storySoFarText;  
  let bibleData = getCombinedStoryBibleText(true);
  try {
    // get a version of the message feed with hierarchical summaries swapped in:
    let messagesWithSummaryReplacements = getMessagesWithSummaryReplacements(storySoFarText);

    if(messagesWithSummaryReplacements.slice(-8).filter(m => /^SUMMARY\^[0-9]+:/.test(m)).length > 0) {
      console.error("Summarization is going too close to the end of the story. Must stay back so LLM doesn't get confused, and so messages-in-startWith trick works.");
    }
    
    // === RE-INSERT REMOVED BIBLE MARKERS ===
    if (Array.isArray(bibleData)) {
      bibleData.forEach(section => {
        const marker = section.marker;
        const markerRegex = new RegExp(`(^|\\n)${marker}(\\n|$)`);
        // If marker existed originally but got removed
        if (markerRegex.test(storySoFarText) && !messagesWithSummaryReplacements.includes(marker)) {
          let messages = storySoFarText.split(/\n{2,}/).map(m => m.trim());
          let markerIndex = messages.findIndex(m => m === marker);
          if (markerIndex !== -1) {
            let messagesAfterMarker = messages.slice(markerIndex + 1);
            for (let i = 0; i < messagesWithSummaryReplacements.length; i++) {
              let m = messagesWithSummaryReplacements[i].trim();
              if (messagesAfterMarker.includes(m)) {
                messagesWithSummaryReplacements.splice(i, 0, marker);
                break;
              }
            }
          }
        }
      });
    }
    
    if (codeDebug) console.log(messagesWithSummaryReplacements);
    messagesWithSummaryReplacements = messagesWithSummaryReplacements.map(m => m.replace(/SUMMARY\^[0-9]+:/, "Summary (previous events):").trim());

    resultText = messagesWithSummaryReplacements.join("\n\n").trim();
  } catch(e) {
    console.error("Falling back to using *all* messages because there was an error while trying to compute messagesWithSummaryReplacements:", e);
  }
  // === REPLACE MARKERS WITH SECTION CONTENT ===
  if (Array.isArray(bibleData)) {
    bibleData.forEach(section => {
      const markerRegex = new RegExp(`(^|\\n+)${section.marker}\\n*`);
      if (section.hasContent && section.data?.content?.trim()) {
        const formattedSection =
          `\n\n<tracked_info>\n${section.data.content.trim()}\n</tracked_info>\n\n`;
        resultText = resultText.replace(markerRegex, formattedSection);
      } else {
        resultText = resultText.replace(markerRegex, "\n\n");
      }
    });
  }
  return resultText;

regenerateLast() =>
  if(codeDebug) {console.log("regenerateLast");}

  let paragraphs = storySoFarEl.value.trim().split('\n\n');
  let lastPara = paragraphs[paragraphs.length - 1];
  if(lastPara.startsWith('>')) {
    if(codeDebug) console.log("Found user action, generating paragraph instead");
    storySoFarEl.value = storySoFarEl.value.trim()+"\n"
    return continueStory({regen:true});
  }
  if(window.storyTextBeforeLastGeneration) {
    if(codeDebug) {console.log("regenerateLast : storyTextBeforeLastGeneration :\n" + window.storyTextBeforeLastGeneration);}
    storySoFarEl.value=window.storyTextBeforeLastGeneration;
  }
  else { 
    storySoFarEl.value=storySoFarEl.value.trim().split('\n\n').slice(0, -1).join('\n\n');
  };
  requestSaveCurrentStory({immediate:true}); 
  return continueStory({regen:true});

async continueStory(opts) =>
  if(!opts) opts = {};
  if(window.currentlyGenerating) return; // we already disable buttons below, but this is just for extra safety
  if(localStorage.emDashesComfirmation !== "1") {
    if(!confirm(`Note: This is your first time running a new story. This Generator cleans up dashes from the text, including imported stores. if you don't want this. hit 'Cancel', and enable the option under Settings.\n\nIf you've already set it to your desired settting, you can hit 'OK'.`)) return;
    localStorage.emDashesComfirmation = "1";
  }
  window.currentlyGenerating = true;

  window.lastGenWasContinueInline = !!opts.continueInline;

  // Check if first story run
  if(opts.storyBegin) {
    storyBeginBtn.textContent = "⏳ loading...";
    storyBeginBtn.disabled = true;
  }

  if (storyDiceCheckbox.checked && (!opts.regen || localStorage.dieRoll === "")) {rollDice();}
  
  try { injectSummariesAndComputeNextSummariesInBackgroundIfNeeded(); } catch(e) { console.error(e); }
  await new Promise(r => setTimeout(r, 5)); // just in case i accidentally make the above function async at some point - want to ensure it grabs a snapshot of the chat logs text before `temporarilyRemovedPrefixChatLogsForStreamingRenderPerformance` stuff
  
  window.userClickedStop = false;
  resetRatingButtons(); 
  
  continueTextBtn.style.visibility = "hidden"; // using this too because i think the continue button textarea tracking stuff is making it visible during generation via style.display
  continueTextBtn.hidden = true;
  continueTextBtn.disabled = true;
  storySoFarEl.spellcheck = false;
  shortcutButtonsCtn.querySelectorAll("button").forEach(el => el.disabled=true);
  
  updateTrackedInfoUndoBtn.hidden = true;
  
  // important for summary stuff, since we need "normalized" paragraphs so that summary replacements/injections work properly:
  antiAntiLayoutJank(() => { storySoFarEl.value = storySoFarEl.value.trim().split(/\n{2,}/).map(p => p.trim()).join("\n\n"); storySoFarEl.scrollTop=storySoFarEl.scrollHeight; })
  
  // if(!opts.continueInline && storySoFarEl.value !== "" && getParagraphEndRegex().test(storySoFarEl.value.trim())) { // if the story textbox isn't empty and it ends with a fullstop, question mark, quote, etc.
  //   antiAntiLayoutJank(() => storySoFarEl.value = storySoFarEl.value.trim() + "\n\n"); // then we add a couple of new lines to the end, ready for the next paragraph that's about to be generated
  // }-

  const bibleData = getCombinedStoryBibleText(true);

  if (infoTrackingBtn.dataset.enabled) {
    // Start with trimmed story text
    let storyText = storySoFarEl.value.trim();
  
    // Iterate through each section in bibleData
    bibleData.forEach(entry => {
      if (entry.hasContent) {
        let paragraphs = storyText.split(/\n\s*\n/);
    
        // Find last paragraph that does NOT start with "<"
        let targetIndex = -1;
        for (let i = paragraphs.length - 1; i >= 0; i--) {
          if (!paragraphs[i].trim().startsWith("<")) {
            targetIndex = i;
            break;
          }
        }
    
        if (!storyText.includes(entry.marker)) {
          if (targetIndex !== -1) {
            paragraphs.splice(targetIndex, 0, entry.marker);
            storyText = paragraphs.join("\n\n");
          } else {
            // fallback
            storyText = entry.marker + "\n\n" + storyText;
          }
        } else {
          // Remove marker from wherever it exists
          paragraphs = paragraphs.map(p =>
            p.replace(entry.marker, '').trim()
          ).filter(p => p !== '');
    
          // Recalculate target index after cleanup
          targetIndex = -1;
          for (let i = paragraphs.length - 1; i >= 0; i--) {
            if (!paragraphs[i].trim().startsWith("<")) {
              targetIndex = i;
              break;
            }
          }
    
          if (targetIndex !== -1) {
            paragraphs.splice(targetIndex, 0, entry.marker);
          } else {
            paragraphs.unshift(entry.marker);
          }
    
          storyText = paragraphs.join("\n\n");
        }
      }
    });
  
    // Update the textarea with cleaned and updated story
    storySoFarEl.value = storyText.trim();
  }
  
  if(opts.continueInline) {
    if (codeDebug) console.log("continueStory : continueInline : START");
    antiAntiLayoutJank(() => storySoFarEl.value = storySoFarEl.value.trim());
    window.continueMode = "inline";
  } else {
    if (codeDebug) console.log("continueStory : continueInline : ELSE");
    window.continueMode = "normal";
    if(storySoFarEl.value.trim() && whatHappensNextEl.value.trim() && !toggleSendStoryInputCheckbox.checked) {
      if (codeDebug) console.log("continueStory : continueInline : ELSE : IF");
      storySoFarEl.value = storySoFarEl.value.trim() + "\n\n" + "> "+whatHappensNextEl.value.trim();
      whatHappensNextEl.value = "";
      localStorage.whatHappensNext = "";
    if (codeDebug) console.log("continueStory : continueInline : END");
    }
  }
  storySoFarEl.scrollTop = storySoFarEl.scrollHeight;
  
  // function replaceLast(str, pattern, replacement) {
  //   const index = str.lastIndexOf(pattern);
  //   if (index === -1) return str;
  //   return str.slice(0, index) + replacement + str.slice(index + pattern.length);
  // }
  
  let instructionStoryText = getPreprocessedStoryText();
  if (codeDebug) console.log("continueStory : instructionStoryText:\n" + instructionStoryText);
  let continueWithAction = false; // we only use the "action" task template if there was a "> " which precedes the text we're about to generate
  let instructionStoryChunks = instructionStoryText.trim().split("\n\n");
  
  // We don't want e.g. part of the tracked_info to be put in the startWith,
  // so we make sure its all in a single chunk

  const bibleMarkers = Array.isArray(bibleData) ? bibleData.map(s => s.marker) : [];

  if (bibleMarkers.length && bibleMarkers.some(m => instructionStoryText.includes(m))) {

    let instructionStoryChunksFixed = [];
    let areWithinMultiParagraphSection = false;
    let currentMultiParagraphSectionChunks = [];

    if (codeDebug) console.log("OriginalChunks:");
    if (codeDebug) console.log(instructionStoryChunks);
    for (let p of instructionStoryChunks) {
  
      const trimmed = p.trim();
      const startsWithMarker = bibleMarkers.some(marker => trimmed.startsWith(marker));
  
      if (startsWithMarker) {
        areWithinMultiParagraphSection = true;
      }
  
      if (areWithinMultiParagraphSection) {
        if (codeDebug) console.log("areWithinMultiParagraphSection");
  
        currentMultiParagraphSectionChunks.push(p);
  
        // End block when we hit closing tracked_info
        if (trimmed.endsWith("</tracked_info>")) {
          instructionStoryChunksFixed.push(currentMultiParagraphSectionChunks.join("\n\n"));
          currentMultiParagraphSectionChunks = [];
          areWithinMultiParagraphSection = false;
        }
  
      } else {
        instructionStoryChunksFixed.push(p);
      }
    }
  
    instructionStoryChunks = instructionStoryChunksFixed;
    if (codeDebug) console.log("FixedChunks:");
    if (codeDebug) console.log(instructionStoryChunks);
  
    // Move final bible block back one spot if it's last
    if (
      instructionStoryChunks.length >= 2 &&
      bibleMarkers.some(marker =>
        instructionStoryChunks.at(-1).trim().startsWith(marker)
      )
    ) {
      let lastIndex = instructionStoryChunks.length - 1;
      let bibleBlock = instructionStoryChunks[lastIndex];
      instructionStoryChunks[lastIndex] = instructionStoryChunks[lastIndex - 1];
      instructionStoryChunks[lastIndex - 1] = bibleBlock;
    }
  }
  
  let inlineCompletionText = ""; 
  if(window.continueMode === "inline") {
    // we kind of treat the inline-completed paragraph like that text is "generated" by the function call, rather than being part of the story.
    // so we don't have to mess around with extra if conditions in the NEXT_ACTION stuff below, for example.
    inlineCompletionText = instructionStoryChunks.pop();
    if (codeDebug) console.log("continueMode : Inline");
    if (codeDebug) console.log(inlineCompletionText);
    
  }

  if (codeDebug) console.log("continueStory : continueWithAction : BEFORE " + continueWithAction);
  // if last paragraph starts with "> " then we should use the "action" template.
  if(instructionStoryChunks.at(-1)?.trim().startsWith("> ")) continueWithAction = true;
  if (codeDebug) console.log("continueStory : continueWithAction : AFTER " + continueWithAction);
  if (codeDebug) console.log("continueStory : opts.continueInline : " + opts.continueInline);
  if(continueWithAction) { // replace last "> " with "NEXT_ACTION: "
    // NOTE: the underscore is important! as of writing, the LLM that the ai text plugin uses pays more attention to it
    let lastParagraph = instructionStoryChunks.at(-1);
    if(lastParagraph.trim().startsWith("> ")) instructionStoryChunks[instructionStoryChunks.length-1] = lastParagraph.trim().replace(/^> /, "NEXT_ACTION: "); 
  }
  
  let startWithStoryText = "";

  if(continueWithAction) {
    if (codeDebug) console.log("continueStory : continueWithAction");
    startWithStoryText = getStoryPrefixData(window.continueMode)+"\n"+inlineCompletionText;
    if (codeDebug) console.log("continueStory : continueWithAction : startWithStoryText :\n" + startWithStoryText);
  } else {
    // the paragraph before the one being generated should be in the startWith, to help the AI see the continuation of the story properly (i.e. not get distracted by the instructions)
    if (codeDebug) console.log(":::: instructionStoryChunks:::::");
    if (codeDebug) console.log(instructionStoryChunks);
    startWithStoryText = instructionStoryChunks.pop() || "";
    if (codeDebug) console.log(":::: startWithStoryText - BEFORE:::::");
    if (codeDebug) console.log(startWithStoryText);
    if(inlineCompletionText) {
      if (codeDebug) console.log("inlineCompletionText");
      if (codeDebug) console.log(inlineCompletionText);
      startWithStoryText +=  (startWithStoryText ? "\n\n" : "") + inlineCompletionText; //getStoryPrefixData("inlineCompletionText")
      if (codeDebug) console.log(":::: startWithStoryText - AFTER::::");
      if (codeDebug) console.log(startWithStoryText);
    } else {
      if (codeDebug) console.log("inlineCompletionText - else");
      startWithStoryText += "\n\n"; // getStoryPrefixData("else")
    }
  }
  
  instructionStoryText = instructionStoryChunks.join("\n\n");
  
  window.processedStorySoFarText = instructionStoryText.trim(); // global, because it's used by sharedInstructionPrefix
  if (codeDebug) console.log("continueWithAction: " + continueWithAction);
  if(continueWithAction) {
    window.taskPrompt = consequencesOfActionTaskInstruction.evaluateItem;
  } else {
    window.taskPrompt = continueWithoutActionTaskInstruction.evaluateItem;
  }
  if (window.continueMode === "inline") {
    let storyEnd = storySoFarEl.value.trim().slice(-2);
    if (storyEnd === ' "') {
      if (codeDebug) console.log("found dialog");
      window.taskPrompt += "\nFinish the current line of dialogue. Continue the text inside the quotation marks and end with a closing quote. Limit the response to a maximum of 3 sentences. Use a single paragraph only. No line breaks.";
    } else {
      window.taskPrompt += "Create new sentences for the current paragraph. no linebreaks and Keep it in a single paragraph, max 3 sentences.";
      // window.taskPrompt += "\nFinish the current line of dialogue without starting a new line or adding a line break. Use a single paragraph only and ensure the text flows directly from the previous sentence.";
    }
  } 
  window.taskPrompt += "\n</instructions>"; // since sharedInstructionPrefix adds <instruction> at the start of the shared instructions to help separate all the instructions from the story text
  console.log("Finished taskPrompt");
  console.log(window.taskPrompt);
  window.storyTextBeforeLastGeneration = storySoFarEl.value;

  
  
  if(hasActualStoryContent()) {
    if (codeDebug) console.log("Continuing story");
    if (codeDebug) console.log("StopSequence: " + window.continueMode);    
    
    window.lastGenerationStreamObj = ai({
      instruction: () => {
        let lines = [];
        lines.push(sharedInstructionPrefix.evaluateItem);
        lines.push(window.taskPrompt);

        return lines.join("\n").trim().replace(/<instructions>\n+/, "<instructions>\n");
      },
      startWith: () => {
        if(storySoFarEl.value.trim() === "") {if (codeDebug) console.log("story empty?"); return "";}
        return startWithStoryText;
      },
      // CAUTION: note to self: if you change the stop sequence, ensure that the onChunk new-line removal stuff still makes sense
      stopSequences: window.continueMode === "inline" ? ["\n\n", "\n# Ambient Outro"] : ["\n# Ambient Outro"],
      onStart: generationEventHandlers.onStart,
      onChunk: generationEventHandlers.onChunk,
      onFinish: generationEventHandlers.onFinish,
    }); // we put it into a 'global' variable so that we can use it in the 'onclick' of the stop button to stop the text generation
  } else {
    if (codeDebug) console.log("Writing new story")
    let storyStartWith = "You";
    storySoFarEl.value = storySoFarEl.value.trim();
    if (storySoFarEl.value.trim().endsWith(">")) {storySoFarEl.value += "\n"};
    if (storyPerspective === "first") {storyStartWith = "I"};
    if (storyPerspective === "third") {storyStartWith = "They"};
    window.includeStartWithInOutput = true;
    window.lastGenerationStreamObj = ai({
      instruction: `Write the opening paragraph of a text adventure RPG based on this instruction/idea by the player: "${storyOverviewEl.value.trim() || "Something unusual and fun"}"\nWrite one paragraph only. This is just the opening paragraph - the *start* of the story, so don't progress too quickly. Avoid cringe/overly grandiose phrasing. Start in a specific/concrete situation, perhaps with some character dialogue. Don't reveal key story details yet.${Math.random() < 0.5 ? " Include some character dialogue." : ""}`,
      startWith: storyStartWith,
      stopSequences: ["\n"],
      onStart: generationEventHandlers.onStart,
      onChunk: generationEventHandlers.onChunk,
      onFinish: generationEventHandlers.onFinish,
    });
    window.lastGenerationStreamObj.then(() => {
      window.includeStartWithInOutput = false;
    });
  }

  loaderEl.innerHTML = icon("cog spin");
  // loaderEl.innerHTML = window.lastGenerationStreamObj.loadingIndicatorHtml; 
  
  let data = await window.lastGenerationStreamObj;
  
  loaderEl.innerHTML = ""; 
  
  window.currentlyGenerating = false;
  
  if(localStorage.generateCount === undefined || isNaN(Number(localStorage.generateCount))) localStorage.generateCount = "0";
  localStorage.generateCount = Number(localStorage.generateCount) + 1;
  updateLastParagraphButtonsDisplayIfNeeded();
  
  if(data.stopReason !== "error" && !window.userClickedStop) {
    enableRatingButtons();
  }
  
  if(/, a stark reminder of [^.]{0, 20}\.$/.test(storySoFarEl.value.slice(-2000).trim())) {
    storySoFarEl.value = storySoFarEl.value.trim().replace(/, a stark reminder of [^.]{1,40}\.$/, ".");
  }
  
  continueTextBtn.disabled = false;
  continueTextBtn.style.visibility = "visible";
  storySoFarEl.spellcheck = true;
  shortcutButtonsCtn.querySelectorAll("button").forEach(el => el.disabled=false);
  
  let generateCount = Number(localStorage.generateCount);
  if(generateCount > 20 && !localStorage.haveUsedTabToContinueMessage) {
    let isTouchScreen = false;
    try { isTouchScreen = window.matchMedia("(pointer: coarse)").matches; } catch(e) { console.error(e); }
    if(window.innerWidth > window.innerHeight && !isTouchScreen) {
      continueTextBtnTabLabel.style.display = "";
    }
  }
  if(generateCount > 5) subtitleEl.style.display = "none";
  console.log("contiueStory : END")

updateLastParagraphButtonsDisplayIfNeeded() =>
  let generateCount = Number(localStorage.generateCount); 
  if(generateCount > 2) {
    rateLastMessageCtn.style.display = "inline-block";
    deleteLastBtn.innerHTML = `${icon("trash")}`;
    // deleteLastBtn.style.minWidth = "3rem";
    regenLastBtn.innerHTML = `${icon("arrows-rotate","color:var(--info);")}`;
    // regenLastBtn.style.minWidth = "3rem";
  }

updateButtonsDisplay() =>
  if(codeDebug) { console.log("updateButtonsDisplay: " + localStorage.gameMode)}
  if(storySoFarEl.value.trim() === "") {
    bottomButtonsCtn.style.display = "none";
  } else {
    bottomButtonsCtn.style.display = "flex";
    generateBtn.textContent = localStorage.gameMode === "game" ? "Continue Game" : "Continue Story";
  }

hasActualStoryContent() =>
  let content = storySoFarEl.value.trim();
  // Your requested non-grouping regex
  let markerRegex = /^[\s\n]*<[^>]+>(?:[\s\n]*<[^>]+>)*[\s\n]*$/;
  
  // Logical check: 
  // 1. It must have text (content.length > 0)
  // 2. It must NOT match the markers (!markerRegex.test)
  return content.length > 0 && !markerRegex.test(content);

deleteLastParagraph() =>
  if (codeDebug) console.log("deleteLastParagraph");
  window.storyTextBeforeLastParagraphDelete = storySoFarEl.value;
  if(window.storyTextBeforeLastGeneration) window.storyTextBeforeLastGeneration_beforeParagraphDelete = window.storyTextBeforeLastGeneration;
  window.storyTextBeforeLastGeneration = null;
  antiAntiLayoutJank(() => { storySoFarEl.value=storySoFarEl.value.trim().split('\n\n').slice(0, -1).join('\n\n'); storySoFarEl.scrollTop=storySoFarEl.scrollHeight; });
  requestSaveCurrentStory({immediate:true});
  // show undo button for a few seconds:
  undoDeleteLastParagraphCtn.style.display = "";
  clearTimeout(window.undoDeleteButtonHideTimeout);
  window.undoDeleteButtonHideTimeout = setTimeout(() => {
    undoDeleteLastParagraphCtn.style.display = "none";
  }, 1000*4);
  
undoDeleteLastParagraph() =>
  if(window.storyTextBeforeLastParagraphDelete) {
    antiAntiLayoutJank(() => storySoFarEl.value = window.storyTextBeforeLastParagraphDelete);
    if(window.storyTextBeforeLastGeneration_beforeParagraphDelete) window.storyTextBeforeLastGeneration = window.storyTextBeforeLastGeneration_beforeParagraphDelete;
    window.storyTextBeforeLastGeneration_beforeParagraphDelete = null;
    requestSaveCurrentStory({immediate:true});
    undoDeleteLastParagraphCtn.style.display = "none";
  } else {
    console.error("??? should not have been able to click delete button.");
  }
  
antiAntiLayoutJank(fn) => // due to browser's built-in anti-scroll-jank algorithm which sometimes has bad heuristics - i.e. forcibly scrolls whole page to keep textarea text in same position, despite that not being what we want
  let prevPageScrollTop = document.scrollingElement.scrollTop; // record page scroll position
  fn();
  document.scrollingElement.scrollTop = prevPageScrollTop; // restore page scroll position

generateWhatHappensNextIdeas(regen) =>
  if (codeDebug) console.log("generateWhatHappensNextIdeas");
  if(whatHappensNextSuggestionsCtn.innerHTML && !regen) {
    generateWhatHappensNextIdeasBtn.innerHTML = icon("lightbulb","color:#ffe070;");    
    generateWhatHappensNextIdeasBtn.disabled = false;
    return;
  }
  whatHappensNextSuggestionsCtn.style.display = "";
  generateWhatHappensNextIdeasBtn.disabled = true;
  generateWhatHappensNextIdeasBtn.innerHTML = [icon("cog spin")];
  let textSoFar = "";
  let pendingObj = ai({
    instruction: whatHappensNextInstruction.evaluateItem,
    startWith: `Here are 3 different ideas for what you could do next in this story:\n1. I`,
    onChunk: (data) => {
      textSoFar += data.textChunk;
      if(!data.isFromStartWith) {
        whatHappensNextSuggestionsCtn.innerHTML = textSoFar.replace(/\n+/g, "\n\n");

      }
    },
    onFinish: () => {
      let existingInstruction = (window.whatHappensNextSuggestionsRegenInstructions || "").trim().replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      
      let html = textSoFar.trim().split("\n").filter(l => /^[0-9]+\./.test(l.trim())).map(l => l.replace(/^[0-9]+\./g, "").trim()).map(ideaText => {
        let ideaTextEscaped = ideaText.replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        return `<div style="border:1px solid gray; margin:0.25rem; display:flex; padding:0.25rem; border-radius:3px;">
          <div style="padding:0.05rem;">${ideaTextEscaped}</div>
          <button data-idea="${ideaTextEscaped}" onclick="whatHappensNextEl.value=this.dataset.idea; whatHappensNextSuggestionsCtn.style.display='none';">use</button>
        </div>`;
      }).join("");
      
      html = `<div style="max-height: min(90vh, 600px); overflow: auto ">${html}</div>`;
      html += `<div style="display:flex; margin:0.25rem;"><input value="${existingInstruction}" oninput="window.whatHappensNextSuggestionsRegenInstructions=this.value" placeholder="(Optional) Idea regen instructions." style="flex-grow: 1;"><button style="margin-left: 0.25rem;" onclick="generateWhatHappensNextIdeas(true)">🔁 regen</button></div>`;
      
      whatHappensNextSuggestionsCtn.innerHTML = html;
      generateWhatHappensNextIdeasBtn.disabled = false;
      generateWhatHappensNextIdeasBtn.innerHTML = icon("lightbulb","color:#ffe070;");
    },
  });
  whatHappensNextSuggestionsCtn.innerHTML = [icon("cog spin")];

whatHappensNextInstruction
  Please write 3 *short* one-sentence, creative ideas for what the player could do next in this text adventure. You should guess at actions that the player is likely to want to choose, based on their previous actions (prefixed by ">").
  [""]
  [literal(getMessagesWithSummaryReplacements(storySoFarEl.value).map(m => m.replace(/SUMMARY\^[0-9]+:/, "Summary (previous events):")).join("\n\n").trim())]
  [""]
  Again, please write 3 one-sentence ideas. They should be unique, creative, high-level ideas for what the player could do next, which the player is likely to find appealing (based on your observation of their previous actions). Just give a few words for each idea.
  Your ideas should be comparable to that of a world–renowned, award-winning author. Original, subtle, realistic, engaging, authentic, grounded, nuanced.
  Each idea must be a SINGLE, *short* sentence.
  Each idea should be unique to give options to the player.
  Phrase your ideas in first person like "I decide to..."
  [window.whatHappensNextSuggestionsRegenInstructions?.trim() ? `IMPORTANT: Your ideas **MUST** be based on this instruction: ${window.whatHappensNextSuggestionsRegenInstructions}` : ""]
  Follow this template:
  [""]
  1. <a short, **ONE-SENTENCE** spark for an idea about what the player could do next>
  2. <a *DIFFERENT* idea for what the player could do next>
  3. <another SHORT alternative idea for what the player could do next>
  $output = [this.joinItems("\n")]
  
resetRatingButtons() =>
  rateLastMessageBadBtn.disabled = true;
  rateLastMessageGoodBtn.disabled = true;
  rateLastMessageBadBtn.style.opacity = 1;
  rateLastMessageGoodBtn.style.opacity = 1;
  
enableRatingButtons() =>
  rateLastMessageBadBtn.disabled = false;
  rateLastMessageGoodBtn.disabled = false;
  
async rateLastMessage(rating) =>
  if(!window.lastGenerationStreamObj) return;
  
  if(!localStorage.knowsHowRatingsWork) {
    if(!confirm("Your ratings help improve Perchance's AI plugin, which powers this generator. Please do not submit ratings if your story includes sensitive personal info.\n\nContinue?")) return;
    localStorage.knowsHowRatingsWork = "1";
  }
  
  let score = rating==="good" ? 1 : 0;
  rateLastMessageBadBtn.disabled = true;
  rateLastMessageGoodBtn.disabled = true;
  if(rating === "good") {
    rateLastMessageBadBtn.style.opacity = 0.2;
  } else {
    rateLastMessageGoodBtn.style.opacity = 0.2;
  }
  
  if(!window.recentRatingReasonCounts) window.recentRatingReasonCounts = {};
  let reasonCountEntries = Object.entries(window.recentRatingReasonCounts).sort((a,b) => b[1]-a[1]);
  if(reasonCountEntries.length > 10) reasonCountEntries = reasonCountEntries.slice(0, 10);
  window.recentRatingReasonCounts = Object.fromEntries(reasonCountEntries);
  recentRatingReasonsDataList.innerHTML =  reasonCountEntries.map(e => `<option value="${e[0].replace(/</g, "&lt;").replace(/"/g, "&quot;")}"></option>`).join("");
  
  let reasonResolver;
  let reasonFinishPromise = new Promise(r => reasonResolver=r);
  ratingReasonEl.value = "";
  ratingReasonCtn.style.display = "";
  ratingReasonEl.focus();
  await new Promise(r => setTimeout(r, 100));
  
  // if they click anywhere other than the reason input, then we resolve with the current contents of the reason box
  function windowClickHandler(event) {
    if(!ratingReasonCtn.contains(event.target)) {
      reasonResolver(ratingReasonEl.value);
    }
  }
  window.addEventListener("click", windowClickHandler);
  
  // if they press enter, then we resolve too
  function enterKeydownHandler(event) {
    if(event.key === 'Enter') {
      reasonResolver(ratingReasonEl.value);
    }
  }
  ratingReasonEl.addEventListener("keydown", enterKeydownHandler);
  
  let reason = await reasonFinishPromise;
  if(reason.length < 100) window.recentRatingReasonCounts[reason] = (window.recentRatingReasonCounts[reason] || 0) + 1;
  
  ratingReasonCtn.style.display = 'none';
  window.removeEventListener("click", windowClickHandler);
  ratingReasonEl.removeEventListener("keydown", enterKeydownHandler);
  window.lastGenerationStreamObj.submitUserRating({score, reason});

// Story Bible / Info Tracker

regenerateBibleSection() =>
  let bibleSection = window.notepadTabsSelectEl.selectedOptions[0].innerText;
  const lastData = window.lastBibleGenerationData && window.lastBibleGenerationData[bibleSection];
  if (lastData) {
    const targetTextarea = window.notepadEditorEl;
    targetTextarea.value = lastData.existingContent;
    generateBibleSection({ isRegeneration: true, previousNewEvents: lastData.newEvents });
  } else {
    generateBibleSection();
  }

async autoUpdateBibleSection(options) =>
  if (!options) return; // Needs to have something to run this.
  if (codeDebug) console.log("autoUpdateBibleSection");
  if (codeDebug) console.log("autoUpdateBibleSection : window :");
  if (codeDebug) console.log(window.appNotebookDate);
  let cleanTitle = options.title.replace(/[<>\s\/]/g,'');
  window.generatingBibleSection[options.title] = true;
  if (codeDebug) console.log("autoUpdateBibleSection : cleanTitle :" + cleanTitle);
  const storyBible = [
    "<Player Info>",
    "<Other Characters>",
    "<Locations>",
    "<Events/Plot>",
    "<Lore/History>",
    "<Plot Threads>",
  ];
  const bibleSectionMarkers = {
    "<Player Info>": "<update_marker_player>",
    "<Other Characters>": "<update_marker_characters>",
    "<Locations>": "<update_marker_locations>",
    "<Events/Plot>": "<update_marker_events>",
    "<Lore/History>": "<update_marker_lore>",
    "<Plot Threads>": "<update_marker_mysteries>"
  };
  if (!storyBible.includes(options.title)) return;
  if (codeDebug) console.log("autoUpdateBibleSection : options.title : " + options.title);
  let data = getNotebookDataForScope("bible");
  if (codeDebug) console.log("autoUpdateBibleSection : data");
  if (codeDebug) console.log(data);
  let tab = data.tabs.find(t => t.title === options.title);
  if (codeDebug) console.log("autoUpdateBibleSection : tab");
  if (codeDebug) console.log(tab);

  let { isRegeneration, previousNewEvents } = options;
  isRegeneration = tab.content !== "" ? true : false;
  previousNewEvents = isRegeneration ? window.lastBibleGenerationData[cleanTitle] : null;
  
  let storyText = storySoFarEl.value;
  let bibleMarker = bibleSectionMarkers[options.title];  
  if (codeDebug) console.log("autoUpdateBibleSection : storyText");
  if (codeDebug) console.log(storyText);
  
  if (isRegeneration && previousNewEvents !== undefined) {
    window.newEventsForPrompt = previousNewEvents;
  } else {
    let placeholderIndex = storyText.lastIndexOf(bibleMarker);
    if (codeDebug) console.log("generateBibleSection : placeholderIndex : " + placeholderIndex);
    window.newEventsForPrompt = placeholderIndex === -1 ? storyText.trim() : storyText.substring(placeholderIndex + bibleMarker.length).trim();
  }

  window.generatingBibleSectionName = options.title;
  let targetTextarea = "";
  window.existingSectionContentForPrompt = tab.content.trim();

    if (!isRegeneration) {
      window.lastBibleGenerationData[options.title] = {
        newEvents: window.newEventsForPrompt,
        existingContent: window.existingSectionContentForPrompt
      };
      
      let cleanedStoryText = storySoFarEl.value.replace(new RegExp(`\\n*\\s*${bibleMarker.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\s*\\n*`, 'g'), "\n\n").trim();
      if (codeDebug) console.log("generateBibleSection : cleanedStoryText : " + cleanedStoryText);
      storySoFarEl.value = (cleanedStoryText ? cleanedStoryText + "\n\n" : "") + bibleMarker;
      localStorage.storySoFar = storySoFarEl.value;
    }
  closeNotepadPanel();
  Object.assign(openNotepadBtn, {
    disabled: true,
    innerHTML: `${icon("spinner spin-pulse")} Notepad`,
    title: "Bible Updating..."
  });

  let originalText = tab.content;
  // let originalPlaceholder = tab.placeholder;
  // targetTextarea.value = "";
  // targetTextarea.placeholder = "⏳ Loading... Just a sec.";

  window.currentAutoBibleGeneration[options.title] = ai({
    instruction: bibleAutoUpdatePrompt.evaluateItem,
    onChunk: (data) => {
      if (!data.isFromStartWith) {
        targetTextarea += data.textChunk;
      }
    }
  });

    let bibleData;
  try {
    window.generatingBibleSection[options.title] = true;
    if (codeDebug) console.log("autoUpdateBibleSection : try : " + window.generatingBibleSection[options.title]);
    if (codeDebug) console.log("autoUpdateBibleSection : try2 : " + window.generatingBibleSection);
    bibleData = await window.currentAutoBibleGeneration[options.title]; 
    
    if (bibleData.stopReason === 'error' || bibleData.stopReason === 'user') {
      if (codeDebug) console.log("autoUpdateBibleSection : generateBibleSection : ifstop");
    } else {
      if (codeDebug) console.log("autoUpdateBibleSection : try : ifstop : else");
      let finalValue = targetTextarea.trim();
      targetTextarea = finalValue;
      tab.content = finalValue;
    }
  } catch (e) {
    console.error("AI call failed:", e);
  } finally {    
    if (codeDebug) console.log("autoUpdateBibleSection : finally");
    setNotebookDataForScope("bible", data);
    Object.assign(openNotepadBtn, {
      disabled: false,
      innerHTML: `${icon("table-list")} Notepad`,
      title: ""
    });
    
    if (bibleData && bibleData.stopReason !== 'error' && bibleData.stopReason !== 'user') {
      storyBibleRegenBtn.style.display = 'inline-block';
    }
    
    window.generatingBibleSection[options.title] = false;
    window.currentAutoBibleGeneration[options.title] = null;
    window.generatingBibleSectionName = null;
    window.newEventsForPrompt = null;
    window.existingSectionContentForPrompt = null;
  }
  
async generateBibleSection(options) =>
  if (codeDebug) console.log("generateBibleSection");  
  saveNotepadEditorToActiveTab();
  bibleOptionalPrompt = "";
  bibleOptionalPrompt = prompt("(Optional) Specify what information you want tracked besides basics or just click OK.");
  if(bibleOptionalPrompt === null) return; // they clicked cancel
  if (options === undefined) options = {};
  let bibleSection = window.notepadTabsSelectEl.selectedOptions[0].innerText;
  const storyBible = [
    "<Player Info>",
    "<Other Characters>",
    "<Locations>",
    "<Events/Plot>",
    "<Lore/History>",
    "<Plot Threads>",
  ];
  const bibleSectionMarkers = {
    "<Player Info>": "<update_marker_player>",
    "<Other Characters>": "<update_marker_characters>",
    "<Locations>": "<update_marker_locations>",
    "<Events/Plot>": "<update_marker_events>",
    "<Lore/History>": "<update_marker_lore>",
    "<Plot Threads>": "<update_marker_mysteries>"
  };
  if (!storyBible.includes(bibleSection)) return;
  if (codeDebug) console.log("generateBibleSection : bibleSection : " + bibleSection);

  const { isRegeneration, previousNewEvents } = options;
  
  let storyText = storySoFarEl.value;
  let bibleMarker = bibleSectionMarkers[bibleSection];
  if (codeDebug) console.log("generateBibleSection : bibleMarker : " + bibleMarker);

  if (isRegeneration && previousNewEvents !== undefined) {
    window.newEventsForPrompt = previousNewEvents;
  } else {
    let placeholderIndex = storyText.lastIndexOf(bibleMarker);
    if (codeDebug) console.log("generateBibleSection : placeholderIndex : " + placeholderIndex);
    window.newEventsForPrompt = placeholderIndex === -1 ? storyText.trim() : storyText.substring(placeholderIndex + bibleMarker.length).trim();
  }

  // if (!window.newEventsForPrompt && storyText.trim()) {
  //   if (codeDebug) console.log("?");
  //   if (codeDebug) console.log(!window.newEventsForPrompt);
  //   if (codeDebug) console.log(storyText.trim());
  //   window.generatingBibleSection[bibleSection] = false;
  //   return;
  // }
  
  window.generatingBibleSectionName = bibleSection;
  let targetTextarea = window.notepadEditorEl;
  window.existingSectionContentForPrompt = window.notepadEditorEl.value.trim();
  if (!isRegeneration) {
    window.lastBibleGenerationData[bibleSection] = {
      newEvents: window.newEventsForPrompt,
      existingContent: window.existingSectionContentForPrompt
    };
    
    let cleanedStoryText = storySoFarEl.value.replace(new RegExp(`\\n*\\s*${bibleMarker.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\s*\\n*`, 'g'), "\n\n").trim();
    if (codeDebug) console.log("generateBibleSection : cleanedStoryText : " + cleanedStoryText);
    storySoFarEl.value = (cleanedStoryText ? cleanedStoryText + "\n\n" : "") + bibleMarker;
    localStorage.storySoFar = storySoFarEl.value;
  }

  storyBibleGenerateBtn.hidden = true;
  storyBibleRegenBtn.hidden = true;
  storyBibleDeleteBtn.disabled = true;
  storyBibleStopBtn.hidden = false;
  storyBibleLoader.hidden = false;
  closeNotepadBtn.disabled = true;
  notepadScopeSelectEl.disabled = true;
  notepadTabsSelectEl.disabled = true;

  let originalText = targetTextarea.value;
  let originalPlaceholder = targetTextarea.placeholder;
  targetTextarea.value = "";
  targetTextarea.placeholder = "⏳ Loading... Just a sec.";

  window.currentBibleGeneration = ai({
    instruction: bibleAutoUpdatePrompt.evaluateItem,
    // startWith: window.existingSectionContentForPrompt,
    onChunk: (data) => {
      if (!data.isFromStartWith) {
        targetTextarea.value += data.textChunk;
      }
    }
  });
    
  let bibleData;
  try {
    
    window.generatingBibleSection[bibleSection] = true;
    if (codeDebug) console.log("generateBibleSection : try : " + window.generatingBibleSection[bibleSection]);
    
    bibleData = await window.currentBibleGeneration; 
    
    if (bibleData.stopReason === 'error' || bibleData.stopReason === 'user') {
      targetTextarea.placeholder = originalPlaceholder;
      targetTextarea.value = originalText;
    } else {
      let finalValue = targetTextarea.value.trim();
      targetTextarea.value = finalValue;
      targetTextarea.placeholder = originalPlaceholder;
      window.notepadEditorEl.value = finalValue;
    }
  } catch (e) {
    console.error("AI call failed:", e);
    targetTextarea.value = originalText;
    targetTextarea.placeholder = originalPlaceholder;
  } finally {
    targetTextarea.placeholder = originalPlaceholder;
    saveNotepadEditorToActiveTab();
    storyBibleRegenBtn.hidden = (window.notepadEditorEl.value.trim() === "");
    storyBibleRegenBtn.disabled = false;
    storyBibleDeleteBtn.hidden = (window.notepadEditorEl.value.trim() === "");
    storyBibleDeleteBtn.disabled = false;
    storyBibleGenerateBtn.hidden = (window.notepadEditorEl.value.trim() !== "");
    storyBibleGenerateBtn.disabled = false;
    storyBibleStopBtn.hidden = true;
    storyBibleLoader.hidden = true;
    closeNotepadBtn.disabled = false;
    notepadScopeSelectEl.disabled = false;
    notepadTabsSelectEl.disabled = false;
    window.generatingBibleSection[bibleSection] = false;
    window.currentBibleGeneration = null;
    window.generatingBibleSectionName = null;
    window.newEventsForPrompt = null;
    window.existingSectionContentForPrompt = null;
  }

loadChatDataIntoInputAreas(data) =>  
  if (codeDebug) console.log("loadChatDataIntoInputAreas : START");
  if (codeDebug) console.log(data);
  // this function accepts a data object, or if it's not specified then it loads from storyManager.currentData (if present)
  if(!data) {
    try {
      if(window.storyManager && window.storyManager.currentData) data = window.storyManager.currentData;
    } catch(e) { console.error(e); }
  }
  if(!data) data = getBlankStoryData();
  data = normalizeStoryData(data);
  
  window.loadingStoryInProgress = true;
  storyOverviewEl.value = data.storyOverview || "";
  storySoFarEl.value = data.storySoFar || "";
  whatHappensNextEl.value = data.whatHappensNext || "";  
  storyArcInstructionEl.value = data.storyArcInstruction || "";
  // // RESPONSE STYLE:
  // let responseStyle = [...responseStyleEl.querySelectorAll("option")][0].value;
  // if(data.responseStyle) {
  //   let isValid = [...responseStyleEl.querySelectorAll("option")].filter(el => el.value===data.responseStyle).length > 0;
  //   if(isValid) responseStyle = data.responseStyle;
  // }
  // responseStyleEl.value = responseStyle;  
  storyWritingStyleSelectEl.value = data.storyWritingStyle || "default",
  storyCustomWritingStyleCtn.hidden = data.storyWritingStyle !== "custom";
  storyWritingStyleResponseInputEl.value = data.storyWritingStyleResponseInput || "";
  storyWritingStyleCustomInputEl.value = data.storyWritingStyleCustomInput || "";

  storyPerspectiveSelectEl.value = data.storyPerspective || "second";
  difficultyModeEl.value = data.difficultyMode || "";
  storyGameModeSelectEl.value = data.gameMode || "";
  storyWritingLengthEl.value = data.storyWritingLength || "1",
  storyGenreSelectEl.value = data.storyGenreSelect || "default",
  storySubGenreSelectEl.value = data.storySubGenreSelect || "default",
  setParagraphLimitSelectValue(data.paragraphLimit);
  localStorage.shortcutButtons = JSON.stringify(data.shortcutButtons || []);
  if (codeDebug) console.log("loadChatDataIntoInputAreas : shortcutButtons");
  if (codeDebug) console.log(localStorage.shortcutButtons);
  localStorage.emDashesComfirmation = data.emDashesComfirmation || ""
  try { applyMediaSettingsFromStoryData(data); } catch(e) { console.error(e); }
  try { applyThemeSettingsFromStoryData(data); } catch(e) { console.error(e); }
  try { applyNotebookSettingsFromStoryData(data); } catch(e) { console.error(e); }
  renderShortcutButtons();
  window.loadingStoryInProgress = false;

  try { deleteWhatHappensNextBtn.hidden = !whatHappensNextEl.value.trim(); } catch(e) {}
  
  if(storySoFarEl.value.trim() || Number(localStorage.generateCount||0) > 1) {
    storyBeginBtn.hidden = true;
    storyGenerationAreaEl.hidden = false;
    storyBeginOptionsCtn.hidden = true;
    toggleOverviewVisibilityEl.hidden = false;
    genInfoCtn.style.display = "none";
    updateBackgroundVisual(false);
  } else {
    // if truly empty, allow begin button
    // (no-op: existing layout already shows it by default)
  }

  {
    // For long stories, this can take a while, so we time it:
    let t = performance.now();
    storySoFarEl.scrollTop = storySoFarEl.scrollHeight; // scroll to the bottom of the current story
    window.storySoFarElInitialRenderTime = performance.now()-t;
    if (codeDebug) console.log("storySoFarElInitialRenderTime:", window.storySoFarElInitialRenderTime);
  }
  
  currentTrackedInfoEl.value = data.currentTrackedInfo || "";
  infoTrackingBtn.dataset.enabled = data.infoTrackingEnabled || "";
  storyGameModeSelectEl.value = data.gameMode || "";
  storyDashesCheckbox.checked = data.storyDashesEnabled || "";
  localStorage.storyBibleAutoCheckbox_PlayerInfo = data.storyBibleAuto_PlayerInfo || "";
  localStorage.storyBibleAutoCheckbox_OtherCharacters = data.storyBibleAuto_OtherCharacters || "";
  localStorage.storyBibleAutoCheckbox_Locations = data.storyBibleAuto_Locations || "";
  localStorage.storyBibleAutoCheckbox_EventsPlot = data.storyBibleAuto_EventsPlot || "";
  localStorage.storyBibleAutoCheckbox_LoreHistory = data.storyBibleAuto_LoreHistory || "";
  localStorage.storyBibleAutoCheckbox_PlotThreads = data.storyBibleAuto_PlotThreads || "";
  storyDiceCheckbox.checked = data.storyDiceEnabled || "";
  toggleSendStoryInputCheckbox.checked = data.toggleSendStoryInput || "";
  diceRollBtn.innerHTML = `${icon("dice-d20")}` + localStorage.dieRoll || `${icon("dice-d20")}`;
  updateInfoTrackingDisplay(false);
  
  updateButtonsDisplay();
  updateStoryHeaderVisibility();
  updateOverviewToggleText();
  checkOverlyLongFixedTokens();
  renderNotepadTabs();

  try { applySharedPresentation(data); } catch(e) { console.error(e); }
  
captureDefaultTitleAndSubtitle() =>
  if(typeof topStuffEl === "undefined") return;
  if(window.defaultPageTitleText === undefined) {
    let h1 = topStuffEl.querySelector("h1");
    let subtitle = document.getElementById("subtitleEl");
    window.defaultPageTitleText = h1 ? h1.textContent : "";
    window.defaultSubtitleText = subtitle ? subtitle.textContent : "";
    window.defaultSubtitleDisplay = subtitle ? subtitle.style.display : "";
  }

applySharedPresentation(data) =>
  captureDefaultTitleAndSubtitle();
  let h1 = topStuffEl?.querySelector("h1");
  let subtitle = document.getElementById("subtitleEl");
  let shareIntroCtn = document.getElementById("shareIntroCtn");
  let intro = (data?.sharedIntroMessage || "").toString().trim();
  window.currentSharedIntroMessage = intro;
  let shareTitle = "";
  try {
    let entry = getMetaEntryById(window.storyManager?.currentId ?? window.currentStoryId);
    shareTitle = (entry?.title || "").toString().trim();
  } catch(e) {}
  if(intro) {
    if(h1) h1.textContent = shareTitle || window.defaultPageTitleText || h1.textContent;
    if(shareIntroCtn) {
      shareIntroCtn.textContent = intro;
      shareIntroCtn.hidden = !intro;
    }
  } else {
    if(h1 && window.defaultPageTitleText !== undefined) h1.textContent = window.defaultPageTitleText;
    if(subtitle && window.defaultSubtitleText !== undefined) {
      subtitle.textContent = window.defaultSubtitleText;
      subtitle.style.display = window.defaultSubtitleDisplay || "";
    }
    if(shareIntroCtn) {
      shareIntroCtn.textContent = "";
      shareIntroCtn.hidden = true;
    }
  }

openShareModal(opts) =>
  if(typeof shareModalEl === "undefined") return;
  window.shareTargetStoryId = opts?.storyId ?? (window.storyManager?.currentId ?? null);
  if(typeof shareIncludeNotesEl !== "undefined") shareIncludeNotesEl.checked = true;
  if(typeof shareIntroMessageEl !== "undefined") shareIntroMessageEl.value = "";
  if(typeof shareGenerateBtn !== "undefined") { shareGenerateBtn.disabled = false; shareGenerateBtn.textContent = "🔗 generate link"; }
  if(typeof shareResultSection !== "undefined") shareResultSection.hidden = true;
  if(typeof shareFormSection !== "undefined") shareFormSection.hidden = false;
  if(typeof shareStoryLinkInputEl !== "undefined") shareStoryLinkInputEl.value = "";
  if(typeof shareLinkCopyBtn !== "undefined") shareLinkCopyBtn.textContent = "📋";
  shareModalEl.hidden = false;

closeShareModal() =>
  if(typeof shareModalEl === "undefined") return;
  shareModalEl.hidden = true;

async runShareFromModal() =>
  if(typeof shareGenerateBtn !== "undefined") {
    shareGenerateBtn.disabled = true;
    shareGenerateBtn.textContent = "⏳ uploading...";
  }
  let includeNotes = !!(typeof shareIncludeNotesEl !== "undefined" && shareIncludeNotesEl.checked);
  let intro = (typeof shareIntroMessageEl !== "undefined" ? shareIntroMessageEl.value : "").toString();
  await generateShareLinkForStory({includeNotes, introMessage:intro, storyId: window.shareTargetStoryId});
  if(typeof shareGenerateBtn !== "undefined") {
    shareGenerateBtn.disabled = false;
    shareGenerateBtn.textContent = "🔗 generate link";
  }

async generateShareLinkForStory(opts) => 
  if(!opts) opts = {};
  if(!window.CompressionStream) {
    alert("Share links use a feature that's only available in modern browsers. Please upgrade your browser to the latest version to use this feature.");
    return;
  }
  if(typeof shareResultSection !== "undefined") shareResultSection.hidden = true;

  let targetId = opts.storyId ?? (window.storyManager?.currentId ?? null);
  let data = null;
  if(targetId !== null && targetId !== undefined && window.storyManager && targetId !== window.storyManager.currentId) {
    let stored = await kv.stories.get(targetId);
    data = normalizeStoryData(stored || getBlankStoryData());
    // if (codeDebug) console.log("share link if")
    // if (codeDebug) console.log(data)
    data.customMusic = mergeCustomMediaLists(data.customMusic || [], window.appCustomMusic || []);
    data.customBackgrounds = mergeCustomMediaLists(data.customBackgrounds || [], window.appCustomBackgrounds || []);
  } else {
    data = getCurrentStoryData();
    // if (codeDebug) console.log("share link else")
    // if (codeDebug) console.log(data)
  }
  if(((data.storyOverview || "") + (data.storySoFar || "")).trim() === "") {
    alert("You need to add some content before sharing.");
    return;
  }
  if(!opts.includeNotes) delete data.notebook;
  let intro = (opts.introMessage || "").toString().trim();
  data.sharedIntroMessage = intro;
  let entry = getMetaEntryById(targetId ?? window.storyManager?.currentId);
  data.title = (entry?.title || "").toString().trim();
  let jsonString = JSON.stringify(data);
  
  // convert json text to blob:
  jsonString = jsonString.replace(/#/g, "%23"); // since hash is a special character in dataurls (like normal URLs)
  let blob = await fetch("data:text/plain;charset=utf-8,"+jsonString).then(res => res.blob());
  
  // compress blob:
  let compressedBlob = await compressBlobWithGzip(blob);
  
  let { url, size, error } = await upload(compressedBlob);
  if(error) {
    shareStoryLinkInputEl.value = `error: ${error}`;
    alert(`Error: ${error}${error === "disallowed_content" ? ". If you believe this is incorrect, then you may need to explicitly state that relevant characters are 18 or older, since the moderation system can make mistakes if there is ambiguity." : ""}`);
  } else {
    shareStoryLinkInputEl.value = `https://perchance.org/${window.generatorName}#data=`+url.replace("https://user.uploads.dev/file/", "uup1:");
  }
  if(!error && typeof shareFormSection !== "undefined") shareFormSection.hidden = true;
  if(typeof shareResultSection !== "undefined") shareResultSection.hidden = false;

async compressBlobWithGzip(blob) =>
  const cs = new CompressionStream('gzip');
  const compressedStream = blob.stream().pipeThrough(cs);
  let outputBlob = await new Response(compressedStream).blob();
  return new Blob([outputBlob], { type: "application/gzip" }); // <-- to add the correct mime type

async confirmAsync(message, opts) =>
  if(!opts) opts = {};
  if(!message) message = "Are you sure?"
  return new Promise(resolve => {
    const overlay = Object.assign(document.createElement("div"), { tabIndex: 0 });
    overlay.style.cssText = `position:fixed;inset:0;z-index:99999999;display:grid;place-items:center;background-color:rgba(0,0,0,.65);font:16px/1.4 system-ui`;
    overlay.innerHTML = `<div style="text-align:left !important;max-width:min(97vw, 450px);padding:15px;border-radius:8px;background-color:light-dark(#fff,#222);color:light-dark(#000,#fff);box-shadow:0 2px 8px rgba(0,0,0,.2);">
      <p style="margin:0 0 20px;white-space:pre-wrap;">${message.replace(/[<>&]/g, m => ({"<":"&lt;","&":"&amp;",">":"&gt;"}[m]))}</p>
      <div style="display:flex;justify-content:flex-end;gap:8px;">
        <button ${opts.hideCancel ? "hidden" : ""} style="padding:6px 16px;border:1px solid light-dark(#ccc,#555);border-radius:6px;background-color:light-dark(#f6f6f6,#333);color:inherit;cursor:pointer;">Cancel</button>
        <button autofocus style="padding:6px 16px;border:none;border-radius:6px;background-color:light-dark(#1677ff,#2b87ff);color:#fff;cursor:pointer;">Okay</button>
      </div>
    </div>`;
    const [cancelBtn, okBtn] = overlay.querySelectorAll("button");
    const finish = val => { overlay.remove(); resolve(val); };
    cancelBtn.onclick = () => finish(false);
    okBtn.onclick = () => finish(true);
    overlay.onkeydown = e => {
      if (e.key === "Escape") finish(false);
      else if (e.key === "Enter") finish(true);
    };
    document.body.append(overlay);
    overlay.focus({ preventScroll: true }); // enables Esc handling immediately
  });
  
async loadDataFromUrlHash() => 
  let success = false;
  if(!window.DecompressionStream) {
    alert("Story share links use a browser feature that's only available in modern browsers. Please upgrade your browser to the latest version to allow for loading data from story share links.");
    return {success, error:"browser_compat"};
  }
  let proceed = await confirmAsync("You're about to load a shared story. If you already have stories saved in this browser, you can access them via the 📚 stories button.\n\nContinue loading this shared story?");
  if(!proceed) {
    try { window.location.hash = ""; } catch(e) {}
    return {success:false, error:"loading_cancelled_by_user"};
  }
  
  let loadingModal = document.createElement('div');
  loadingModal.innerHTML = `<div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.5); z-index: 9999; display: flex; justify-content: center; align-items: center;">
    <div style="padding: 20px; background-color: var(--box-color); border-radius: 8px;">
      ⏳ loading story data...
    </div>
  </div>`;
  loadingModal = loadingModal.firstElementChild;
  document.body.append(loadingModal);
  
  try {
    let hashText = window.location.hash.slice(1);
    if(!hashText.startsWith("data=")) {
      throw new Error("Invalid share URL.");
    }
    let fileUrl = hashText.replace(/^data=/, "");
    if(/^uup1(:|%3A)/.test(fileUrl)) {
      fileUrl = fileUrl.replace(/^uup1(:|%3A)/, "https://user.uploads.dev/file/");
    }
    let fetchOptions = {};
    if(window.AbortSignal && AbortSignal.timeout) fetchOptions.signal = AbortSignal.timeout(10000);
    let blob = await fetch(fileUrl, fetchOptions).then(res => res.ok ? res.blob() : null).catch(console.error);
    if(!blob) {
      loadingModal.remove();
      await confirmAsync(`It seems you've tried to load a share URL, but the file specified by the URL does not exist. If you believe it should exist, you can ask for help on the community forum, or check if the file has been quarantined:\n\nperchance.org/quarantined-files`, {hideCancel:true});
      return {success:false, error:"loading_cancelled_by_user"};
    }
    let text;
    if(fileUrl.endsWith(".gz")) {
      let decompressedBlob = await decompressBlobWithGzip(blob);
      text = await decompressedBlob.text();
    } else {
      text = await blob.text();
    }
    let data = JSON.parse(text);
    // if (codeDebug) console.log("Import story from URL Hash");
    // if (codeDebug) console.log(data);
    if(data.format === "perchance-ai-story-v1") {
      try {
        // Import as new story (safer than overwriting current story in multi-story world)
        let title = extractAndStripTitleFromImportedStoryData(data, "Imported story");
        await createNewStory({title, data:normalizeStoryData(data)});
        
        if (codeDebug) console.log("reqeusted urlhash? story")
      } catch(e) {
        alert("Failed to import story into your browser storage. Please report this issue using the feedback button, including the story length (word count) and your device/browser.");
        console.error(e);
      }
      success = true;
    } else {
      alert("Unknown story data format.");
    }
  } catch(e) {
    alert(`Failed to load story data: ${e.message}`);
    console.error(e);
  }
  
  loadingModal.remove();
  return {success};
  
async decompressBlobWithGzip(blob) =>
  const ds = new DecompressionStream("gzip");
  const decompressedStream = blob.stream().pipeThrough(ds);
  return await new Response(decompressedStream).blob();

mergeCustomMediaLists(listA, listB) =>
  let map = new Map();
  for(let item of (listA || [])) {
    if(item && item.url) map.set(item.url, {url:item.url, title:item.title || "", emoji:item.emoji || ""});
  }
  for(let item of (listB || [])) {
    if(item && item.url && !map.has(item.url)) map.set(item.url, {url:item.url, title:item.title || "", emoji:item.emoji || ""});
  }
  return [...map.values()];

getCurrentStoryData() =>
  if (codeDebug) console.log("getCurrentStoryData : START");
  let combinedCustomMusic = mergeCustomMediaLists(window.currentCustomMusic || [], window.appCustomMusic || []);
  let combinedCustomBackgrounds = mergeCustomMediaLists(window.currentCustomBackgrounds || [], window.appCustomBackgrounds || []);
  let entry = getMetaEntryById(window.storyManager?.currentId);
  return {
    format: "perchance-ai-story-v1",
    title: (entry?.title || "").toString(),
    storyOverview: storyOverviewEl.value.trim(),
    storySoFar: storySoFarEl.value.trim(),
    whatHappensNext: whatHappensNextEl.value.trim(),
    paragraphLimit: getParagraphLimitFromSelect(),
    backgroundVisual: window.currentBackgroundVisual || "",
    backgroundMusic: window.currentBackgroundMusic || "",
    customBackgrounds: combinedCustomBackgrounds,
    customMusic: combinedCustomMusic,
    hideDefaultBackgrounds: !!window.hideDefaultBackgrounds,
    hideDefaultMusic: !!window.hideDefaultMusic,
    musicRepeatMode: normalizeMusicRepeatMode(window.musicRepeatMode),
    themeSettingsByScheme: normalizeThemeSettingsByScheme(getEffectiveThemeSettingsByScheme(), {allowNull:false}),
    notebook: normalizeNotebookData(window.currentStoryNotebookData),
    appNotebook: normalizeNotebookData(window.appNotebookData),
    sharedIntroMessage: window.currentSharedIntroMessage || "",
    // responseStyle: responseStyleEl.value,
    storyWritingStyleResponseInput: storyWritingStyleResponseInputEl.value,
    storyWritingStyleCustomInput: storyWritingStyleCustomInputEl.value,
    currentTrackedInfo: currentTrackedInfoEl.value,
    infoTrackingEnabled: infoTrackingBtn.dataset.enabled,
    gameMode: storyGameModeSelectEl.value,
    storyDashesEnabled: storyDashesCheckbox.checked,    
    storyBibleAuto_PlayerInfo: localStorage.storyBibleAutoCheckbox_PlayerInfo,
    storyBibleAuto_OtherCharacters: localStorage.storyBibleAutoCheckbox_OtherCharacters,
    storyBibleAuto_Locations: localStorage.storyBibleAutoCheckbox_Locations,
    storyBibleAuto_EventsPlot: localStorage.storyBibleAutoCheckbox_EventsPlot,
    storyBibleAuto_LoreHistory: localStorage.storyBibleAutoCheckbox_LoreHistory,
    storyBibleAuto_PlotThreads: localStorage.storyBibleAutoCheckbox_PlotThreads,
    storyDiceEnabled: storyDiceCheckbox.checked,
    doNotSendStoryInputEnabled: toggleSendStoryInputCheckbox.checked,
    toggleSendStoryInput: toggleSendStoryInputCheckbox.checked,
    storyPerspective: storyPerspectiveSelectEl.value,
    difficultyMode: difficultyModeEl.value,
    storyWritingStyle: storyWritingStyleSelectEl.value,
    storyWritingLength: storyWritingLengthEl.value,
    storyGenreSelect: storyGenreSelectEl.value,
    storySubGenreSelect: storySubGenreSelectEl.value,
    emDashesComfirmation: localStorage.emDashesComfirmation,
    storyArcInstruction: storyArcInstructionEl.value,
    shortcutButtons: JSON.parse(localStorage.shortcutButtons || "[]"),
  };

saveStoryDataToUsersDevice() => 
  let data = getCurrentStoryData();
  let filename = prompt("Choose a filename:", window.lastSaveFilenameUsed || "my-story");
  if(filename === null) return;
  window.lastSaveFilenameUsed = filename;
  filename += ".ai-story.json";
  let blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  downloadBlob(blob, filename);
  
downloadBlob(blob, filename) =>
  let url = URL.createObjectURL(blob);
  let a = document.createElement('a');
  a.href = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);
  
async ensureCBOR() =>
  if(window.CBOR) return window.CBOR;
  try {
    window.CBOR = await import("https://user.uploads.dev/file/4cc84b2c503aad595e5c6e9fffe24602.js").then(r => r.default);
  } catch(e) {
    console.error(e);
  }
  return window.CBOR;

async ensureZipJs() =>
  if(window.zipJs) return window.zipJs;
  window.zipJs = await import('https://esm.sh/@zip.js/zip.js@2.7.60');
  return window.zipJs;

async getAllStoriesBundle() =>
  ensureStoryManager();
  await saveCurrentStoryToKvNow();
  await flushAllStorySaves();
  let meta = (window.storyManager.meta || []).map(m => ({...m}));
  let stories = {};
  for(let entry of meta) {
    let data = await kv.stories.get(entry.id);
    stories[entry.id] = normalizeStoryData(data);
  }
  return {
    format: "perchance-ai-stories-bundle-v1",
    exportedAt: Date.now(),
    activeStoryId: window.storyManager.currentId,
    storiesMeta: meta,
    folderMeta: (window.storyManager.folderMeta || []).map(f => ({...f})),
    stories,
  };

openExportModal() =>
  if(typeof exportModalEl === "undefined") return;
  exportModalEl.hidden = false;
  setExportPasswordVisibility(!!exportEncryptCheckboxEl.checked);
  if(typeof exportTempUrlInputEl !== "undefined") exportTempUrlInputEl.value = "";
  if(typeof exportFormSection !== "undefined") exportFormSection.hidden = false;
  if(typeof exportResultSection !== "undefined") exportResultSection.hidden = true;
  if(typeof exportRunBtn !== "undefined") { exportRunBtn.disabled = false; exportRunBtn.textContent = "💾 export"; }
  
closeExportModal() =>
  if(typeof exportModalEl === "undefined") return;
  exportModalEl.hidden = true;
  setExportPasswordVisibility(false);
  if(typeof exportFormSection !== "undefined") exportFormSection.hidden = false;
  if(typeof exportResultSection !== "undefined") exportResultSection.hidden = true;
  if(typeof exportRunBtn !== "undefined") { exportRunBtn.disabled = false; exportRunBtn.textContent = "💾 export"; }

setExportPasswordVisibility(show) =>
  if(typeof exportEncryptPasswordEl === "undefined" || typeof exportEncryptPasswordConfirmEl === "undefined") return;
  exportEncryptPasswordEl.hidden = !show;
  exportEncryptPasswordConfirmEl.hidden = !show;
  exportEncryptPasswordEl.type = show ? "password" : "text";
  exportEncryptPasswordConfirmEl.type = show ? "password" : "text";

async runExportFromModal() =>
  if(typeof exportRunBtn !== "undefined") {
    exportRunBtn.disabled = true;
    exportRunBtn.textContent = "⏳ exporting...";
  }
  let format = exportFormatSelectEl.value || "native";
  let delivery = (typeof exportDeliverySelectEl !== "undefined" ? exportDeliverySelectEl.value : "download") || "download";
  let encrypt = !!exportEncryptCheckboxEl.checked;
  let password = exportEncryptPasswordEl.value || "";
  let confirmPassword = exportEncryptPasswordConfirmEl.value || "";
  if(encrypt && password !== confirmPassword) {
    alert("Passwords do not match.");
    if(typeof exportRunBtn !== "undefined") { exportRunBtn.disabled = false; exportRunBtn.textContent = "💾 export"; }
    return;
  }
  try {
    let result = await exportAllStories({format, encrypt, password});
    if(!result || !result.blob) {
      if(typeof exportRunBtn !== "undefined") { exportRunBtn.disabled = false; exportRunBtn.textContent = "💾 export"; }
      return;
    }
    if(delivery === "temp") {
      if(typeof exportFormSection !== "undefined") exportFormSection.hidden = true;
      if(typeof exportResultSection !== "undefined") exportResultSection.hidden = false;
      if(typeof exportTempUrlInputEl !== "undefined") exportTempUrlInputEl.value = "Uploading...";
      let { url, error } = await upload(result.blob, {expires:Date.now()+1000*60*60*24*3});
      if(error) {
        alert(`Error: ${error}`);
        if(typeof exportFormSection !== "undefined") exportFormSection.hidden = false;
        if(typeof exportResultSection !== "undefined") exportResultSection.hidden = true;
        if(typeof exportRunBtn !== "undefined") { exportRunBtn.disabled = false; exportRunBtn.textContent = "💾 export"; }
        return;
      }
      if(typeof exportTempUrlInputEl !== "undefined") exportTempUrlInputEl.value = url || "";
    } else {
      downloadBlob(result.blob, result.filename);
      closeExportModal();
    }
    localStorage.lastExportTime = Date.now();
    localStorage.lastExportGenerateCount = Number(localStorage.generateCount || 0);
    renderStoriesFooterNotices();
    if(delivery !== "temp" && typeof exportRunBtn !== "undefined") { exportRunBtn.disabled = false; exportRunBtn.textContent = "💾 export"; }
  } catch(e) {
    console.error(e);
    alert("Export failed.");
    if(typeof exportRunBtn !== "undefined") { exportRunBtn.disabled = false; exportRunBtn.textContent = "💾 export"; }
  }

async copyExportTempUrl() =>
  if(typeof exportTempUrlInputEl === "undefined" || typeof exportTempUrlCopyBtn === "undefined") return;
  let text = exportTempUrlInputEl.value || "";
  if(!text.trim()) return;
  try {
    await navigator.clipboard.writeText(text);
    let original = exportTempUrlCopyBtn.textContent;
    exportTempUrlCopyBtn.textContent = "✅";
    setTimeout(() => { exportTempUrlCopyBtn.textContent = original; }, 2000);
  } catch(e) {
    console.error(e);
    alert("Failed to copy.");
  }

async copyShareLink() =>
  if(typeof shareStoryLinkInputEl === "undefined" || typeof shareLinkCopyBtn === "undefined") return;
  let text = shareStoryLinkInputEl.value || "";
  if(!text.trim()) return;
  try {
    await navigator.clipboard.writeText(text);
    let original = shareLinkCopyBtn.textContent;
    shareLinkCopyBtn.textContent = "✅";
    setTimeout(() => { shareLinkCopyBtn.textContent = original; }, 2000);
  } catch(e) {
    console.error(e);
    alert("Failed to copy.");
  }

async exportAllStories(opts) =>
  if(!opts) opts = {};
  let bundle = await getAllStoriesBundle();
  let filenameBase = `perchance-stories-${new Date().toISOString().slice(0,10)}`;
  let blob;
  if(opts.format === "folders") {
    let zip = await ensureZipJs();
    let writer = new zip.ZipWriter(new zip.BlobWriter("application/zip"));
    let usedFolderNames = new Set();
    for(let entry of bundle.storiesMeta) {
      let data = bundle.stories[entry.id];
      let folderPath = normalizeFolderPath(entry.folderPath || "");
      let safeSegments = folderPath ? folderPath.split("/").map(s => s.replace(/[\\/:*?"<>|]/g, "_")) : [];
      let safeTitle = (entry.title || "Untitled story").replace(/[\\/:*?"<>|]/g, "_").slice(0, 80) || "Untitled story";
      let baseFolder = `${safeTitle} (${entry.id})`;
      let storyFolder = [...safeSegments, baseFolder].join("/");
      if(usedFolderNames.has(storyFolder)) storyFolder += "-" + Math.random().toString(36).slice(2,6);
      usedFolderNames.add(storyFolder);
      let storyWithoutSummaries = (data.storySoFar || "").split(/\n{2,}/).map(p => p.trim()).filter(p => !p.startsWith("SUMMARY^")).join("\n\n");
      let metaJson = {
        meta: entry,
        storyData: data,
      };
      await writer.add(`${storyFolder}/overview.txt`, new zip.TextReader(data.storyOverview || ""));
      await writer.add(`${storyFolder}/story.txt`, new zip.TextReader(data.storySoFar || ""));
      await writer.add(`${storyFolder}/story_without_summaries.txt`, new zip.TextReader(storyWithoutSummaries));
      await writer.add(`${storyFolder}/meta.json`, new zip.TextReader(JSON.stringify(metaJson, null, 2)));
    }
    blob = await writer.close();
    filenameBase += ".stories.zip";
  } else {
    let CBOR = await ensureCBOR();
    if(!CBOR) { alert("CBOR library failed to load."); return; }
    let cborBytes = CBOR.encode(bundle);
    let cborBlob = new Blob([cborBytes], { type: 'application/cbor' });
    let compressedCborBlob = await new Response(cborBlob.stream().pipeThrough(new CompressionStream('gzip'))).blob();
    blob = new Blob([compressedCborBlob], { type: "application/gzip" });
    filenameBase += ".cbor.gz";
  }
  
  if(opts.encrypt) {
    if(!opts.password) {
      alert("Please enter an encryption password.");
      return;
    }
    let zip = await ensureZipJs();
    let writer = new zip.ZipWriter(new zip.BlobWriter("application/zip"), { password: opts.password });
    await writer.add(filenameBase, new zip.BlobReader(blob));
    let encryptedBlob = await writer.close();
    blob = encryptedBlob;
    filenameBase = filenameBase.replace(/\.[^.]+$/, "") + ".encrypted.zip";
  }
  return { blob, filename: filenameBase };

openImportModal() =>
  if(typeof importModalEl === "undefined") return;
  importModalEl.hidden = false;
  if(typeof importUrlInputEl !== "undefined") importUrlInputEl.value = "";
  if(typeof importDropZone !== "undefined") importDropZone.classList.remove("dragOver");

closeImportModal() =>
  if(typeof importModalEl === "undefined") return;
  importModalEl.hidden = true;

async importStoriesFromUser() =>
  openImportModal();

triggerImportFilePicker() =>
  let input = document.createElement('input');
  input.type = 'file';
  input.accept = '.zip,.cbor,.gz,.json,application/zip,application/gzip,application/cbor,application/octet-stream,text/plain,application/json';
  input.onchange = async (event) => {
    let file = event.target.files[0];
    if(file) {
      try {
        await importStoriesFromBlob(file);
        closeImportModal();
      } catch(e) {
        console.error(e);
        alert(`Import failed: ${e?.message || e}`);
      }
    }
  };
  input.click();

async importStoriesFromUrl() =>
  if(typeof importUrlInputEl === "undefined") return;
  let raw = (importUrlInputEl.value || "").trim();
  if(!raw) { alert("Please paste a URL."); return; }
  let fileUrl = raw;
  if(fileUrl.includes("#data=")) fileUrl = fileUrl.split("#data=")[1];
  if(/^uup1(:|%3A)/.test(fileUrl)) {
    fileUrl = fileUrl.replace(/^uup1(:|%3A)/, "https://user.uploads.dev/file/");
  }
  try {
    let fetchOptions = {};
    if(window.AbortSignal && AbortSignal.timeout) fetchOptions.signal = AbortSignal.timeout(15000);
    let res = await fetch(fileUrl, fetchOptions);
    if(!res.ok) {
      alert(`Failed to load that URL (status ${res.status}).`);
      return;
    }
    let blob = await res.blob();
    await importStoriesFromBlob(blob);
    closeImportModal();
  } catch(e) {
    console.error(e);
    alert(`Import failed: ${e?.message || e}`);
  }

async importStoriesFromBlob(blob, opts) =>
  if(!opts) opts={};
  if(blob.name?.toLowerCase().endsWith(".json") || blob.type === "application/json" || blob.type === "text/json" || blob.type === "text/plain") {
    try {
      let text = await blob.text();
      let data = JSON.parse(text);
      if(data && data.format === "perchance-ai-story-v1") {
        let title = extractAndStripTitleFromImportedStoryData(data, "Imported story");
        return createNewStory({title, data:normalizeStoryData(data)});
        if (codeDebug) console.log("reqeusted fromblob? story")
      }
      if(data && data.format === "perchance-ai-stories-bundle-v1") {
        let bundles = Object.keys(data.stories || {}).map(id => ({meta: (data.storiesMeta || []).find(m => m.id == id) || {}, storyData: data.stories[id]}));
        if(Array.isArray(data.folderMeta)) {
          mergeFolderMeta(data.folderMeta);
        }
        return importStoryBundles(bundles);
      }
      if(data && data.storyData) {
        return importStoryBundles([{meta: data.meta || {}, storyData: data.storyData}]);
      }
    } catch(e) {
      console.error(e);
    }
  }
  if(blob.name?.toLowerCase().endsWith(".zip") || blob.type === "application/zip") {
    let zip = await ensureZipJs();
    let entries = null;
    try {
      let reader = new zip.ZipReader(new zip.BlobReader(blob));
      entries = await reader.getEntries();
      let needsPassword = entries.some(e => e.encrypted);
      await reader.close();
      if(needsPassword) {
        let password = prompt("This zip is encrypted. Enter password:");
        if(password === null) return;
        reader = new zip.ZipReader(new zip.BlobReader(blob), { password });
        entries = await reader.getEntries();
        await reader.close();
      }
    } catch(e) {
      let password = prompt("This zip may be encrypted. Enter password:");
      if(password === null) return;
      let reader = new zip.ZipReader(new zip.BlobReader(blob), { password });
      entries = await reader.getEntries();
      await reader.close();
    }
    if(entries && entries.length === 1 && entries[0].filename.toLowerCase().endsWith(".zip")) {
      let innerBlob = await entries[0].getData(new zip.BlobWriter());
      return importStoriesFromBlob(innerBlob);
    }
    if(entries) {
      return importStoriesFromZipEntries(entries);
    }
  }
  return importStoriesFromNativeBlob(blob);

async importStoriesFromZipEntries(entries) =>
  let zip = await ensureZipJs();
  let metaEntries = entries.filter(e => e.filename.toLowerCase().endsWith("meta.json"));
  let cborEntry = entries.find(e => /\.cbor(\.gz)?$/i.test(e.filename));
  if(cborEntry) {
    let cborBlob = await cborEntry.getData(new zip.BlobWriter());
    return importStoriesFromNativeBlob(cborBlob);
  }
  if(metaEntries.length > 0) {
    let storyBundles = [];
    for(let metaEntry of metaEntries) {
      let metaBlob = await metaEntry.getData(new zip.BlobWriter());
      let metaText = await metaBlob.text();
      let parsed = JSON.parse(metaText);
      let storyData = parsed.storyData || parsed;
      storyBundles.push({meta: parsed.meta || {}, storyData});
    }
    return importStoryBundles(storyBundles);
  }
  alert("No recognizable story data found in that zip.");

async importStoriesFromNativeBlob(blob) =>
  let CBOR = await ensureCBOR();
  if(!CBOR) { alert("CBOR library failed to load."); return; }
  let bytes = new Uint8Array(await blob.arrayBuffer());
  let isGzip = blob.name?.toLowerCase().endsWith(".gz") || blob.type === "application/gzip";
  if(bytes.length >= 2 && bytes[0] === 0x1f && bytes[1] === 0x8b) isGzip = true;
  if(isGzip) {
    const ds = new DecompressionStream("gzip");
    const decompressedStream = new Blob([bytes]).stream().pipeThrough(ds);
    bytes = new Uint8Array(await new Response(decompressedStream).arrayBuffer());
  }
  let data = CBOR.decode(bytes);
  if(data && data.format === "perchance-ai-stories-bundle-v1") {
    let bundles = Object.keys(data.stories || {}).map(id => ({meta: (data.storiesMeta || []).find(m => m.id == id) || {}, storyData: data.stories[id]}));
    if(Array.isArray(data.folderMeta)) {
      mergeFolderMeta(data.folderMeta);
    }
    return importStoryBundles(bundles);
  }
  if(data && data.format === "perchance-ai-story-v1") {
    let title = extractAndStripTitleFromImportedStoryData(data, "Imported story");
    return createNewStory({title, data:normalizeStoryData(data)});
    if (codeDebug) console.log("reqeusted nativeblob? story")
  }
  alert("Unknown import format.");

mergeFolderMeta(folderMeta) =>
  ensureStoryManager();
  let existing = window.storyManager.folderMeta || [];
  let map = new Map(existing.map(f => [normalizeFolderPath(f.path || ""), f]));
  for(let f of folderMeta) {
    let path = normalizeFolderPath(f.path || "");
    if(!path) continue;
    map.set(path, {path, emoji: f.emoji || ""});
  }
  window.storyManager.folderMeta = [...map.values()];
  requestFolderMetaSaveDebounced({debounceMs:200});

async importStoryBundles(bundles) =>
  ensureStoryManager();
  if(!Array.isArray(bundles) || bundles.length === 0) return;
  let confirmed = await confirmAsync(`This will import ${bundles.length} story${bundles.length===1?"":"ies"} into your stories list. Continue?`);
  if(!confirmed) return;
  bundles.sort((a, b) => a.meta?.lastEditTime - b.meta?.lastEditTime);
  for(let b of bundles) {
    let data = normalizeStoryData(b.storyData || {});
    let title = (b.meta?.title || "Imported story");
    let folderPath = normalizeFolderPath(b.meta?.folderPath || "");
    let pinned = !!b.meta?.pinned;
    await createNewStory({title, data, folderPath, pinned});
    if (codeDebug) console.log("reqeusted importbundle story")
  }
  renderStoriesList();

async deleteAllStoriesData() =>
  let answer = prompt("Type \"yes\" to delete all stories and data:");
  if(answer !== "yes") return;
  await new Promise(r => setTimeout(r, 1000));
  if(!window.confirm("🚨 Final confirmation: Delete ALL stories and local data?")) return;
  window.isDeletingAllData = true;
  try {
    if(window.storyManager) {
      window.storyManager.isReady = false;
      window.storyManager.isLoading = true;
      clearTimeout(window.storyManager.saveDebounceTimeout);
      clearTimeout(window.storyManager.metaSaveDebounceTimeout);
      clearTimeout(window.storyManager.folderMetaSaveDebounceTimeout);
      clearTimeout(window.storyManager.appMediaSaveDebounceTimeout);
      clearTimeout(window.storyManager.appNotebookSaveDebounceTimeout);
      window.storyManager.meta = [];
      window.storyManager.folderMeta = [];
    }
  } catch(e) { console.error(e); }
  try {
    await kv.stories.clear();
  } catch(e) { console.error(e); }
  try {
    await kv.storiesMeta.clear();
  } catch(e) { console.error(e); }
  try {
    await kv.autoBackups.clear();
  } catch(e) { console.error(e); }
  try { localStorage.clear(); } catch(e) { console.error(e); }
  location.reload();

async getStoryStats() =>
  if(!window.storyManager?.meta) {
    console.log("Story manager not ready.");
    return;
  }

  let meta = window.storyManager.meta;
  let totalStories = meta.length;
  let totalChars = 0;

  for (let entry of meta) {
    let data = await kv.stories.get(entry.id);
    if (!data) continue;

    let str = JSON.stringify(data);
    totalChars += str.length;
  }

  let totalKB = (totalChars / 1024).toFixed(2);
  let totalMB = (totalChars / (1024 * 1024)).toFixed(2);

  console.log("Stories:", totalStories);
  console.log("Total characters:", totalChars);
  console.log("Total size:", totalKB + " KB (" + totalMB + " MB)");

  return {
    stories: totalStories,
    characters: totalChars,
    kb: totalKB,
    mb: totalMB
  };

//////////////////////////////////////////////////////
// Background + music + theme customization helpers //
//////////////////////////////////////////////////////

getCombinedMusicTracks() =>
  let list = (window.currentCustomMusic || []).slice(0).concat(window.appCustomMusic || []);
  if(!window.hideDefaultMusic) list = list.concat(defaultMusicTracks);
  return list;

getCombinedBackgroundVisuals() =>
  let list = (window.currentCustomBackgrounds || []).slice(0).concat(window.appCustomBackgrounds || []);
  if(!window.hideDefaultBackgrounds) list = list.concat(defaultBackgroundVisuals);
  return list;

renderMediaSelectOptions() =>
  if(typeof backgroundMusicSelectEl === "undefined" || typeof backgroundVisualSelectEl === "undefined") return;
  let musicOptions = getCombinedMusicTracks();
  let bgOptions = getCombinedBackgroundVisuals();
  backgroundMusicSelectEl.innerHTML = `<option value="">🚫 None</option>` + musicOptions.map(t => `<option value="${escapeHtml(t.url)}">${escapeHtml((t.emoji||"🎵") + " " + (t.title || t.url))}</option>`).join("");
  backgroundVisualSelectEl.innerHTML = `<option value="">🚫 None</option>` + bgOptions.map(t => `<option value="${escapeHtml(t.url)}">${escapeHtml((t.emoji||"🖼️") + " " + (t.title || t.url))}</option>`).join("");
  backgroundMusicSelectEl.value = window.currentBackgroundMusic || "";
  backgroundVisualSelectEl.value = window.currentBackgroundVisual || "";
  if(backgroundMusicSelectEl.value !== (window.currentBackgroundMusic || "")) {
    window.currentBackgroundMusic = backgroundMusicSelectEl.value || "";
    updateMusicPlayback(false);
  }
  if(backgroundVisualSelectEl.value !== (window.currentBackgroundVisual || "")) {
    window.currentBackgroundVisual = backgroundVisualSelectEl.value || "";
    updateBackgroundVisual(false);
  }
  if(typeof hideDefaultMusicCheckboxEl !== "undefined") hideDefaultMusicCheckboxEl.checked = !!window.hideDefaultMusic;
  if(typeof hideDefaultBackgroundsCheckboxEl !== "undefined") hideDefaultBackgroundsCheckboxEl.checked = !!window.hideDefaultBackgrounds;

applyMediaSettingsFromStoryData(data) =>
  data = normalizeStoryData(data);
  window.currentCustomMusic = normalizeCustomMediaList(data.customMusic);
  window.currentCustomBackgrounds = normalizeCustomMediaList(data.customBackgrounds);
  window.hideDefaultMusic = !!data.hideDefaultMusic;
  window.hideDefaultBackgrounds = !!data.hideDefaultBackgrounds;
  window.currentBackgroundMusic = data.backgroundMusic || "";
  window.currentBackgroundVisual = data.backgroundVisual || "";
  window.musicRepeatMode = normalizeMusicRepeatMode(data.musicRepeatMode);
  renderMediaSelectOptions();
  updateBackgroundVisual(false);
  updateMusicPlayback(false);

applyThemeSettingsFromStoryData(data) =>
  if (codeDebug) console.log("applyThemeSettingsFromStoryData");
  data = normalizeStoryData(data);
  window.currentStoryThemeSettingsByScheme = normalizeThemeSettingsByScheme(data.themeSettingsByScheme, {allowNull:true});
  if(window.currentStoryThemeSettingsByScheme) {
    for(let scheme of ["light","dark"]) {
      let entry = window.currentStoryThemeSettingsByScheme[scheme];
      if(entry?.storyFontFamily) entry.storyFontFamily = parseFontFamilyInput(entry.storyFontFamily);
    }
  }
  applyThemeSettings();

applyNotebookSettingsFromStoryData(data) =>
  data = normalizeStoryData(data);
  window.currentStoryNotebookData = normalizeNotebookData(data.notebook);
  if(typeof updateNotepadForCurrentStory === "function") updateNotepadForCurrentStory();

getNotebookScope() =>
  const allowedScopes = ["app", "bible", "story"];
  return allowedScopes.includes(window.notepadScope) ? window.notepadScope : "story";

getNotebookDataForScope(scope) =>
  if (codeDebug) console.log("getNotebookDataForScope")
  const allowedScopes = ["app", "bible", "story"];
  scope = (allowedScopes.includes(scope)) ? scope : "story";
  let data = (scope === "app") ? window.appNotebookData : window.currentStoryNotebookData;
  // if (codeDebug) console.log("notebook data:");
  // if (codeDebug) console.log(data);
  return normalizeNotebookData(data);

setNotebookDataForScope(scope, data) =>
  scope = (scope === "app") ? "app" : "story";
  let normalized = normalizeNotebookData(data);
  if(scope === "app") window.appNotebookData = normalized;
  else window.currentStoryNotebookData = normalized;
  return normalized;

ensureNotepadEditor() =>
  if(window.notepadEditorEl) return window.notepadEditorEl;
  if(typeof notepadEditorCtn === "undefined") return null;
  window.notepadEditorEl = createTextEditor({
    textStyleRules: getStoryTextStyleRules(),
  });
  notepadEditorEl.id = "notepadEditorEl";
  notepadEditorEl.class = "text";
  notepadEditorEl.placeholder = "A place to add notes that won't affect the story.";
  notepadEditorEl.style.cssText = "width:100%; height:100%; min-height:0; max-height:none; display:block; resize:none;";
  notepadEditorCtn.innerHTML = "";
  notepadEditorCtn.appendChild(notepadEditorEl);
  notepadEditorEl.addEventListener("input", function() {
    if(window.notepadLoadingContent) return;
    clearTimeout(window.notepadSaveDebounceTimeout);
    window.notepadSaveDebounceTimeout = setTimeout(() => {
      saveNotepadEditorToActiveTab();
    }, 350);
  });
  return notepadEditorEl;

saveNotepadEditorToActiveTab() =>
  if (codeDebug) console.log("saveNotepadEditorToActiveTab");
  if(!window.notepadEditorEl) return;
  let scope = getNotebookScope();
  let data = getNotebookDataForScope(scope);
  let active = data.tabs.find(t => t.id === data.activeTabId) || data.tabs[0];
  if(active) {
    active.content = window.notepadEditorEl.value || "";
    active.lastEditedTime = Date.now();
  }
  // if (codeDebug) console.log("Scope: " + scope);
  // if (codeDebug) console.log("data:");
  // if (codeDebug) console.log(data);
  // if (codeDebug) console.log("active:");
  // if (codeDebug) console.log(active);
  setNotebookDataForScope(scope, data);
  if(typeof notepadPanel !== "undefined" && !notepadPanel.hidden) renderNotepadTabs({skipLoad:true});
  if(scope === "app") requestAppNotebookSaveDebounced({debounceMs:400});
  else requestSaveCurrentStory({debounceMs:400});

loadNotepadTabContent(tabId) =>
  if (codeDebug) console.log("loadNotepadTabContent: " + tabId);
  let scope = getNotebookScope();
  let data = getNotebookDataForScope(scope);
  let tab = data.tabs.find(t => t.id === tabId) || data.tabs[0];
  if(!tab) return;
  // const isValidTab = sortedTabs.some(tab => tab.id === data.activeTabId);
  data.activeTabId = tab.id;
  setNotebookDataForScope(scope, data);
  ensureNotepadEditor();
  if(window.notepadEditorEl) {
    // if (codeDebug) console.log("Tab title: " + tab.title);
    window.notepadLoadingContent = true;

    const storyBiblePlaceholders = [
      { title: "<Player Info>", placeholder: "Enter player info, stats, inventory, etc."},
      { title: "<Other Characters>", placeholder: "Describe other key characters, their motivations, relationships, etc."},
      { title: "<Locations>", placeholder: "Describe important locations, cities, dungeons, etc."},
      { title: "<Events/Plots>", placeholder: "Summarize key past events or ongoing plot points."},
      { title: "<Lore/History>", placeholder: "Describe the world's lore, factions, history, magic systems, etc."},
      { title: "<Plot Threads>", placeholder: "Keep track of unresolved mysteries, plot threads, foreshadowing, etc."},
    ];
    const match = storyBiblePlaceholders.find(item => item.title === tab.title);
    // if (codeDebug) console.log("Title Match:");
    // if (codeDebug) console.log(match);
    if (match) { notepadEditorEl.placeholder = match.placeholder;} else {notepadEditorEl.placeholder = "A place to add notes that won't affect the story.";};
    window.notepadEditorEl.value = tab.content || "";
    storyBibleCheckboxKey = 'storyBibleAutoCheckbox_' + notepadTabsSelectEl.selectedOptions[0].text.replace(/[<>\s\/]/g,'');
    if (codeDebug) console.log("loadNotepadTabContent : storyBibleCheckboxKey : " + storyBibleCheckboxKey);
    storyBibleAutoUpdateCheckBox.checked = localStorage[storyBibleCheckboxKey] || "";
    storyBibleRegenBtn.hidden = (window.notepadEditorEl.value.trim() === "");
    storyBibleDeleteBtn.hidden = (window.notepadEditorEl.value.trim() === "");
    storyBibleGenerateBtn.hidden = (window.notepadEditorEl.value.trim() !== "");
    window.notepadLoadingContent = false;
  }

renderNotepadTabs(opts) =>
  if (codeDebug) console.log("renderNotepadTabs");
  if(!opts) opts = {};
  if(typeof notepadTabsSelectEl === "undefined") return;
  let scope = getNotebookScope();
  let data = setNotebookDataForScope(scope, getNotebookDataForScope(scope));

  const order = [
    "<Player Info>",
    "<Other Characters>",
    "<Locations>",
    "<Events/Plot>",
    "<Lore/History>",
    "<Plot Threads>"
  ];
  const orderMap = Object.fromEntries(order.map((v, i) => [v, i]));
  let sortedTabs = (data.tabs || []).filter(tab => scope === "bible" ? tab.title?.startsWith("<") : !tab.title?.startsWith("<")).slice(0).sort((a,b) =>scope === "bible" ? (orderMap[a.title] ?? Infinity) - (orderMap[b.title] ?? Infinity) : (b.lastEditedTime || 0) - (a.lastEditedTime || 0));
  let options = (scope === "bible") ? [] : [`<option value="__add__">➕ 𝗡𝗲𝘄 𝗽𝗮𝗴𝗲</option>`];
  options = options.concat(sortedTabs.map(t => `<option value="${escapeHtml(t.id)}">${escapeHtml(t.title || "Page")}</option>`));
  notepadTabsSelectEl.innerHTML = options.join("");
  const isValidTab = sortedTabs.some(tab => tab.id === data.activeTabId);
  // if (codeDebug) console.log("isValidTab: " + isValidTab);
  notepadTabsSelectEl.value = isValidTab ? data.activeTabId : (sortedTabs[0]?.id || "");
  if(!opts.skipLoad) loadNotepadTabContent(isValidTab ? data.activeTabId : (sortedTabs[0]?.id || ""));

setActiveNotepadTab(tabId) =>
  if (codeDebug) console.log("setActiveNotepadTab");
  let scope = getNotebookScope();
  let data = getNotebookDataForScope(scope);
  // if (codeDebug) console.log(window.notepadEditorEl.value.trim());
  if(window.notepadEditorEl && !window.notepadLoadingContent) {
    let active = data.tabs.find(t => t.id === data.activeTabId) || data.tabs[0];
    if(active) active.content = window.notepadEditorEl.value || "";
  }
  let nextTab = data.tabs.find(t => t.id === tabId);
  if(!nextTab) return;
  data.activeTabId = nextTab.id;
  setNotebookDataForScope(scope, data);
  
  if(typeof notepadTabsSelectEl !== "undefined") {
    notepadTabsSelectEl.value = nextTab.id;
  }
  storyBibleCheckboxKey = 'storyBibleAutoCheckbox_' + notepadTabsSelectEl.selectedOptions[0].text.replace(/[<>\s\/]/g,'');
  if (codeDebug) console.log("setActiveNotepadTab : storyBibleCheckboxKey : " + storyBibleCheckboxKey);
  storyBibleAutoUpdateCheckBox.value = localStorage[storyBibleCheckboxKey] || "";
  loadNotepadTabContent(nextTab.id);
  if(scope === "app") requestAppNotebookSaveDebounced({debounceMs:400});
  else requestSaveCurrentStory({debounceMs:400});

setActiveNotepadTabByName(tabName) =>
  if (codeDebug) console.log("setActiveNotepadTabByName");
  let scope = getNotebookScope();
  let data = getNotebookDataForScope(scope);
  // if (codeDebug) console.log("Notebook Data");
  // if (codeDebug) console.log(data);
  if(window.notepadEditorEl && !window.notepadLoadingContent) {
    let active = data.tabs.find(t => t.id === data.activeTabId) || data.tabs[0];
    if(active) active.content = window.notepadEditorEl.value || "";
  }
  let nextTab = data.tabs.find(t => t.title === tabName);
  if(!nextTab) return false;
  data.activeTabId = nextTab.id;
  setNotebookDataForScope(scope, data);
  if(typeof notepadTabsSelectEl !== "undefined") {
    notepadTabsSelectEl.value = nextTab.id;
  }
  loadNotepadTabContent(nextTab.id);
  if(scope === "app") requestAppNotebookSaveDebounced({debounceMs:400});
  else requestSaveCurrentStory({debounceMs:400});
  return true;

onNotepadTabsSelectChange(value) =>
  if(value === "__add__") {
    addNotepadTab();
    return;
  }
  setActiveNotepadTab(value);

openNotepadPanel() =>
  if(typeof notepadPanel === "undefined") return;
  notepadPanel.hidden = false;
  requestAnimationFrame(() => {
    document.body.classList.add("notepadOpen");
    updateNotepadOverlayMode();
  });
  if(typeof notepadScopeSelectEl !== "undefined") {
    const allowedScopes = ["app", "bible", "story"];
    window.notepadScope = allowedScopes.includes(notepadScopeSelectEl.value) ? notepadScopeSelectEl.value : "story";
    notepadScopeSelectEl.value = window.notepadScope;
  }
  ensureNotepadEditor();
  renderNotepadTabs();
  setupNotepadResizer();

toggleNotepadPanel() =>
  if(document.body.classList.contains("notepadOpen")) closeNotepadPanel();
  else openNotepadPanel();

openNotepadForStory() =>
  if(typeof notepadScopeSelectEl !== "undefined") notepadScopeSelectEl.value = "story";
  window.notepadScope = "story";
  openNotepadPanel();
  closeStoryToolsMenu();

closeNotepadPanel() =>
  if(typeof notepadPanel === "undefined") return;
  saveNotepadEditorToActiveTab();
  document.body.classList.remove("notepadOpen");
  document.body.classList.remove("notepadOverlayMode");
  if(typeof notepadTabMenu !== "undefined") notepadTabMenu.hidden = true;
  if(typeof notepadOverlay !== "undefined") notepadOverlay.hidden = true;
  setTimeout(() => {
    if(!document.body.classList.contains("notepadOpen")) notepadPanel.hidden = true;
  }, 160);

setNotepadScope(scope) =>
  saveNotepadEditorToActiveTab();
  const allowedScopes = ["app", "bible", "story"];
  window.notepadScope = allowedScopes.includes(scope) ? scope : "story";
  if(typeof notepadScopeSelectEl !== "undefined") notepadScopeSelectEl.value = window.notepadScope;
  const scopeSelect = document.getElementById("notepadScopeSelectEl");
  const menuBtn = document.getElementById("notepadTabsMenuBtn");
  if(scope === "bible") {
    if (codeDebug) console.log("Found bible")
    window.notepadTabsMenuBtn.hidden = true;
    window.notepadBibleCtn.hidden = false;
  } else {
    window.notepadTabsMenuBtn.hidden = false;
    window.notepadBibleCtn.hidden = true;
  }
  renderNotepadTabs();

addNotepadTab(name) =>
  saveNotepadEditorToActiveTab();
  let scope = getNotebookScope();
  let data = getNotebookDataForScope(scope);
  let id = `tab_${Date.now()}_${Math.random().toString(36).slice(2,6)}`;
  let title = name || `Page ${data.tabs.length + 1}`;
  data.tabs.push({id, title, content:"", lastEditedTime:Date.now()});
  data.activeTabId = id;
  setNotebookDataForScope(scope, data);
  renderNotepadTabs();
  if(scope === "app") requestAppNotebookSaveDebounced({debounceMs:400});
  else requestSaveCurrentStory({debounceMs:400});

renameActiveNotepadTab() =>
  if (codeDebug) console.log("renameActiveNotepadTab");
  saveNotepadEditorToActiveTab();
  let scope = getNotebookScope();
  let data = getNotebookDataForScope(scope);
  let active = data.tabs.find(t => t.id === data.activeTabId) || data.tabs[0];
  if(!active) return;
  let name = prompt("Rename tab: (Cannot start with '<' )", active.title || "");
  if(typeof notepadTabMenu !== "undefined") notepadTabMenu.hidden = true;
  if (codeDebug) console.log("Name: " + name);
  if(name === null) return;
  if(name.startsWith("<")) {
    alert("Renaming failed!\nThe name cannot start with <");
    return;
  }
  name = name.trim();
  if (codeDebug) console.log("Name.trim: " + name);
  if(!name) return;
  active.title = name;
  if (codeDebug) console.log(name);
  setNotebookDataForScope(scope, data);
  renderNotepadTabs();
  if(scope === "app") requestAppNotebookSaveDebounced({debounceMs:400});
  else requestSaveCurrentStory({debounceMs:400});

deleteActiveNotepadTab() =>
  saveNotepadEditorToActiveTab();
  let scope = getNotebookScope();
  let data = getNotebookDataForScope(scope);
  let active = data.tabs.find(t => t.id === data.activeTabId) || data.tabs[0];
  if(!active) return;
  if(!confirm("Delete this tab?")) return;
  data.tabs = data.tabs.filter(t => t.id !== active.id);
  if(typeof notepadTabMenu !== "undefined") notepadTabMenu.hidden = true;
  if(data.tabs.length <= 6) {
    let id = `tab_${Date.now()}_${Math.random().toString(36).slice(2,6)}`;
    data.tabs = [{id, title:"Page 1", content:"", lastEditedTime:Date.now()}];
    data.activeTabId = id;
  } else {
    data.activeTabId = data.tabs[0].id;
  }
  setNotebookDataForScope(scope, data);
  renderNotepadTabs();
  if(scope === "app") requestAppNotebookSaveDebounced({debounceMs:400});
  else requestSaveCurrentStory({debounceMs:400});

toggleNotepadTabMenu() =>
  if(typeof notepadTabMenu === "undefined") return;
  notepadTabMenu.hidden = !notepadTabMenu.hidden;

updateNotepadForCurrentStory() =>
  if(typeof notepadScopeSelectEl !== "undefined") {
    notepadScopeSelectEl.value = getNotebookScope();
  }
  if(typeof notepadPanel !== "undefined" && !notepadPanel.hidden) {
    renderNotepadTabs();
  }

updateNotepadOverlayMode() =>
  let overlayMode = window.innerWidth < 650;
  window.notepadOverlayMode = overlayMode;
  document.body.classList.toggle("notepadOverlayMode", overlayMode);
  if(typeof notepadOverlay !== "undefined") {
    let isOpen = document.body.classList.contains("notepadOpen");
    notepadOverlay.hidden = !overlayMode || !isOpen;
  }

setupNotepadResizer() =>
  if(window.notepadResizerSetup) return;
  if(typeof notepadResizeHandle === "undefined" || typeof notepadPanel === "undefined") return;
  window.notepadResizerSetup = true;
  notepadResizeHandle.addEventListener("pointerdown", e => {
    e.preventDefault();
    let startX = e.clientX;
    let startWidth = notepadPanel.getBoundingClientRect().width;
    notepadResizeHandle.setPointerCapture(e.pointerId);
    function onMove(ev) {
      let delta = startX - ev.clientX;
      let nextWidth = Math.max(310, startWidth + delta);
      nextWidth = Math.min(nextWidth, Math.max(310, window.innerWidth - 160));
      document.documentElement.style.setProperty("--notepad-width", `${Math.round(nextWidth)}px`);
    }
    function onUp(ev) {
      notepadResizeHandle.releasePointerCapture(ev.pointerId);
      window.removeEventListener("pointermove", onMove);
      window.removeEventListener("pointerup", onUp);
      let width = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--notepad-width")) || notepadPanel.getBoundingClientRect().width;
      localStorage.notepadWidth = Math.round(width);
    }
    window.addEventListener("pointermove", onMove);
    window.addEventListener("pointerup", onUp);
  });

onMusicSelectChange(userInitiated) =>
  window.currentBackgroundMusic = backgroundMusicSelectEl.value || "";
  requestSaveCurrentStory({debounceMs:300});
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  updateMusicPlayback(!!userInitiated);

onBackgroundSelectChange(userInitiated) =>
  window.currentBackgroundVisual = backgroundVisualSelectEl.value || "";
  requestSaveCurrentStory({debounceMs:300});
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  updateBackgroundVisual(!!userInitiated);

toggleHideDefaultMusic(val) =>
  window.hideDefaultMusic = !!val;
  requestSaveCurrentStory({debounceMs:300});
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  renderMediaSelectOptions();

toggleHideDefaultBackgrounds(val) =>
  window.hideDefaultBackgrounds = !!val;
  requestSaveCurrentStory({debounceMs:300});
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  renderMediaSelectOptions();

openMediaModal(section) =>
  if(section === "music") openMusicModal();
  else if(section === "background") openBackgroundModal();

openMusicModal() =>
  if(typeof musicModalEl === "undefined") return;
  musicModalEl.style.zIndex = "9999999";
  musicModalEl.hidden = false;
  renderMediaSelectOptions();
  renderCustomMediaLists();

closeMusicModal() =>
  if(typeof musicModalEl === "undefined") return;
  musicModalEl.hidden = true;

openBackgroundModal() =>
  if(typeof backgroundModalEl === "undefined") return;
  backgroundModalEl.style.zIndex = "9999999";
  backgroundModalEl.hidden = false;
  renderMediaSelectOptions();
  renderCustomMediaLists();

closeBackgroundModal() =>
  if(typeof backgroundModalEl === "undefined") return;
  backgroundModalEl.hidden = true;

closeMediaModal() =>
  if(typeof musicModalEl !== "undefined") musicModalEl.hidden = true;
  if(typeof backgroundModalEl !== "undefined") backgroundModalEl.hidden = true;

renderCustomMediaLists() =>
  if(typeof customMusicListEl !== "undefined") {
    let storyMusic = window.currentCustomMusic || [];
    let appMusic = window.appCustomMusic || [];
    let rows = [];
    rows = rows.concat(storyMusic.map((t,i) => ({...t, scope:"story", index:i})));
    rows = rows.concat(appMusic.map((t,i) => ({...t, scope:"app", index:i})));
    if(typeof customMusicListSection !== "undefined") customMusicListSection.hidden = rows.length === 0;
    customMusicListEl.innerHTML = rows.map(t => `
      <div class="mediaListRow" data-scope="${t.scope}" data-index="${t.index}">
        <input class="mediaEmojiEdit" value="${escapeHtml(t.emoji || "🎵")}" title="Emoji">
        <input class="mediaTitleEdit" value="${escapeHtml(t.title || t.url)}" title="${escapeHtml(t.url || "")}">
        <select class="mediaScopeSelect">
          <option value="story" ${t.scope === "story" ? "selected" : ""}>this story</option>
          <option value="app" ${t.scope === "app" ? "selected" : ""}>all stories</option>
        </select>
        <button class="mediaRemoveBtn" title="Remove">🗑️</button>
      </div>
    `).join("");
  }
  if(typeof customBackgroundListEl !== "undefined") {
    let storyBackgrounds = window.currentCustomBackgrounds || [];
    let appBackgrounds = window.appCustomBackgrounds || [];
    let rows = [];
    rows = rows.concat(storyBackgrounds.map((t,i) => ({...t, scope:"story", index:i})));
    rows = rows.concat(appBackgrounds.map((t,i) => ({...t, scope:"app", index:i})));
    if(typeof customBackgroundListSection !== "undefined") customBackgroundListSection.hidden = rows.length === 0;
    customBackgroundListEl.innerHTML = rows.map(t => `
      <div class="mediaListRow" data-scope="${t.scope}" data-index="${t.index}">
        <input class="mediaEmojiEdit" value="${escapeHtml(t.emoji || "🖼️")}" title="Emoji">
        <input class="mediaTitleEdit" value="${escapeHtml(t.title || t.url)}" title="${escapeHtml(t.url || "")}">
        <select class="mediaScopeSelect">
          <option value="story" ${t.scope === "story" ? "selected" : ""}>this story</option>
          <option value="app" ${t.scope === "app" ? "selected" : ""}>all stories</option>
        </select>
        <button class="mediaRemoveBtn" title="Remove">🗑️</button>
      </div>
    `).join("");
  }
  let hasCustomMusic = (window.currentCustomMusic || []).length > 0 || (window.appCustomMusic || []).length > 0;
  let hasCustomBackgrounds = (window.currentCustomBackgrounds || []).length > 0 || (window.appCustomBackgrounds || []).length > 0;
  if(typeof hideDefaultMusicRow !== "undefined") hideDefaultMusicRow.hidden = !hasCustomMusic;
  if(typeof hideDefaultBackgroundsRow !== "undefined") hideDefaultBackgroundsRow.hidden = !hasCustomBackgrounds;

updateCustomMediaField(scope, listType, index, field, value) =>
  let list = (scope === "app")
    ? (listType === "music" ? (window.appCustomMusic || []) : (window.appCustomBackgrounds || []))
    : (listType === "music" ? (window.currentCustomMusic || []) : (window.currentCustomBackgrounds || []));
  if(!list[index]) return;
  list[index][field] = value;
  if(scope === "app") requestAppMediaSaveDebounced({debounceMs:300});
  else requestSaveCurrentStory({debounceMs:300});
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  renderMediaSelectOptions();

moveCustomMediaScope(listType, fromScope, index, toScope) =>
  if(fromScope === toScope) return;
  let fromList = (fromScope === "app")
    ? (listType === "music" ? (window.appCustomMusic || []) : (window.appCustomBackgrounds || []))
    : (listType === "music" ? (window.currentCustomMusic || []) : (window.currentCustomBackgrounds || []));
  let toList = (toScope === "app")
    ? (listType === "music" ? (window.appCustomMusic || []) : (window.appCustomBackgrounds || []))
    : (listType === "music" ? (window.currentCustomMusic || []) : (window.currentCustomBackgrounds || []));
  let item = fromList[index];
  if(!item) return;
  fromList.splice(index, 1);
  toList.push(item);
  requestSaveCurrentStory({debounceMs:300});
  requestAppMediaSaveDebounced({debounceMs:300});
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  renderMediaSelectOptions();
  renderCustomMediaLists();

uploadCustomMediaFile(opts) =>
  if(!opts) return;
  let {accept, urlInputEl, buttonEl} = opts;
  if(!urlInputEl || !buttonEl) return;
  let input = document.createElement("input");
  input.type = "file";
  if(accept) input.accept = accept;
  input.onchange = async (event) => {
    let file = event.target.files[0];
    if(!file) return;
    let originalText = buttonEl.textContent;
    let originalPlaceholder = urlInputEl.placeholder;
    buttonEl.textContent = "⏳";
    buttonEl.disabled = true;
    urlInputEl.placeholder = "uploading...";
    try {
      let { url, error } = await upload(file);
      if(error) throw new Error(error);
      urlInputEl.value = url;
    } catch(e) {
      alert(`Upload failed: ${e.message || e}`);
    } finally {
      buttonEl.textContent = originalText;
      buttonEl.disabled = false;
      urlInputEl.placeholder = originalPlaceholder;
    }
  };
  input.click();

uploadCustomMusicFile() =>
  uploadCustomMediaFile({
    accept: "audio/*",
    urlInputEl: newMusicUrlEl,
    buttonEl: uploadMusicBtn,
  });

uploadCustomBackgroundFile() =>
  uploadCustomMediaFile({
    accept: "image/*,video/*,.gif,.webm,.mp4,.mov",
    urlInputEl: newBackgroundUrlEl,
    buttonEl: uploadBackgroundBtn,
  });

addCustomMusic() =>
  let url = (newMusicUrlEl.value || "").trim();
  let title = (newMusicTitleEl.value || "").trim();
  if(!url || !title) {
    alert("Please add a title and URL.");
    return;
  }
  let emoji = "🎵";
  window.appCustomMusic = window.appCustomMusic || [];
  window.appCustomMusic.push({url, title, emoji});
  newMusicUrlEl.value = "";
  newMusicTitleEl.value = "";
  requestAppMediaSaveDebounced({debounceMs:300});
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  renderMediaSelectOptions();
  renderCustomMediaLists();

removeCustomMusic(i, scope) =>
  if(!confirm("Remove this custom music?")) return;
  if(scope === "app") {
    window.appCustomMusic.splice(i,1);
    requestAppMediaSaveDebounced({debounceMs:300});
  } else {
    window.currentCustomMusic.splice(i,1);
    requestSaveCurrentStory({debounceMs:300});
  }
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  renderMediaSelectOptions();
  renderCustomMediaLists();

addCustomBackground() =>
  let url = (newBackgroundUrlEl.value || "").trim();
  let title = (newBackgroundTitleEl.value || "").trim();
  if(!url || !title) {
    alert("Please add a title and URL.");
    return;
  }
  let emoji = "🖼️";
  window.appCustomBackgrounds = window.appCustomBackgrounds || [];
  window.appCustomBackgrounds.push({url, title, emoji});
  newBackgroundUrlEl.value = "";
  newBackgroundTitleEl.value = "";
  requestAppMediaSaveDebounced({debounceMs:300});
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  renderMediaSelectOptions();
  renderCustomMediaLists();

removeCustomBackground(i, scope) =>
  if(!confirm("Remove this custom background?")) return;
  if(scope === "app") {
    window.appCustomBackgrounds.splice(i,1);
    requestAppMediaSaveDebounced({debounceMs:300});
  } else {
    window.currentCustomBackgrounds.splice(i,1);
    requestSaveCurrentStory({debounceMs:300});
  }
  try { if(typeof storyDataChangedHandler === "function") storyDataChangedHandler(); } catch(e) {}
  renderMediaSelectOptions();
  renderCustomMediaLists();

async updateBackgroundVisual(userInitiated) =>
  if(typeof backgroundImageCtn === "undefined") return;
  let url = (window.currentBackgroundVisual || "").trim();
  if(url) {
    let isVideo = /\.(mp4|webm|mkv|mov)$/i.test(url.split("?")[0]);
    let sameMedia = (window.lastBackgroundVisualUrl === url && !!window.lastBackgroundIsVideo === !!isVideo);
    if(isVideo) {
      backgroundImageCtn.style.backgroundImage = "";
      backgroundVideoEl.hidden = false;
      if(!sameMedia) {
        backgroundVideoEl.src = url;
        backgroundVideoEl.currentTime = 0;
      }
      try { backgroundVideoEl.play().catch(() => {}); } catch(e) {}
      userActivationPromise.then(() => backgroundVideoEl.play().catch(console.error));
    } else {
      if(!sameMedia) {
        backgroundImageCtn.style.backgroundImage = `url(${url})`;
        backgroundImageCtn.style.imageRendering = url.endsWith(".gif") ? "pixelated" : "";
      }
      backgroundVideoEl.hidden = true;
      backgroundVideoEl.src = "";
      backgroundVideoEl.pause();
    }
    document.body.classList.add("backgroundImageIsActive");
    let editorVisible = (typeof storyGenerationAreaEl !== "undefined" && !storyGenerationAreaEl.hidden);
    if(editorVisible) {
      topStuffEl.hidden = true;
      toggleOverviewVisibilityEl.hidden = false;
      storyOverviewEl.hidden = true;
      storyOverviewPaddingEl.hidden = false;
    } else {
      topStuffEl.hidden = false;
      toggleOverviewVisibilityEl.hidden = true;
      storyOverviewEl.hidden = false;
      storyOverviewPaddingEl.hidden = true;
    }
    window.lastBackgroundVisualUrl = url;
    window.lastBackgroundIsVideo = isVideo;
  } else {
    backgroundImageCtn.style.backgroundImage = "";
    backgroundVideoEl.hidden = true;
    backgroundVideoEl.src = "";
    backgroundVideoEl.pause();
    document.body.classList.remove("backgroundImageIsActive");
    topStuffEl.hidden = false;
    storyOverviewEl.hidden = false;    
    storyOverviewPaddingEl.hidden = true;
    window.lastBackgroundVisualUrl = "";
    window.lastBackgroundIsVideo = false;
  }
  updateOverviewToggleText();

applyMusicRepeatMode() =>
  musicRepeatMode = normalizeMusicRepeatMode(musicRepeatMode);
  if(typeof backgroundAudioPlayerEl !== "undefined") {
    backgroundAudioPlayerEl.loop = (musicRepeatMode === "repeat");
  }
  if(typeof musicRepeatBtn !== "undefined") {
    musicRepeatBtn.textContent = (musicRepeatMode === "repeat") ? "🔁" : "➡️";
  }

updateMusicPlayback(userInitiated) =>
  if(typeof backgroundAudioPlayerEl === "undefined") return;
  let wasPlaying = !backgroundAudioPlayerEl.paused;
  let url = (window.currentBackgroundMusic || "").trim();
  let shouldAutoPlay = !!window.musicAutoPlayNext || (!!userInitiated && !!url);
  window.musicAutoPlayNext = false;
  applyMusicRepeatMode();
  backgroundAudioPlayerEl.autoplay = false;
  backgroundAudioPlayerEl.onended = () => {
    if(musicRepeatMode === "next") {
      window.musicAutoPlayNext = true;
      playNextTrack();
    }
    else if(musicRepeatMode === "repeat") backgroundAudioPlayerEl.currentTime = 0;
  };
  backgroundAudioPlayerEl.onplay = updatePageMusicToggleBtn;
  backgroundAudioPlayerEl.onpause = updatePageMusicToggleBtn;
  backgroundAudioPlayerEl.volume = 0.6;
  if(!url) {
    backgroundAudioPlayerEl.pause();
    backgroundAudioPlayerEl.removeAttribute("src");
    backgroundAudioPlayerEl.hidden = true;
    updatePageMusicToggleBtn();
    return;
  }
  backgroundAudioPlayerEl.hidden = false;
  if(backgroundAudioPlayerEl.src !== url) {
    backgroundAudioPlayerEl.src = url;
    backgroundAudioPlayerEl.currentTime = 0;
  }
  if(shouldAutoPlay) {
    backgroundAudioPlayerEl.play().catch(console.error);
  } else {
    backgroundAudioPlayerEl.pause();
  }
  updatePageMusicToggleBtn();

updatePageMusicToggleBtn() =>
  if(typeof pageMusicToggleBtn === "undefined" || typeof backgroundAudioPlayerEl === "undefined") return;
  let hasSong = !!(window.currentBackgroundMusic || "").trim();
  pageMusicToggleBtn.hidden = !hasSong;
  if(!hasSong) return;
  pageMusicToggleBtn.textContent = backgroundAudioPlayerEl.paused ? "🎵" : "⏸️";

togglePageMusicPlayback() =>
  if(typeof backgroundAudioPlayerEl === "undefined") return;
  if(backgroundAudioPlayerEl.paused) {
    backgroundAudioPlayerEl.play().then(updatePageMusicToggleBtn).catch(console.error);
  } else {
    backgroundAudioPlayerEl.pause();
    updatePageMusicToggleBtn();
  }

playNextTrack() =>
  let list = getCombinedMusicTracks().map(t => t.url).filter(Boolean);
  if(list.length === 0) return;
  let current = window.currentBackgroundMusic || "";
  let idx = list.indexOf(current);
  let next = list[(idx + 1) % list.length];
  if(typeof backgroundAudioPlayerEl !== "undefined" && !backgroundAudioPlayerEl.paused) {
    window.musicAutoPlayNext = true;
  }
  backgroundMusicSelectEl.value = next;
  onMusicSelectChange(true);

playPreviousTrack() =>
  let list = getCombinedMusicTracks().map(t => t.url).filter(Boolean);
  if(list.length === 0) return;
  let current = window.currentBackgroundMusic || "";
  let idx = list.indexOf(current);
  let prev = list[(idx - 1 + list.length) % list.length];
  if(typeof backgroundAudioPlayerEl !== "undefined" && !backgroundAudioPlayerEl.paused) {
    window.musicAutoPlayNext = true;
  }
  backgroundMusicSelectEl.value = prev;
  onMusicSelectChange(true);

toggleMusicRepeatMode() =>
  musicRepeatMode = (musicRepeatMode === "repeat") ? "next" : "repeat";
  applyMusicRepeatMode();
  requestSaveCurrentStory({debounceMs:300});
  updateMusicPlayback(false);

openThemeModal() =>
  if(typeof themeModalEl === "undefined") return;
  ensureThemeSchemeListeners();
  if(typeof themeSchemeSelectEl !== "undefined") themeSchemeSelectEl.value = getActiveColorScheme();
  loadThemeSettingsIntoModal();
  window.themeModalSnapshot = getThemeModalSnapshot();
  if(typeof themeAdvancedSection !== "undefined" && !themeAdvancedSection.hidden) {
    ensureThemeAdvancedReady();
  }
  themeModalEl.hidden = false;

closeThemeModal(opts) =>
  if(typeof themeModalEl === "undefined") return;
  if(!opts || !opts.skipConfirm) {
    if(hasThemeModalUnsavedChanges()) {
      if(!confirm("Discard theme changes?")) return;
    }
  }
  try { if(typeof fontHelpTooltip !== "undefined") fontHelpTooltip.hidden = true; } catch(e) {}
  themeModalEl.hidden = true;

openStorySettingsModal() =>
  if(typeof storySettingsModalEl === "undefined") return;
  ensureThemeSchemeListeners();
  if(typeof themeSchemeSelectEl !== "undefined") themeSchemeSelectEl.value = getActiveColorScheme();
  loadThemeSettingsIntoModal();
  window.themeModalSnapshot = getThemeModalSnapshot();
  if(typeof themeAdvancedSection !== "undefined" && !themeAdvancedSection.hidden) {
    ensureThemeAdvancedReady();
  }
  storySettingsModalEl.hidden = false;

closeStorySettingsModal(opts) =>
  if(typeof storySettingsModalEl === "undefined") return;
  if(!opts || !opts.skipConfirm) {
    if(hasThemeModalUnsavedChanges()) {
      if(!confirm("Discard theme changes?")) return;
    }
  }
  try { if(typeof fontHelpTooltip !== "undefined") fontHelpTooltip.hidden = true; } catch(e) {}
  storySettingsModalEl.hidden = true;

normalizeColorScheme(scheme) =>
  return (scheme === "dark") ? "dark" : "light";

getActiveColorScheme() =>
  let scheme = document.documentElement.style.colorScheme;
  if(scheme !== "dark" && scheme !== "light") {
    scheme = (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? "dark" : "light";
  }
  return normalizeColorScheme(scheme);

setManualColorScheme(scheme) =>
  scheme = normalizeColorScheme(scheme);
  localStorage.forceColorScheme = scheme;
  setColorScheme(scheme);
  let systemColorScheme = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? "dark" : "light";
  if(systemColorScheme === scheme) {
    localStorage.removeItem("forceColorScheme");
  }

loadAppThemeSettingsByScheme() =>
  if (codeDebug) console.log("loadAppThemeSettingsByScheme");
  let raw = localStorage.themeSettingsByScheme || "";
  let settings = getThemeDefaultsByScheme();
  if(raw) {
    try { settings = normalizeThemeSettingsByScheme(JSON.parse(raw), {allowNull:false}); } catch(e) { console.error(e); }
  }
  for(let scheme of ["light","dark"]) {
    let entry = settings[scheme];
    if(entry?.storyFontFamily) entry.storyFontFamily = parseFontFamilyInput(entry.storyFontFamily);
  }
  window.themeSettingsByScheme = settings;
  return settings;

getEffectiveThemeSettingsByScheme() =>
  if(window.currentStoryThemeSettingsByScheme) {
    let storySettings = normalizeThemeSettingsByScheme(window.currentStoryThemeSettingsByScheme, {allowNull:false});
    return storySettings;
  }
  return loadAppThemeSettingsByScheme();

getEffectiveThemeSettings(scheme) =>
  scheme = normalizeColorScheme(scheme || getActiveColorScheme());
  let settingsByScheme = getEffectiveThemeSettingsByScheme();
  return settingsByScheme[scheme] || {...getThemeDefaults()};

saveThemeSettingsByScheme() =>
  localStorage.themeSettingsByScheme = JSON.stringify(window.themeSettingsByScheme || getThemeDefaultsByScheme());

parseFontFamilyInput(raw) =>
  if (codeDebug) console.log("parseFontFamilyInput");
  let val = (raw || "").toString().trim();
  if(!val) return "";
  return val.replace(/^https?:\/\//i, "");

extractFontNameFromInput(raw) =>
  let val = (raw || "").toString().trim();
  if(!val) return "";
  val = val.replace(/^https?:\/\//i, "");
  let specimenMatch = val.match(/fonts\.google\.com\/specimen\/([^?#/]+)/i);
  if(specimenMatch && specimenMatch[1]) {
    let name = specimenMatch[1].replace(/\+/g, " ");
    try { name = decodeURIComponent(name); } catch(e) {}
    return name.trim();
  }
  let familyMatch = val.match(/[?&]family=([^&#]+)/i);
  if(familyMatch && familyMatch[1]) {
    let name = familyMatch[1].split(":")[0].replace(/\+/g, " ");
    try { name = decodeURIComponent(name); } catch(e) {}
    return name.trim();
  }
  return val;

getThemeModalScheme() =>
  if(typeof themeSchemeSelectEl !== "undefined") {
    let val = themeSchemeSelectEl.value;
    if(val === "dark" || val === "light") return val;
  }
  return getActiveColorScheme();

ensureThemeSchemeListeners() =>
  if(codeDebug) { console.log("ensureThemeSchemeListeners"); }
  if(window.themeSchemeListenersReady) return;
  window.themeSchemeListenersReady = true;
  if(typeof themeSchemeSelectEl === "undefined") return;
  themeSchemeSelectEl.addEventListener("change", () => {
    let newScheme = normalizeColorScheme(themeSchemeSelectEl.value);
    let currentScheme = getActiveColorScheme();
    if(newScheme === currentScheme) return;
    if(hasThemeModalUnsavedChanges()) {
      if(!confirm("Discard theme changes?")) {
        themeSchemeSelectEl.value = currentScheme;
        return;
      }
    }
    setManualColorScheme(newScheme);
    loadThemeSettingsIntoModal();
    window.themeModalSnapshot = getThemeModalSnapshot();
  });

getThemeModalDefaultColors() =>
  let scheme = getThemeModalScheme();
  let defaultText = (scheme === "light") ? "#000000" : "#bebebe";
  let defaultStoryBg = (scheme === "light") ? "#fafafa" : "#000000";
  let defaultUserBg = (scheme === "light") ? "#fafafa" : "#00000000";
  let defaultPageBg = (scheme === "light") ? "#131516" : "fafafa";
  
  return {scheme, defaultText, defaultStoryBg, defaultUserBg, defaultPageBg};

updateThemeAutoDefaultsInModal() =>
  if(typeof themeTextColorEl === "undefined") return;
  let {defaultText, defaultStoryBg, defaultUserBg, defaultPageBg} = getThemeModalDefaultColors();
  if(typeof themeTextAutoEl !== "undefined" && themeTextAutoEl.checked) {
    themeTextColorEl.value = defaultText;
  }
  if(typeof themeBackgroundAutoEl !== "undefined" && themeBackgroundAutoEl.checked) {
    themeBackgroundColorEl.value = defaultStoryBg;
  }
  if(typeof themeUserBgAutoEl !== "undefined" && themeUserBgAutoEl.checked) {
    themeUserBgColorEl.value = defaultUserBg;
  }
  if(typeof themeUserTextAutoEl !== "undefined" && themeUserTextAutoEl.checked) {
    themeUserTextColorEl.value = defaultText;
  }
  if(typeof themeAsteriskAutoEl !== "undefined" && themeAsteriskAutoEl.checked) {
    themeAsteriskColorEl.value = defaultText;
  }
  if(typeof themeQuoteAutoEl !== "undefined" && themeQuoteAutoEl.checked) {
    themeQuoteColorEl.value = defaultText;
  }

ensureThemeAutoListeners() =>
  if(window.themeAutoListenersReady) return;
  window.themeAutoListenersReady = true;
  if(typeof themeTextColorEl !== "undefined") {
    themeTextColorEl.addEventListener("input", () => {
      if(typeof themeTextAutoEl !== "undefined") themeTextAutoEl.checked = false;
    });
  }
  if(typeof themeBackgroundColorEl !== "undefined") {
    themeBackgroundColorEl.addEventListener("input", () => {
      if(typeof themeBackgroundAutoEl !== "undefined") themeBackgroundAutoEl.checked = false;
    });
  }
  if(typeof themeUserBgColorEl !== "undefined") {
    themeUserBgColorEl.addEventListener("input", () => {
      if(typeof themeUserBgAutoEl !== "undefined") themeUserBgAutoEl.checked = false;
    });
  }
  if(typeof themeUserTextColorEl !== "undefined") {
    themeUserTextColorEl.addEventListener("input", () => {
      if(typeof themeUserTextAutoEl !== "undefined") themeUserTextAutoEl.checked = false;
    });
  }
  if(typeof themeAsteriskColorEl !== "undefined") {
    themeAsteriskColorEl.addEventListener("input", () => {
      if(typeof themeAsteriskAutoEl !== "undefined") themeAsteriskAutoEl.checked = false;
    });
  }
  if(typeof themeQuoteColorEl !== "undefined") {
    themeQuoteColorEl.addEventListener("input", () => {
      if(typeof themeQuoteAutoEl !== "undefined") themeQuoteAutoEl.checked = false;
    });
  }
  if(typeof themeTextAutoEl !== "undefined") {
    themeTextAutoEl.addEventListener("change", () => {
      if(themeTextAutoEl.checked) updateThemeAutoDefaultsInModal();
    });
  }
  if(typeof themeBackgroundAutoEl !== "undefined") {
    themeBackgroundAutoEl.addEventListener("change", () => {
      if(themeBackgroundAutoEl.checked) updateThemeAutoDefaultsInModal();
    });
  }
  if(typeof themeUserBgAutoEl !== "undefined") {
    themeUserBgAutoEl.addEventListener("change", () => {
      if(themeUserBgAutoEl.checked) updateThemeAutoDefaultsInModal();
    });
  }
  if(typeof themeUserTextAutoEl !== "undefined") {
    themeUserTextAutoEl.addEventListener("change", () => {
      if(themeUserTextAutoEl.checked) updateThemeAutoDefaultsInModal();
    });
  }
  if(typeof themeAsteriskAutoEl !== "undefined") {
    themeAsteriskAutoEl.addEventListener("change", () => {
      if(themeAsteriskAutoEl.checked) updateThemeAutoDefaultsInModal();
    });
  }
  if(typeof themeQuoteAutoEl !== "undefined") {
    themeQuoteAutoEl.addEventListener("change", () => {
      if(themeQuoteAutoEl.checked) updateThemeAutoDefaultsInModal();
    });
  }
  if(window.onForcedColorSchemeChangeHandlers) {
    window.onForcedColorSchemeChangeHandlers.add(() => updateThemeAutoDefaultsInModal());
  }

getThemeModalSnapshot() =>
  if (codeDebug) console.log("getThemeModalSnapshot");
  if(typeof themeTextColorEl === "undefined") return "";
  return JSON.stringify({
    storyTextColor: themeTextColorEl.value || "",
    storyBackgroundColor: themeBackgroundColorEl.value || "",
    storyTextAuto: (typeof themeTextAutoEl !== "undefined" ? !!themeTextAutoEl.checked : false),
    pageBackgroundAtuo: (typeof pageBackgroundAutoEl !== "undefined" ? !!pageBackgroundAutoEl.checked :false),
    storyBackgroundAuto: (typeof themeBackgroundAutoEl !== "undefined" ? !!themeBackgroundAutoEl.checked : false),
    storyFontFamily: parseFontFamilyInput(themeFontFamilyEl.value || ""),
    userBackgroundColor: themeUserBgColorEl.value || "",
    userBackgroundAuto: (typeof themeUserBgAutoEl !== "undefined" ? !!themeUserBgAutoEl.checked : false),
    userTextColor: themeUserTextColorEl.value || "",
    userTextAuto: (typeof themeUserTextAutoEl !== "undefined" ? !!themeUserTextAutoEl.checked : false),
    userItalic: !!themeUserIsItalicEl.checked,
    userBold: !!themeUserIsBoldEl.checked,
    asteriskColor: themeAsteriskColorEl.value || "",
    asteriskAuto: (typeof themeAsteriskAutoEl !== "undefined" ? !!themeAsteriskAutoEl.checked : false),
    asteriskItalic: !!themeAsteriskIsItalicEl.checked,
    asteriskBold: !!themeAsteriskIsBoldEl.checked,
    quoteColor: themeQuoteColorEl.value || "",
    quoteAuto: (typeof themeQuoteAutoEl !== "undefined" ? !!themeQuoteAutoEl.checked : false),
    quoteItalic: !!themeQuoteIsItalicEl.checked,
    quoteBold: !!themeQuoteIsBoldEl.checked,
    scope: (typeof themeScopeSelectEl !== "undefined" ? themeScopeSelectEl.value : "app"),
    advancedVisible: (typeof themeAdvancedSection !== "undefined" ? !themeAdvancedSection.hidden : false),
    advancedRules: collectThemeAdvancedRulesFromModal(),
  });

hasThemeModalUnsavedChanges() =>
  let snap = window.themeModalSnapshot || "";
  let now = getThemeModalSnapshot();
  return snap && now && snap !== now;

renderThemeAdvancedRules(rules) =>
  if(typeof themeAdvancedRulesCtn === "undefined") return;
  if(!Array.isArray(rules)) rules = [];
  let ready = !!window.themeAdvancedReady;
  let patternPlaceholder = ready ? "Text or /regex/flags" : "Loading...";
  let cssPlaceholder = ready ? "e.g. color:#d33; font-weight:bold;" : "Loading...";
  let disabledAttr = ready ? "" : "disabled";
  let aiButtonText = ready ? "🧠" : "⏳";
  let rows = rules.map(r => ({pattern: (r?.pattern || "").toString(), css: (r?.css || "").toString()}));
  rows.push({pattern:"", css:""});
  themeAdvancedRulesCtn.innerHTML = rows.map((r, i) => `
    <div class="themeAdvancedRow" data-index="${i}">
      <textarea class="themePatternInput" rows="1" placeholder="${patternPlaceholder}" ${disabledAttr}>${escapeHtml(r.pattern)}</textarea>
      <input class="themeCssInput" placeholder="${cssPlaceholder}" value="${escapeHtml(r.css)}" ${disabledAttr}>
      <button class="themeRuleAiBtn" title="Describe rule" ${disabledAttr}>${aiButtonText}</button>
    </div>
  `).join("");
  ensureThemeAdvancedRowCount();

collectThemeAdvancedRulesFromModal() =>
  if(typeof themeAdvancedRulesCtn === "undefined") return [];
  let rows = [...themeAdvancedRulesCtn.querySelectorAll(".themeAdvancedRow")];
  let rules = [];
  for(let row of rows) {
    let pattern = row.querySelector(".themePatternInput")?.value?.trim() || "";
    let css = row.querySelector(".themeCssInput")?.value?.trim() || "";
    if(pattern && css) rules.push({pattern, css});
  }
  return rules;

ensureThemeAdvancedRowCount() =>
  if(typeof themeAdvancedRulesCtn === "undefined") return;
  let rows = [...themeAdvancedRulesCtn.querySelectorAll(".themeAdvancedRow")];
  if(rows.length === 0) {
    renderThemeAdvancedRules([]);
    return;
  }
  let last = rows[rows.length-1];
  let lastPattern = last.querySelector(".themePatternInput")?.value?.trim() || "";
  let lastCss = last.querySelector(".themeCssInput")?.value?.trim() || "";
  if(lastPattern && lastCss) {
    renderThemeAdvancedRules(collectThemeAdvancedRulesFromModal());
  }

toggleThemeAdvancedSection() =>
  if(typeof themeAdvancedSection === "undefined") return;
  themeAdvancedSection.hidden = !themeAdvancedSection.hidden;
  window.themeAdvancedVisible = !themeAdvancedSection.hidden;
  if(!themeAdvancedSection.hidden) ensureThemeAdvancedReady();
  if(typeof themeAdvancedToggleBtn !== "undefined") themeAdvancedToggleBtn.textContent = themeAdvancedSection.hidden ? "⚙️ advanced" : "🙈 advanced";

buildThemeAdvancedTextRules(rules) =>
  let output = [];
  if(!Array.isArray(rules)) return output;
  for(let r of rules) {
    let pattern = (r?.pattern || "").toString().trim();
    let css = (r?.css || "").toString().trim();
    if(!pattern || !css) continue;
    let regex = null;
    if(/^\/.+\/[gimsuy]*$/.test(pattern)) {
      let lastSlash = pattern.lastIndexOf("/");
      let body = pattern.slice(1, lastSlash);
      let flags = pattern.slice(lastSlash+1) || "g";
      if(!flags.includes("g")) flags += "g";
      try { regex = new RegExp(body, flags); } catch(e) { regex = null; }
    } else {
      let escaped = pattern.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      try { regex = new RegExp(escaped, "g"); } catch(e) { regex = null; }
    }
    if(!regex) continue;
    output.push({match: regex, style: css});
  }
  return output;

ensureThemeAdvancedReady() =>
  if(window.themeAdvancedReady) return;
  if(window.themeAdvancedReadyPromise) return;
  window.themeAdvancedReadyPromise = (async () => {
    try { await ai({preload:true}); } catch(e) { console.error(e); }
    window.themeAdvancedReady = true;
    window.themeAdvancedReadyPromise = null;
    renderThemeAdvancedRules(collectThemeAdvancedRulesFromModal());
  })();

async generateThemeRuleWithAi(rowEl, btnEl) =>
  if(!rowEl) return;
  let originalBtnText = btnEl?.textContent;
  if(btnEl) { btnEl.textContent = "⏳"; btnEl.disabled = true; }
  let description = prompt("Describe the rule you want, e.g. \"make the word Alice appear bold\".");
  if(!description) { if(btnEl) { btnEl.textContent = originalBtnText || "⏳"; btnEl.disabled = false; } return; }
  try {
    let result = await ai({
      instruction: [
        "Convert the user's description into a JSON object with keys:",
        `"pattern": a literal text or a /regex/flags string (include 'g' flag),`,
        `"css": CSS text styling rules like "color:#d33; font-weight:bold;"`,
        "Return ONLY JSON with those two keys and no extra text.",
        "",
        `User description: ${description}`,
      ].join("\n"),
      stopSequences: ["\n\n"],
    });
    if(result.stopReason === "error") {
      alert("Failed to generate rule.");
      return;
    }
    let text = (result.generatedText || "").trim();
    let jsonText = text.match(/\{[\s\S]*\}/)?.[0] || "";
    if(!jsonText) {
      alert("Could not parse the generated rule.");
      return;
    }
    let parsed = JSON.parse(jsonText);
    let pattern = (parsed.pattern || "").toString().trim();
    let css = (parsed.css || "").toString().trim();
    if(!pattern || !css) {
      alert("Generated rule was incomplete.");
      return;
    }
    rowEl.querySelector(".themePatternInput").value = pattern;
    rowEl.querySelector(".themeCssInput").value = css;
    ensureThemeAdvancedRowCount();
  } catch(e) {
    console.error(e);
    alert("Failed to generate rule.");
  } finally {
    if(btnEl) { btnEl.textContent = originalBtnText || "⏳"; btnEl.disabled = false; }
  }

loadThemeSettingsIntoModal() =>
  if (codeDebug) console.log("loadThemeSettingsIntoModal");
  ensureThemeSchemeListeners();
  let scheme = getThemeModalScheme();
  if(typeof themeSchemeSelectEl !== "undefined") themeSchemeSelectEl.value = scheme;
  let s = getEffectiveThemeSettings(scheme);
  if(typeof themeScopeSelectEl !== "undefined") themeScopeSelectEl.value = "story";
  ensureThemeAutoListeners();
  let {defaultText, defaultStoryBg, defaultUserBg, defaultPageBg} = getThemeModalDefaultColors();
  let defaultQuote = defaultText;
  let pageBgColor = defaultPageBg;
  let textColor = s.storyTextColor || defaultText;
  let bgColor = s.storyBackgroundColor || defaultStoryBg;
  let userBgColor = s.userBackgroundColor || defaultUserBg;
  let userTextColor = s.userTextColor || defaultText;
  let asteriskColor = s.asteriskColor || defaultText;
  let quoteColor = s.quoteColor || defaultQuote;
  let pageBgIsAuto = !s.pageBgColor;
  let textIsAuto = !s.storyTextColor;
  let bgIsAuto = !s.storyBackgroundColor;
  let userBgIsAuto = !s.userBackgroundColor;
  let userTextIsAuto = !s.userTextColor;
  let italicIsAuto = !s.asteriskColor;
  let quoteIsAuto = !s.quoteColor;  
  let asteriskBold = s.asteriskBold;
  if(!/^#([0-9a-f]{3}){1,2}$/i.test(textColor)) { textColor = defaultText; textIsAuto = true; }
  if(!/^#([0-9a-f]{3}){1,2}$/i.test(bgColor)) { bgColor = defaultStoryBg; bgIsAuto = true; }
  if(!/^#([0-9a-f]{3}){1,2}$/i.test(userBgColor)) { userBgColor = defaultUserBg; userBgIsAuto = true; }
  if(!/^#([0-9a-f]{3}){1,2}$/i.test(userTextColor)) { userTextColor = defaultStoryBg; userTextIsAuto = true; }  
  if(!/^#([0-9a-f]{3}){1,2}$/i.test(asteriskColor)) { asteriskColor = defaultText; italicIsAuto = true; }
  if(!/^#([0-9a-f]{3}){1,2}$/i.test(quoteColor)) { quoteColor = defaultQuote; quoteIsAuto = true; }
  if(typeof themeTextAutoEl !== "undefined") themeTextAutoEl.checked = textIsAuto;
  if(typeof themeBackgroundAutoEl !== "undefined") themeBackgroundAutoEl.checked = bgIsAuto;
  if(typeof themeUserBgAutoEl !== "undefined") themeUserBgAutoEl.checked = userBgIsAuto;
  if(typeof themeUserTextAutoEl !== "undefined") themeUserTextAutoEl.checked = userTextIsAuto;
  if(typeof themeAsteriskAutoEl !== "undefined") themeAsteriskAutoEl.checked = italicIsAuto;
  if(typeof themeQuoteAutoEl !== "undefined") themeQuoteAutoEl.checked = quoteIsAuto;
  themeTextColorEl.value = textColor;
  themeBackgroundColorEl.value = bgColor;
  themeFontFamilyEl.value = parseFontFamilyInput(s.storyFontFamily || "");
  themeUserBgColorEl.value = userBgColor;
  themeUserTextColorEl.value = userTextColor;
  themeAsteriskColorEl.value = asteriskColor;
  themeUserIsItalicEl.checked = (s.userItalic !== false);
  themeAsteriskIsItalicEl.checked = (s.asteriskItalic !== false);
  themeQuoteColorEl.value = quoteColor;
  themeQuoteIsItalicEl.checked = !!s.quoteItalic;
  themeQuoteIsBoldEl.checked = !!s.quoteBold;
  
  if(typeof themeAdvancedRulesCtn !== "undefined") renderThemeAdvancedRules(s.advancedRules || []);
  if(typeof themeAdvancedSection !== "undefined") themeAdvancedSection.hidden = !window.themeAdvancedVisible;
  if(typeof themeAdvancedToggleBtn !== "undefined") themeAdvancedToggleBtn.textContent = (themeAdvancedSection?.hidden ? "⚙️ advanced" : "🔙 advanced");

saveThemeSettingsFromModal() =>
  if (codeDebug) console.log("saveThemeSettingsFromModal");
  let scheme = getThemeModalScheme();
  let s = {...getThemeDefaults()};
  let pageBgAuto = (typeof themeBackgroundAutoEl !== "undefined") ? !!themeBackgroundAutoEl.checked : false;
  let textAuto = (typeof themeTextAutoEl !== "undefined") ? !!themeTextAutoEl.checked : false;
  let bgAuto = (typeof themeBackgroundAutoEl !== "undefined") ? !!themeBackgroundAutoEl.checked : false;
  let userBgAuto = (typeof themeUserBgAutoEl !== "undefined") ? !!themeUserBgAutoEl.checked : false;
  let userTextAuto = (typeof themeUserTextAutoEl !== "undefined") ? !!themeUserTextAutoEl.checked : false;
  let asteriskAuto = (typeof themeAsteriskAutoEl !== "undefined") ? !!themeAsteriskAutoEl.checked : false;
  let quoteAuto = (typeof themeQuoteAutoEl !== "undefined") ? !!themeQuoteAutoEl.checked : false;
  // s.pageBackgroundColor = pageBgAuto ? "" : pageBackgroundColorEl.value.trim();
  s.storyTextColor = textAuto ? "" : themeTextColorEl.value.trim();
  s.storyBackgroundColor = bgAuto ? "" : themeBackgroundColorEl.value.trim();
  s.storyFontFamily = parseFontFamilyInput(themeFontFamilyEl.value);
  themeFontFamilyEl.value = s.storyFontFamily || "";
  s.userBackgroundColor = userBgAuto ? "" : themeUserBgColorEl.value.trim();
  s.userTextColor = userTextAuto ? "" : themeUserTextColorEl.value.trim();
  s.userItalic = !!themeUserIsItalicEl.checked;
  s.userBold = !!themeUserIsBoldEl.checked;
  s.asteriskColor = asteriskAuto ? "" : themeAsteriskColorEl.value.trim();
  s.asteriskItalic = !!themeAsteriskIsItalicEl.checked;
  s.asteriskBold = !!themeAsteriskIsBoldEl.checked;
  s.quoteColor = quoteAuto ? "" : themeQuoteColorEl.value.trim();
  s.quoteItalic = !!themeQuoteIsItalicEl.checked;
  s.quoteBold = !!themeQuoteIsBoldEl.checked;
  s.advancedRules = collectThemeAdvancedRulesFromModal();
  if(typeof themeScopeSelectEl !== "undefined" && themeScopeSelectEl.value === "story") {
    let map = window.currentStoryThemeSettingsByScheme || getThemeDefaultsByScheme();
    map = normalizeThemeSettingsByScheme(map, {allowNull:false});
    map[scheme] = s;
    window.currentStoryThemeSettingsByScheme = map;
    requestSaveCurrentStory({debounceMs:300});
  } else {
    window.currentStoryThemeSettingsByScheme = null;
    let map = window.themeSettingsByScheme || loadAppThemeSettingsByScheme();
    map = normalizeThemeSettingsByScheme(map, {allowNull:false});
    map[scheme] = s;
    window.themeSettingsByScheme = map;
    saveThemeSettingsByScheme();
    requestSaveCurrentStory({debounceMs:300});
  }
  applyThemeSettings();
  closeThemeModal({skipConfirm:true});

resetThemeSettingsToDefault() =>
  if(!confirm("Reset theme to default?")) return;
  let scheme = getThemeModalScheme();
  if(typeof themeScopeSelectEl !== "undefined" && themeScopeSelectEl.value === "story") {
    let map = window.currentStoryThemeSettingsByScheme || getThemeDefaultsByScheme();
    map = normalizeThemeSettingsByScheme(map, {allowNull:false});
    map[scheme] = {...getThemeDefaults()};
    window.currentStoryThemeSettingsByScheme = map;
    requestSaveCurrentStory({debounceMs:300});
  } else {
    window.currentStoryThemeSettingsByScheme = null;
    let map = window.themeSettingsByScheme || loadAppThemeSettingsByScheme();
    map = normalizeThemeSettingsByScheme(map, {allowNull:false});
    map[scheme] = {...getThemeDefaults()};
    window.themeSettingsByScheme = map;
    saveThemeSettingsByScheme();
    requestSaveCurrentStory({debounceMs:300});
  }
  applyThemeSettings();
  loadThemeSettingsIntoModal();

ensureGoogleFontLoaded(fontName) =>
  let name = (fontName || "").toString().trim();
  if(!name) return;
  let safeName = extractFontNameFromInput(name).split(",")[0].replace(/["'<>]/g, "").trim();
  if(!safeName) return;
  let id = "googleFont_" + btoa(safeName).replace(/=+/g, "");
  if(document.getElementById(id)) return;
  let family = encodeURIComponent(safeName).replace(/%20/g, "+");
  let link = document.createElement("link");
  link.id = id;
  link.rel = "stylesheet";
  link.href = `https://fonts.googleapis.com/css2?family=${family}&display=swap`;
  document.head.appendChild(link);

getStoryTextStyleRules() =>
  let s = getEffectiveThemeSettings(getActiveColorScheme());
  let userParts = [];
  if(s.userBackgroundColor) userParts.push(`background-color:${s.userBackgroundColor}26; border-left: 4px solid ${s.userBackgroundColor}; padding-left: 8px;`);
  if(s.userTextColor) userParts.push(`color:${s.userTextColor};`);
  if(s.userItalic !== false) userParts.push("font-style:italic;");
  if(s.userBold !== false) userParts.push("font-weight:bold;");
  let userStyle = userParts.join(" ");
  let asteriskParts = [];
  if(s.asteriskColor) asteriskParts.push(`color:${s.asteriskColor};`);
  if(s.asteriskItalic !== false) asteriskParts.push("font-style:italic;");
  if(s.asteriskBold !== false) asteriskParts.push("font-weight:bold;");
  let asteriskStyle = asteriskParts.join(" ");
  let quoteParts = [];
  if(s.quoteColor) quoteParts.push(`color:${s.quoteColor};`);
  else quoteParts.push("color:var(--text-style-rule-quote-color);");
  if(s.quoteItalic !== false) quoteParts.push("font-style:italic;");
  if(s.quoteBold !== false) quoteParts.push("font-weight:bold;");
  let quoteStyle = quoteParts.join(" ");
  let rules = [
    {match: /(\s|^|—)\*\*(.+?)\*\*(?=\s|$|—|\.|,)/g, style: "font-weight:bold;"}, // **Hello World**
    {match: /(?<=[\s(—]|^)\*"(?!\s).*?"\*(?=[\s).—]|$)/g,  style: "color:var(--text-style-rule-asterisk-color); color:light-dark(#303030, #536878); font-style:italic;"}, // *"I can't believe this!"*
    {match: /(?:(?<=\s")|(?<=[\s—]))\*[^ \*"“”][^*"“”]*\*(?![“”])(?=[\s—,."]|$)/g, style: asteriskStyle || "font-style:italic;"}, // *Quoted Text*
    {match: /["“][^"]+?["”]/g,    style: quoteStyle || "color:var(--text-style-rule-quote-color); font-style:italic;"}, // "Hello World"
    {match: /(^|\n)SUMMARY\^[0-9]+: /g, style: "font-weight:bold;"},
    {match: /^>\s?\S+:/g,           style: "font-weight:bold;"}, // : bold
    {match: /^(?!>\s?)[^:]{1,30}?:/g, style: "font-weight:bold;"}, // : bold
    {match: /(^|\n)#+ [^\n]*/g,         style: "font-weight:bold;"}, 
    {match: /(^|\n)>[^\n]*/g,           style: userStyle || "color:light-dark(#7c3e00, #ffc86e); font-style:italic; background-color: #ffcc8026; border-left: 4px solid #FFCC80; padding-left: 8px;"}, // > User Input
    {match: /<[^>\n]+>/g, style: "color:DimGray ;"},
  ];
  let advanced = buildThemeAdvancedTextRules(s.advancedRules || []);
  if(advanced.length) rules = rules.concat(advanced);
  return rules;

applyTextStyleRulesToEditor() =>
  let rules = getStoryTextStyleRules();
  let applyToEditor = (el) => {
    if(!el) return;
    if(el.setTextStyleRules) el.setTextStyleRules(rules);
    else if(el.updateTextStyleRules) el.updateTextStyleRules(rules);
  };
  if(typeof storySoFarEl !== "undefined") applyToEditor(storySoFarEl);
  if(window.notepadEditorEl) applyToEditor(notepadEditorEl);

applyThemeSettings() =>
  if (codeDebug) console.log("applyThemeSettings");
  let scheme = getActiveColorScheme();
  let s = getEffectiveThemeSettings(scheme);
  let defaultText = (scheme === "light") ? "black" : "#bebebe";
  let defaultStoryBg = (scheme === "light") ? "#fafafa" : "#000000";
  let defaultUserBg = (scheme === "light") ? "#fafafa00" : "#00000000";
  let textColor = s.storyTextColor || defaultText;
  let bgColor = s.storyBackgroundColor || defaultStoryBg;
  let userBgColor = s.userBackgroundColor || defaultUserBg;
  let userTextColor = s.userTextColor || defaultText;
  let fontValue = parseFontFamilyInput(s.storyFontFamily || "");
  let fontName = extractFontNameFromInput(fontValue);
  if(typeof storySoFarEl !== "undefined") {
    if(fontName) ensureGoogleFontLoaded(fontName);
    storySoFarEl.style.color = textColor;
    storySoFarEl.style.fontFamily = fontName || "";
    storySoFarEl.style.fontSize = "";
    storySoFarEl.style.lineHeight = "";
    storySoFarEl.style.border = "";
  }
  if(window.notepadEditorEl) {
    if(fontName) ensureGoogleFontLoaded(fontName);
    notepadEditorEl.style.color = textColor;
    notepadEditorEl.style.fontFamily = fontName || "";
    notepadEditorEl.style.fontSize = "";
    notepadEditorEl.style.lineHeight = "";
    notepadEditorEl.style.border = "";
  }
  if(typeof storyOverviewEl !== "undefined") {
    storyOverviewEl.style.border = "";
  }
  if(typeof whatHappensNextEl !== "undefined") {
    whatHappensNextEl.style.border = "";
  }
  document.documentElement.style.setProperty('--text-style-rule-quote-color', textColor);
  applyTextStyleRulesToEditor();
  updateThemeDependentVars(bgColor, scheme);

updateThemeDependentVars(bgColor, scheme) =>
  let normalBg = bgColor || (scheme === "light" ? "#fafafa" : "#000000");
  let activeBg = addAlphaToColor(normalBg, 0.78);
  document.documentElement.style.setProperty('--bg-story', normalBg);
  document.documentElement.style.setProperty('--background-image-active-textbox-background-color', activeBg);
  document.documentElement.style.setProperty('--background-image-active-box-shadow-color', scheme === "light" ? "#fafafa" : "#000000");

addAlphaToColor(color, alpha) =>
  let hex = color.trim();
  if(/^#([0-9a-f]{3}){1,2}$/i.test(hex)) {
    if(hex.length === 4) hex = "#" + hex[1]+hex[1]+hex[2]+hex[2]+hex[3]+hex[3];
    let r = parseInt(hex.slice(1,3),16);
    let g = parseInt(hex.slice(3,5),16);
    let b = parseInt(hex.slice(5,7),16);
    return `rgba(${r},${g},${b},${alpha})`;
  }
  if(/^rgb\(/i.test(color)) return color.replace(/^rgb\(/i, "rgba(").replace(/\)$/, `,${alpha})`);
  if(/^rgba\(/i.test(color)) return color.replace(/,[^,]+\)$/, `,${alpha})`);
  return color;

async loadStoryDataFromUsersDevice() =>
  return new Promise((resolve, reject) => {
    let input = document.createElement('input');
    input.type = 'file';
    input.accept = 'application/json, text/json, text/plain, application/JSON, .json';
    input.onchange = async (event) => {
      let file = event.target.files[0];
      if (file) {
        try {
          let content = await file.text();
          let data = JSON.parse(content);
          if(data.format === "perchance-ai-story-v1") {
            let title = extractAndStripTitleFromImportedStoryData(data, "Imported story");
            await createNewStory({title, data:normalizeStoryData(data)});
            if (codeDebug) console.log("reqeusted fromuserdevice story")
          } else {
            alert("Unknown save file format.");
          }
        } catch (error) {
          alert("There was an error while loading that story file.");
          reject(error);
        }
      }
    };
    input.click();
  });

async copyStoryTextToClipboard(btn) =>
  let text = storySoFarEl.value;
  await navigator.clipboard.writeText(text);
  let targetBtn = btn || (typeof copyStoryTextWithSummariesBtn !== "undefined" ? copyStoryTextWithSummariesBtn : null);
  if(targetBtn) targetBtn.textContent = "✅ copied";
  setTimeout(() => {
    if(targetBtn) targetBtn.textContent = "📋 copy story";
  }, 3000);
  try {
    if(btn && btn.closest && btn.closest(".storyToolsMenu")) closeStoryToolsMenu();
  } catch(e) {}

async copyStoryTextToClipboardWithoutSummaries(btn) =>
  let text = storySoFarEl.value.split(/\n{2,}/).map(p => p.trim()).filter(p => !p.startsWith("SUMMARY^")).join("\n\n");
  
  await navigator.clipboard.writeText(text);
  let targetBtn = btn || (typeof copyStoryTextWithoutSummariesBtn !== "undefined" ? copyStoryTextWithoutSummariesBtn : null);
  if(targetBtn) targetBtn.textContent = "✅ copied";
  setTimeout(() => {
    if(targetBtn) targetBtn.textContent = "📋 copy story (no summaries)";
  }, 3000);
  try {
    if(btn && btn.closest && btn.closest(".storyToolsMenu")) closeStoryToolsMenu();
  } catch(e) {}

openAudiobookTool() =>
  window.open("https://perchance.org/text-to-audiobook", "_blank", "noopener");
  closeStoryToolsMenu();

openImageTool() =>
  window.open("https://perchance.org/ai-text-to-image-generator", "_blank", "noopener");
  closeStoryToolsMenu();

toggleStoryToolsMenu() =>
  if(typeof storyToolsMenu === "undefined") return;
  storyToolsMenu.hidden = !storyToolsMenu.hidden;

closeStoryToolsMenu() =>
  if(typeof storyToolsMenu === "undefined") return;
  storyToolsMenu.hidden = true;

handleStoryToolsDelete() =>
  if(typeof storyToolsDeleteBtn === "undefined") return;
  if(storyToolsDeleteBtn.dataset.mode === "undo") {
    storySoFarEl.value = window.deletedStorySoFar || "";
    storyToolsDeleteBtn.dataset.mode = "delete";
    storyToolsDeleteBtn.textContent = "🗑️ delete story text";
    requestSaveCurrentStory({immediate:true});
    closeStoryToolsMenu();
    return;
  }
  if(!confirm("Delete all of the current story text?")) return;
  window.deletedStorySoFar = storySoFarEl.value;
  storySoFarEl.value = "";
  storyToolsDeleteBtn.dataset.mode = "undo";
  storyToolsDeleteBtn.textContent = "↩️ undo deletion";
  requestSaveCurrentStory({immediate:true});
  closeStoryToolsMenu();

getMessagesWithSummaryReplacements(text, opts) =>
  if(!opts) opts = {};
  const minimumMessageLevel = opts.minimumMessageLevel || 0; // used by the summarization process.
  
  let messages = text.split("\n\n").map(m => m.trim()).filter(m => m);
  let messagesWithSummaryReplacements = [];
  let highestLevelSeen = 0;
  
  // it's we go backwards through the messages, and only 'collect' a message if its level is not below the highest level we've seen so far. it makes sense if you think about it for a bit.
  // said another way, we go from the end of the messages to the start while 'monotonically climbing' up a level whenever we hit a 'higher' message.
  while(messages.length > 0) {
    let m = messages.pop();
    let level = Number((m.match(/SUMMARY\^([0-9]+):/)||[])[1] || 0);
    if(level < minimumMessageLevel) continue;
    if(level >= highestLevelSeen) {
      messagesWithSummaryReplacements.unshift(m);
      highestLevelSeen = level;
    }
  }
  return messagesWithSummaryReplacements;
  
summaryPromptInstruction
  Your task is to generate some text for a story/narration and then a 'SUMMARY' of that text, and then do that a few more times. Below is the story overview, and a summary of earlier events. You must write the text, and then a summary of that text that you wrote, and then some more text, and a summary of that new text, and so on. Each summary should be a single paragraph of text which summarizes the important details from the preceding text to roughly half its original size.
  Use this format/template for your response:
  ```
  >>> FULL TEXT of \[A\]: <story/narration text>
  >>> SUMMARY of \[A\]: <a one-paragraph summary of the full \[A\] text>
  ---
  >>> FULL TEXT of \[B\]: <story/narration text>
  >>> SUMMARY of \[B\]: <a one-paragraph summary of the full \[B\] text>
  ---
  >>> FULL TEXT of \[C\]: <story/narration text>
  >>> SUMMARY of \[C\]: <a one-paragraph summary of the full \[C\] text>
  ```
  [""]
  # Story Overview:
  [literal(storyOverviewEl.value.trim().replace(/\n+/g, "\n") || "(Not specified.)")][getCombinedStoryBibleText()]
  [""]
  # Summary of Previous Events:
  [literal(window.summaryMessagesForInstruction.join("\n"))]
  [""]
  ---
  [""]
  Again, your task is to write some text labelled with a letter, and then a summary of that text, and then some new text, and then a summary of that new text, and so on. Each summary should be a single paragraph of text which summarizes the new text to roughly half its original length. Don't add flowery prose to summaries. Summary text should contain only the most important information, and should use well-phrased sentences with natural structure and correct grammar.
  NOTE: Don't append any other commentary/notes in your summaries (e.g. no word counts or commentary after completing the task). Just do the task and then end your response.
  IMPORTANT: Avoid repetition in summaries! If there are erroneously repeated elements in the full text, then remove or ignore them when writing your well-phrased summary.
  TIP: In order to ensure the summary is half the length of the full text, you should consider what's actually happening in the story at a "higher level", rather than simply re-stating all the individual facts in a terse form. The summary should be a higher-level explanation of the full text.
  $output = [this.joinItems("\n")] // joins all of the above lines together

injectSummariesAndComputeNextSummariesInBackgroundIfNeeded() =>
  if (codeDebug) console.log("injectSummariesAndComputeNextSummariesInBackgroundIfNeeded : START");
  // Make summaries per-story so they don't leak across story switching:
  let storyId = window.currentStoryId ?? (window.storyManager?.currentId ?? 0);
  if(!window.summariesReadyToInjectByStoryId) window.summariesReadyToInjectByStoryId = {};
  if(!window.summariesReadyToInjectByStoryId[storyId]) window.summariesReadyToInjectByStoryId[storyId] = [];
  if(!window.alreadyDoingSummaryByStoryId) window.alreadyDoingSummaryByStoryId = {};
  
  let summariesReadyToInject = window.summariesReadyToInjectByStoryId[storyId];
  
  // inject summaries if we have any:
  if(summariesReadyToInject.length > 0) {
    if (codeDebug) console.log("injectSummariesAndComputeNextSummariesInBackgroundIfNeeded : summariesReadyToInject > 0");
    // ensure logs are normalized so our message comparison checks work:
    let allMessagesOriginal = storySoFarEl.value.split(/\n{2,}/g).map(m => m.trim()).filter(m => m);
    let allMessagesNew = allMessagesOriginal.slice(0);
    for(let {summarizedMessages, lastMessageSummarizedIndex, summary, level} of summariesReadyToInject) {
      let lastSummarizedMessage = summarizedMessages[summarizedMessages.length-1];
      if(allMessagesOriginal[lastMessageSummarizedIndex] === lastSummarizedMessage) {
        allMessagesNew.splice(lastMessageSummarizedIndex + 1, 0, `SUMMARY^${level}: ${summary}`);
      } else {
        console.warn("Content of last-summmarized-message doesn't match content of message at lastMessageSummarizedIndex. Safe to ignore this warning if logs have been edited since last 'send' button click. This summary will simply be discarded and we'll compute a new one with the up-to-date story text.");
      }
    }
    if (codeDebug) console.log("injectSummariesAndComputeNextSummariesInBackgroundIfNeeded : Join");
    storySoFarEl.value = allMessagesNew.join("\n\n");
    window.summariesReadyToInjectByStoryId[storyId] = [];
    summariesReadyToInject = window.summariesReadyToInjectByStoryId[storyId];
  }
  
  const { countTokens, idealMaxContextTokens } = ai({getMetaObject:true});
  
  const contextLengthToIdeallyStayUnder = idealMaxContextTokens*0.88;
  const numCharsToSummarizeAtATime = 1500; // don't make this bigger without testing
  
  // must get text synchronously, since storySoFarEl can be temporarily ablated during streaming for rendering performance.
  const storySoFarElText = storySoFarEl.value;
  const messagesWithSummaryReplacements = getMessagesWithSummaryReplacements(storySoFarElText);
  
  let currentlyUsedContextLength = countTokens(messagesWithSummaryReplacements.join("\n\n") + storyOverviewEl.value);
  if(currentlyUsedContextLength < contextLengthToIdeallyStayUnder) {
    if (codeDebug) console.log(`Summarization not needed. currentlyUsedContextLength=${currentlyUsedContextLength} which is less than ${contextLengthToIdeallyStayUnder}`);
    return;
  }
      
  // compute next summary in background if needed:
  (async function() {
    let thisStoryId = storyId;
    if(window.alreadyDoingSummaryByStoryId[thisStoryId]) return;
    try {
      window.alreadyDoingSummaryByStoryId[thisStoryId] = true;
      
      const allMessageObjs = storySoFarElText.split(/\n{2,}/).map(m => m.trim()).filter(m => m).map((text, i) => {
        return {
          text,
          index: i,
          level: Number((text.match(/SUMMARY\^([0-9]+):/)||[])[1] || 0)
        };
      });
      
      let summaryLevelToMessageBlocks = new Map();
      let summaryLevelBeingProcessed = 1;
      while(1) {
        const thisLevelAndPreviousLevelMessageObjs = allMessageObjs.filter(m => m.level === summaryLevelBeingProcessed || m.level === summaryLevelBeingProcessed-1);
        
        if(thisLevelAndPreviousLevelMessageObjs.length === 0) {
          if (codeDebug) console.log("Finished creating summaryLevelToMessageBlocks.");
          break;
        }
        
        const blocks = [];
        let currentBlock = [];
        currentBlock.globalMessageIndices = [];
        for(let m of thisLevelAndPreviousLevelMessageObjs) {
          currentBlock.push(m.text);
          currentBlock.globalMessageIndices.push(m.index);
          if(m.level === summaryLevelBeingProcessed) {
            blocks.push(currentBlock);
            currentBlock = [];
            currentBlock.globalMessageIndices = [];
          }
        }
        if(summaryLevelBeingProcessed === 1 && currentBlock.length === 0) {
          console.warn("final block for summaryLevel==1 should have messages? if it doesn't, then we're maybe summarizing too close to the end of the story text?");
        }
        blocks.push(currentBlock);
        summaryLevelToMessageBlocks.set(summaryLevelBeingProcessed, blocks);
        
        summaryLevelBeingProcessed++;
      }
      
      const summaryLevelBlockEntries = [...summaryLevelToMessageBlocks.entries()].sort((a,b) => a[0]-b[0]);
      for(let [summaryLevel, blocks] of summaryLevelBlockEntries) {
        // discard if story switched
        if((window.currentStoryId ?? window.storyManager?.currentId) !== thisStoryId) {
          if (codeDebug) console.log("Discarding summary work because story changed.");
          return;
        }
  
        let messagesToSummarizeFromFinalBlock = blocks[blocks.length-1];
        
        let numCharsInFinalBlock = messagesToSummarizeFromFinalBlock.reduce((a,v) => a+v.length, 0);
        if(numCharsInFinalBlock < numCharsToSummarizeAtATime) { 
          if (codeDebug) console.log(`summaryLevel=${summaryLevel} doesn't need summarizing yet. numCharsInFinalBlock=${numCharsInFinalBlock}`);
          continue;
        }
      
        while(1) {
          if(messagesToSummarizeFromFinalBlock.length <= 2) break;
          let numChars = messagesToSummarizeFromFinalBlock.reduce((a,v) => a+v.length, 0);
          if(numChars < numCharsToSummarizeAtATime) break;
          
          if(numChars > numCharsToSummarizeAtATime*10) {
            let halfOfMessagesCount = Math.floor(messagesToSummarizeFromFinalBlock.length/2);
            for(let j = 0; j < halfOfMessagesCount; j++) {
              messagesToSummarizeFromFinalBlock.pop();
              messagesToSummarizeFromFinalBlock.globalMessageIndices.pop();
            }
          } else {
            messagesToSummarizeFromFinalBlock.pop();
            messagesToSummarizeFromFinalBlock.globalMessageIndices.pop();
          }
        }
  
        if(messagesToSummarizeFromFinalBlock.length === 0) {
          console.error("No messages to summarize??");
          continue;
        }
  
        // ensure per-story summariesReadyToInject exists
        if(!window.summariesReadyToInjectByStoryId[thisStoryId]) window.summariesReadyToInjectByStoryId[thisStoryId] = [];
  
        let existingSummary = window.summariesReadyToInjectByStoryId[thisStoryId].filter(s => s.summarizedMessages.join("\n\n") === messagesToSummarizeFromFinalBlock.join("\n\n"))[0];
        if(existingSummary) {
          console.error("Existing summary hasn't been injected yet?? Should have happened before this code ran.");
          return;
        }
        
        let lastMessageSummarizedIndex = messagesToSummarizeFromFinalBlock.globalMessageIndices[messagesToSummarizeFromFinalBlock.length-1];
        if(messagesToSummarizeFromFinalBlock.globalMessageIndices.length !== messagesToSummarizeFromFinalBlock.length) { console.error("should be one index per message"); return; }
        
        let exampleBlocksForStartWith = blocks.slice(-3, -1);
        let exampleBlockSummaries = exampleBlocksForStartWith.map(b => b[b.length-1]);
        
        let instructionSummaries = getMessagesWithSummaryReplacements(storySoFarElText, {minimumMessageLevel:summaryLevel});
        while(1) {
          if(instructionSummaries.length === 0) break;
          if(exampleBlockSummaries.includes(instructionSummaries[instructionSummaries.length-1])) {
            instructionSummaries.pop();
            continue;
          }
          break;
        }
        instructionSummaries = instructionSummaries.map(m => m.replace(/SUMMARY\^[0-9]+:/, "").trim());
        
        let startWithBlocks = exampleBlocksForStartWith.map((block) => ({messages:block.slice(0, -1), summary:block.slice(-1)[0]}));
        startWithBlocks.push({messages:messagesToSummarizeFromFinalBlock, summary:""});
        
        if(messagesToSummarizeFromFinalBlock.join("\n").replaceAll(`SUMMARY^${summaryLevel-1}:`, "").includes("SUMMARY^")) {
          console.error("Should have only been summaryLevel-1 summaries in messagesToSummarizeText. messagesToSummarizeFromFinalBlock:", messagesToSummarizeFromFinalBlock);
        }
        
        let startWith = startWithBlocks.map(({messages, summary}, blockI) => {
          let letterLabel = "";
          if(blockI===0) letterLabel = "[A]";
          if(blockI===1) letterLabel = "[B]";
          if(blockI===2) letterLabel = "[C]";
  
          let messagesText = messages.map((message, mi) => {
            message = message.replace(`SUMMARY\^${summaryLevel-1}:`, "").replace(`SUMMARY\^${summaryLevel}:`, "").replace(/\n/g, " ").trim();
            return `${summaryLevel === 1 ? `(${mi+1}) ` : ""}${message}`;
          }).join(" ");
          
          summary = summary.replace(`SUMMARY\^${summaryLevel-1}:`, "").replace(`SUMMARY\^${summaryLevel}:`, "").replace(/\n/g, " ").trim();
  
          return `>>> FULL TEXT of ${letterLabel}: ${messagesText}\n>>> SUMMARY of ${letterLabel}: ${summary}`;
        }).join("\n---\n");
        
        startWith = startWith.trim();
        startWith = startWith.trim().slice(0, -1) + " (full, natural, readable sentences with correct grammar):";
  
        window.summaryMessagesForInstruction = instructionSummaries.length > 0 ? instructionSummaries : ["(None.)"];
        let instruction = root.summaryPromptInstruction.evaluateItem;
        window.summaryMessagesForInstruction = null;
  
        let promptOptions = {
          instruction,
          startWith,
          stopSequences: ["\n\n", "\n---", ">>> FULL TEXT", "FULL TEXT"],
        };
  
        // discard if story switched just before LLM call
        if((window.currentStoryId ?? window.storyManager?.currentId) !== thisStoryId) return;
  
        let data = await root.ai(promptOptions);
        if(data.stopReason === "error") continue;
        
        let summary = data.generatedText.trim().replace(/\n+/g, " ").trim().replace(/---$/, "").replace(">>> FULL TEXT", "").replace("FULL TEXT", "").trim();
        if(!summary.trim() || (instructionSummaries[instructionSummaries.length-1] || "").trim() === summary.trim()) {
          console.warn("AI copied previous summary or gave blank summary. Skipping this summary level for this 'round'. Summary:", summary);
          continue;
        }
  
        if(summary.split(summary.slice(-30)).length > 5) {
          console.warn("Repeition detected within summary. Fixing...");
          let result = await root.ai({
            instruction: [
              `Does the following story summary snippet shown within <story_summary_snippet>...</story_summary_snippet> include erroneous/unnecessary repetition? If so, respond with fixed, repetition-free text within <fixed_story_summary_snippet>...</fixed_story_summary_snippet>. If the text is fine, then just respond with exactly 'no_repetition', and nothing more.`,
              ``,
              `<story_summary_snippet>`,
              `${summary}`,
              `</story_summary_snippet>`,
              ``,
              `Your response should either be 'no_repetition' or start with <fixed_story_summary_snippet> and give the repetition-free summary, and then end with </fixed_story_summary_snippet>. Feel free to just respond with 'no_repetition' if there's no repetition. Don't add any extra commentary.`,
            ].join("\n"),
            stopSequences: ["</fixed_story_summary_snippet>"],
          });
          if(result.stopReason === "error") continue;
          let fixedSummary = result.generatedText.match(/<fixed_story_summary_snippet>(.+)<\/fixed_story_summary_snippet>/s)?.[1].trim();
          if(fixedSummary) summary = fixedSummary;
        }
        
        // discard if story switched before committing summary
        if((window.currentStoryId ?? window.storyManager?.currentId) !== thisStoryId) {
          if (codeDebug) console.log("Discarding computed summary because story changed.");
          return;
        }
        
        window.summariesReadyToInjectByStoryId[thisStoryId].push({summarizedMessages:messagesToSummarizeFromFinalBlock, lastMessageSummarizedIndex, summary, level:summaryLevel});
      }
    } catch(e) {
      console.error(e);
    } finally {
      window.alreadyDoingSummaryByStoryId[thisStoryId] = false;
    }
  })();

//  Helper function to build the combined story bible text
getCombinedStoryBibleText(prompt) =>
  if(!infoTrackingBtn.dataset.enabled) return "";

  let scope = "bible";
  let BibleTabs = getNotebookDataForScope(scope);
  
  const order = [
    "<Player Info>",
    "<Other Characters>",
    "<Locations>",
    "<Events/Plot>",
    "<Lore/History>",
    "<Plot Threads>"
  ];

  const bibleSectionMarkers = [
    "<update_marker_player>",
    "<update_marker_characters>",
    "<update_marker_locations>",
    "<update_marker_events>",
    "<update_marker_lore>",
    "<update_marker_mysteries>"
  ];
    
  const orderMap = Object.fromEntries(order.map((v, i) => [v, i]));
  let sortedTabs = (BibleTabs.tabs || []).filter(tab => scope === "bible" ? tab.title?.startsWith("<") : !tab.title?.startsWith("<")).slice(0).sort((a,b) =>scope === "bible" ? (orderMap[a.title] ?? Infinity) - (orderMap[b.title] ?? Infinity) : (b.lastEditedTime || 0) - (a.lastEditedTime || 0));
    
  // Extract content with optional chaining and defaults
  const sectionContents = [
    sortedTabs[0]?.content?.trim() || "",
    sortedTabs[1]?.content?.trim() || "",
    sortedTabs[2]?.content?.trim() || "",
    sortedTabs[3]?.content?.trim() || "",
    sortedTabs[4]?.content?.trim() || "",
    sortedTabs[5]?.content?.trim() || ""
  ];

   // If prompt=true, return array of objects with boolean + marker + data
  if (prompt === true) {
    return sectionContents.map((content, i) => ({
      hasContent: !!content,
      marker: bibleSectionMarkers[i],
      data: sortedTabs[i]
    }));
  }

  if (sectionContents.every(c => !c)) return "";

  // Construct bible content as before
  const [playerInfo, charactersInfo, locationsInfo, eventsInfo, loreInfo, mysteriesInfo] = sectionContents;
  
  let bibleContent = 
    "## Player Info & Inventory:\n" + (literal(playerInfo) || "(Not specified.)") + "\n\n" +
    "## Other Characters:\n" + (literal(charactersInfo) || "(Not specified.)") + "\n\n" +
    "## Locations:\n" + (literal(locationsInfo) || "(Not specified.)") + "\n\n" +
    "## Events & Plot:\n" + (literal(eventsInfo) || "(Not specified.)") + "\n\n" +
    "## Lore & Factions:\n" + (literal(loreInfo) || "(Not specified.)") + "\n\n" +
    "## Mysteries & Plot Threads:\n" + (literal(mysteriesInfo) || "(Not specified.)");

  return "\n\n<tracked_info>\n# STORY BIBLE\n" + bibleContent.trim() + "\n</tracked_info>";
  
// This is the prompt for updating any bible section
bibleAutoUpdatePrompt
  You are an intelligent assistant that updates a Story Bible using new story events.
  Your task is to update ONLY ONE section at a time. You must be precise and preserve existing information unless it is explicitly contradicted.
  
  ---
  
  CURRENT SECTION: [window.generatingBibleSectionName]

  You are ONLY updating this section. Any information not belonging to this section must be ignored.

  ---
  
  You are given:
  * The EXISTING CONTENT for the section: [window.generatingBibleSectionName]
  * NEW STORY EVENTS since the last update
  * The STORY OVERVIEW for context and initial details like characters, inventory, lore.
  * ADDITIONAL CONTENT to be added/populated in the section

  ---
  
  OTHER SECTIONS (REFERENCE ONLY - DO NOT MODIFY):
  <Player Info> → Player attributes, inventory, time, weather
  <Other Characters> → Non-player characters only
  <Locations> → Places only
  <Events/Plot> → Events and outcomes
  <Lore/History> → Factions and world lore
  <Plot Threads> → Ongoing mysteries and clues
  
  ---
  
  RULES:
  
  1. Read the NEW STORY EVENTS carefully.
  2. Compare them to the EXISTING CONTENT for the target section only.
  3. Update ONLY information that is new or directly changed.
  4. NEVER remove existing fields, you can change the value, but let the player decide what should be removed.
  5. Use STATUS: to mark other characters inactive instead of deleting them.
  6. If nothing changes, return the EXISTING CONTENT exactly as it is.
  7. Be concise. Separate key details with semicolons.
  8. Short sections only, no long descriptions or details.
  9. When listing relationships, include only: NAME (relationship). - Do not describe the other character.
  10. Refer to the player as their name if given, otherwise "Main Character".
    - If multiple are specified in the overview, use "Main Characters" and structure them separately under Player Info & Inventory.
  11. Use the reference format as a guideline; you may add new sections or reorganize if needed.
  12. Do not place Main Character inside Other Characters.
  13. Only Main Character should be in Player Info, never in any other section
  14. Do not mix sections.
    - Mysteries do not go in Lore & Factions.
    - Factions do not go in Mysteries & Plot Threads.
  15. Do not infer or invent information.
    - Only include facts explicitly stated in the NEW STORY EVENTS.
    - If a field is requested but you have no data but "Not discovered"
  16. You MUST populate additional data as new entries or lines depending on what's needed: [bibleSectionAdditionaInfo()]
  19. Examples of INVALID behavior:
    - Adding LOCATION data inside Other Characters → INVALID
    - Adding FACTIONS inside Plot Threads → INVALID
    - Adding INVENTORY items outside Player Info → INVALID

    These must NEVER occur.

  GUIDELINES:

  - The '#' symbols in the reference format are **guidelines only**.
  - DO NOT output any '#' symbols in the final result.
  - Instead, use 2 spaces per level to indicate hierarchy in the output.
  - Parent sections have 0 spaces, subsections 2 spaces, sub-subsections 4 spaces.
  - Use clear headings for sections and subsections. - NEVER output the section name (e.g., "<Locations>", "<Other Characters>", etc.).
  - The output must begin directly with the first field (e.g., NAME:, EVENT NAME:, FACTIONS:, etc.).
  - Maintain readability and alignment. 
  - Field labels (text BEFORE ":") must be ALL CAPS (e.g., NAME:, AGE:).
  - Field values (text AFTER ":") must use normal sentence case or proper title case.
  - Proper names must NEVER be written in all caps.
    Correct: NAME: John Doe
    Incorrect: NAME: JOHN DOE
  - Include relevant details from NEW STORY EVENTS and EXISTING CONTENT like: HEIGHT, OCCUPATION, LOCATION, etc.
  - Reference format shows typical structure but is not mandatory.
  - Indentation must reflect hierarchy: subsections are indented 2 spaces relative to their parent.
  - Under INVENTORY LIST:, each important item must appear on its own line.
  - Each item must be indented 4 spaces under INVENTORY LIST:.
  - Do NOT combine multiple items on one line.
  - Only include inventory items that are plot-relevant, unique, newly acquired, lost, or specifically emphasized in the NEW STORY EVENTS.
  - Do NOT include ordinary everyday items (e.g., clothes, phone, wallet) unless they are explicitly relevant to the story event.
  - Do NOT infer standard possessions.
  ---
  REFERENCE FORMAT (guideline)

  Here is a suggested structure you can use as a reference. You may add, skip, or reorganize sections if the story requires it.
  Do not output the word "SECTION:" in the final answer.
  [bibleSectionFormat(window.generatingBibleSectionName)]

  ---
  CONTEXT:
  
  STORY OVERVIEW:
  [literal(document.getElementById('storyOverviewEl').value.trim() || "(Not specified.)")]

  EXISTING CONTENT:
  [literal(window.existingSectionContentForPrompt || "(This section is currently empty.)")]

  NEW STORY EVENTS:
  [literal(window.newEventsForPrompt)]

  ADDITIONAL CONTENT:
  [bibleSectionAdditionaInfo()]
  
  ---
  TASK:
  Write the complete updated content of the current section.
  Do NOT output the section name.
  Do NOT restate the section label.

  $output = [this.joinItems("\n")]
  
bibleSectionFormat(section) =>
  if (codeDebug) console.log("bibleSectionFormat");
  let lines = [];
  // <Player/World Info>
  if (section === "<Player Info>") {
    lines.push(
      `# NAME:
      ## AGE:
      ## HEIGHT:
      ## ORIENTATION: 
      ## OCCUPATION:
      ## PHYSICAL APPEARANCE: (do not include clothes, just the person itself)
      ## BACKGROUND:
      ## CLOTHES:
      ## NOTABLE TRAITS:
      ## INVENTORY LIST: 
      ## RELATIONSHIPS: NAME (relation); NAME (relation)
      
      # DATE: (Weekday - Month Day, Year)
      # TIME: (Specific if possible, daypart )
      # WEATHER:`
    );
  }
  // <Other Characters>
  if (section === "<Other Characters>") {
    lines.push(
  `# NAME:
  ## STATUS: (Keep track of active or inactive characters without removing them)
  ## AGE:
  ## HEIGHT:
  ## OCCUPATION:
  ## BUST SIZE: (only if character is female)
  ## PHYSICAL APPEARANCE: (do not include clothes, just the person itself)
  ## BACKGROUND:
  ## CLOTHES:
  ## RELATIONSHIPS:`
    );
  }
  // <Locations>
  if (section === "<Locations>") {
    lines.push(
  `# NAME:
  ## TYPE:
  ## DESCRIPTION:
  ## NOTABLE FEATURES:`
    );
  }
  // <Events/Plot>
  if (section === "<Events/Plot>") {
    lines.push(
      `# EVENT NAME:
      ## DESCRIPTION:
      ## CHARACTERS INVOLVED:
      ## OUTCOME:`
    );
  }
  // <Lore/History>
  if (section === "<Lore/History>") {
    lines.push(
      `# FACTIONS:
    ## FACTION NAME:
    ### TYPE:
    ### DESCRIPTION:
    ### KEY MEMBERS:
    ### GOALS:
    
    # LORE:
    ## CONCEPT NAME:
    ### DESCRIPTION:
    ### ELEMENTS:
    ### PURPOSE:`
    );
  }
  // <Plot Threads>
  if (section === "<Plot Threads>") {
    lines.push(
      `# THREAD NAME:
      ## DESCRIPTION:
      ## CLUES:
      ## STATUS:`
    );
  }
  
  lines = lines.filter(l => l); // filter out `null` lines
  let text = lines.join("\n")
    .replace(/^### /gm, "    ") // 4 spaces
    .replace(/^## /gm, "  ")    // 2 spaces
    .replace(/^# /gm, "");      // 0 spaces (parent);
  return text;

bibleSectionAdditionaInfo() =>
  if (codeDebug) console.log("Running bibleSectionAdditionaInfo");
  let lines = [];
  
  if(bibleOptionalPrompt && bibleOptionalPrompt.trim() !== "" ) {
    lines.push(bibleOptionalPrompt.trim());
  }
  lines = lines.filter(l => l); // filter out `null` lines
  let text = lines.join("\n").trim();
  return text;

// This defines the function
initStoryObserver() =>
  if (!window.MutationObserver) return;
  
  const observer = new MutationObserver((mutations) => {
    // Logic for when the story changes
    let content = storySoFarEl.value?.trim() || "";
    if (content.length === 0) {
      generateBtn.textContent = "📖 New Story";
    }
  });

  observer.observe(storySoFarEl, { 
    attributes: true, 
    childList: true, 
    characterData: true, 
    subtree: true 
  });

// This "runs" the function without causing a Top-Level List error
// By indenting it under a name, Perchance treats it as a script execution
runObserver
  [setTimeout(() => initStoryObserver(), 1000)]

// Writing Style & Genre Lists
genreInstructions
  default
  fantasy
    - **Genre: Fantasy.** Weave in elements of magic, unique mythical creatures, and fantastical worlds. Build a rich world with its own history and rules. Magic should feel wondrous and mysterious. 
  dark_fantasy
    - **Genre: Dark Fantasy.** Blend fantasy with elements of horror. The world should be grim, morally ambiguous, and dangerous. Magic should have a high cost. Characters should face difficult choices and consequences.
  sci_fi
    - **Genre: Sci-Fi.** Explore futuristic concepts, advanced technology, space exploration, or extraterrestrial life. Ground the story in scientific principles, even if they are speculative.
  noir
    - **Genre: Noir.** Adopt a cynical, hardboiled tone. The protagonist should be a flawed anti-hero. The setting is typically a dark, corrupt city. Use sharp, cynical dialogue. The plot often involves crime and moral ambiguity.
  mystery
    - **Genre: Mystery.** Center the plot around a puzzle or crime to be solved. Drop clues and red herrings. Build suspense and lead to a satisfying revelation. 
  thriller
    - **Genre: Thriller.** Focus on creating suspense, excitement, and anticipation. The stakes should be high, often with a race against time. The protagonist should face significant obstacles.
  horror
    - **Genre: Horror.** Aim to evoke fear, dread, and terror. Use atmosphere, psychological tension, and unsettling imagery meant to terrify or scare the reader.
  contemporary
    - **Genre: Contemporary.** Set the story in the present day. The conflicts and themes should be relatable to a modern audience. Focus on realistic characters and situations.
  slice_of_life
    - **Genre: Slice of Life.** Focus on small, everyday moments in characters' lives. The narrative should emphasize ordinary experiences, subtle emotions, and realistic interactions. The story must remain grounded in normal daily life. Do NOT introduce major conflicts, conspiracies, villains, mysteries, or large-scale explanations. If something unusual or inconvenient occurs, treat it as a minor personal problem rather than a larger plot. Characters should react in practical, mundane ways instead of investigating or uncovering hidden causes.
  romance
    - **Genre: Romance.** The central plot must revolve around the development of a romantic relationship between characters. Ensure emotional depth and a satisfying romantic arc. 
  self_help
    - **Genre: Self-Help.** The narrative should be structured to provide guidance or inspiration to the reader, often through a character's journey of personal growth and overcoming obstacles. The tone should be positive and encouraging. 
  historical_fiction
    - **Genre: Historical Fiction.** Set the story in a recognizable period of history. Pay close attention to historical accuracy in setting, customs, and events, while weaving a fictional narrative. 
  dystopian
    - **Genre: Dystopian.** Set the story in a future society that is deeply flawed, often oppressive or post-apocalyptic. Explore themes of societal control, rebellion, and the human condition. 
  cyberpunk
    - **Genre: Cyberpunk.** Set the story in a high-tech, low-life future. Focus on themes of corporate control, cybernetics, and the fusion of man and machine. The setting should be gritty and neon-lit. 
  steampunk
    - **Genre: Steampunk.** Set the story in a world where steam power and clockwork technology dominate, often in a Victorian or Wild West aesthetic. Include airships, clockwork automatons, and steam-powered machinery.
  political
    - **Genre: Political.** Focus on the workings of government, political systems, or political intrigue. Explore themes of power, corruption, and ideology. The plot often involves intrigue, double-crosses, and high-stakes missions. 
  comedy
    - **Genre: Comedy.** The primary goal is to make the reader laugh. Use humor, wit, and absurdity. The plot can be lighthearted or satirical. Characters may be exaggerated or quirky. 
  adventure
    - **Genre: Adventure.** Focus on a journey or quest. The protagonist should face physical challenges and obstacles. The tone is often exciting and fast-paced, with a focus on action and exploration. 
  western
    - **Genre: Western.** Set the story in the American Old West. Include elements like cowboys, outlaws, frontier towns, and the struggle for survival. The tone is often rugged and adventurous. 
  post_apocalyptic
    - **Genre: Post-Apocalyptic.** Set the story in a world after a catastrophic event. Focus on survival, the collapse of society, and the struggle to rebuild. The tone is often bleak and desperate. 
  war
    - **Genre: War.** Set the story during a time of armed conflict. Focus on the experiences of soldiers and civilians. Explore themes of courage, sacrifice, and the horrors of war.
  spy
    - **Genre: Spy.** Focus on espionage, secret agents, and covert operations. The plot often involves intrigue, double-crosses, and high-stakes missions. The tone is often fast-paced and suspenseful. 
  superhero
    - **Genre: Superhero.** Focus on characters with superhuman abilities who use them to fight crime or protect the world, and villains who use their powers for evil or personal gain, sometimes for understandable or relatable reasons. Explore themes of power, responsibility, and morality. The tone is often action-packed and dramatic.

styleInstructions
  default
    - **Writing Style: Novel Style (Default).** Use a clear, balanced, and engaging novelistic style. Vary sentence structure and length. Avoid overly complex or overly simple prose. Focus on strong storytelling and clear narration.
  descriptive
    - **Writing Style: Descriptive.** Focus heavily on rich, sensory details. Paint a vivid picture of the setting, characters, and atmosphere. Use strong verbs and evocative adjectives to immerse the reader in the scene.
  minimalist
    - **Writing Style: Minimalist.** Use short, direct, and unadorned sentences. Omit needless words. Focus on action and subtext, implying emotion rather than stating it. The prose should be sparse and clean.
  poetic
    - **Writing Style: Poetic & Lyrical.** Use evocative imagery, metaphor, and simile. Prioritize the rhythm and sound of the prose. Sentences may be long and flowing, with a focus on emotional resonance.
  journalistic
    - **Writing Style: Journalistic.** Adopt an objective, factual, and detached tone. Report events clearly and concisely, like a newspaper article. Avoid emotional language and flowery descriptions.
  wonderous
    - **Writing Style: Wonderous.** Focus on creating a sense of awe and wonder. Use vivid, imaginative descriptions. The tone is often optimistic, magical, or filled with childlike curiosity.
  stream_of_consciousness
    - **Writing Style: Stream of Consciousness.** Write in a continuous, flowing "train of thought." Leap between thoughts, memories, and sensory inputs. Ignore conventional grammar and punctuation to mimic the raw, unfiltered flow of a character's mind.
  epistolary
    - **Writing Style: Epistolary.** The entire narrative must be told through documents, such as letters, diary entries, emails, blog posts, or text messages. The style of each document should reflect its author, but the overall narrative should be coherent.
  satirical
    - **Writing Style: Satirical.** Use irony, humor, and exaggeration to criticize or mock a subject. The tone should be witty, sharp, and subversive, often taking a cynical or absurd perspective.
  gothic
    - **Writing Style: Gothic.** Use dramatic, moody, and atmospheric language. Build a sense of dread, mystery, and suspense. Focus on dark settings, decaying grandeur, and characters' heightened dark emotions.
  romantic
    - **Writing Style: Romantic.** Emphasize strong emotions, individualism, and the awe-inspiring beauty of nature. The tone is often passionate, awestruck, or melancholic. (This refers to the literary movement, not just love stories).
  realist
    - **Writing Style: Realist.** Focus on the objective, "true-to-life" depiction of everyday people and their social realities. The prose should be straightforward and avoid romanticism, exaggeration, or melodrama.
  naturalist
    - **Writing Style: Naturalist.** A more extreme form of Realism. Portray characters as being controlled by their environment, heredity, and animalistic instincts. The tone is often grim, deterministic, and detached.
  modernist
    - **Writing Style: Modernist.** Focus on the inner, subjective experience of the characters. Experiment with form, fragmented narratives, and non-linear timelines. Often includes themes of alienation and disillusionment.
  existing
    - **Writing Style: Existing.** Use the pre-exisitng StorySoFar to learn the writing style and continue it's formatting.

